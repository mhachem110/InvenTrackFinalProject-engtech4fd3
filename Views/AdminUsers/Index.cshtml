@model InvenTrack.ViewModels.Admin.UserRolesIndexVM
@using System

@{
    ViewData["Title"] = "User Admin";

    var startItem = Model.TotalCount == 0 ? 0 : ((Model.PageIndex - 1) * Model.PageSize) + 1;
    var endItem = Model.TotalCount == 0 ? 0 : Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount);

    var firstPage = Math.Max(1, Model.PageIndex - 2);
    var lastPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">User Admin</h1>
        </div>
        <div class="text-muted small">Admin-only: create users, assign roles, reset passwords, lock/unlock, delete users.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">+ Create User</a>
    </div>
</div>

@if (TempData["RoleMsg"] != null)
{
    <div class="alert alert-success">@TempData["RoleMsg"]</div>
}

<form asp-action="Index" method="get" class="it-panel mb-3">
    <div class="it-panel-body">
        <input type="hidden" id="pageNumber" name="page" value="1" />

        <div class="row g-2 align-items-center">
            <div class="col-lg-5">
                <div class="it-input">
                    <span class="it-input-ico">🔎</span>
                    <input name="q"
                           value="@Model.Query"
                           type="search"
                           class="form-control it-input-field"
                           placeholder="Search by email or username..." />
                </div>
            </div>

            <div class="col-lg-3">
                <select id="pageSize" name="pageSize" class="form-select">
                    <option value="10" selected="@(Model.PageSize == 10 ? "selected" : null)">10 per page</option>
                    <option value="25" selected="@(Model.PageSize == 25 ? "selected" : null)">25 per page</option>
                    <option value="50" selected="@(Model.PageSize == 50 ? "selected" : null)">50 per page</option>
                </select>
            </div>

            <div class="col-lg-4 d-flex justify-content-lg-end gap-2">
                <button type="submit" class="btn btn-primary">Apply</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </div>

        <div class="mt-2 text-muted small">
            Showing @startItem - @endItem of @Model.TotalCount users
        </div>
    </div>
</form>

<div class="it-panel">
    <div class="it-panel-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 it-table">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th style="width:220px;">Username</th>
                        <th style="width:140px;">Role</th>
                        <th style="width:170px;">Status</th>
                        <th class="text-end" style="width:420px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users == null || !Model.Users.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <div class="fw-semibold mb-1">No users found</div>
                                <div class="small">Try a different search.</div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var u in Model.Users)
                        {
                            <tr>
                                <td class="fw-semibold">@u.Email</td>
                                <td class="text-muted">@u.UserName</td>
                                <td>
                                    @if (u.Role == "Admin")
                                    {
                                        <span class="badge bg-primary-subtle text-primary border it-badge">Admin</span>
                                    }
                                    else if (u.Role == "Manager")
                                    {
                                        <span class="badge bg-success-subtle text-success border it-badge">Manager</span>
                                    }
                                    else if (u.Role == "Viewer")
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border it-badge">Viewer</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border it-badge">None</span>
                                    }
                                </td>
                                <td>
                                    @if (u.IsLockedOut)
                                    {
                                        <span class="badge bg-danger-subtle text-danger border it-badge">Locked</span>
                                        <div class="text-muted small mt-1">Until: @(u.LockoutEnd?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success border it-badge">Active</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@u.UserId" class="btn btn-sm btn-outline-primary">Role</a>
                                        <a asp-action="ResetPassword" asp-route-id="@u.UserId" class="btn btn-sm btn-outline-secondary">Reset PW</a>
                                        <a asp-action="Lockout" asp-route-id="@u.UserId" class="btn btn-sm btn-outline-warning">Lock</a>
                                        <a asp-action="Delete" asp-route-id="@u.UserId" class="btn btn-sm btn-outline-danger">Delete</a>
                                    </div>

                                    @if (u.IsLockedOut)
                                    {
                                        <form asp-action="Unlock" asp-route-id="@u.UserId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-success ms-2">Unlock</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 p-3 border-top">
                <div class="text-muted small">
                    Page @Model.PageIndex of @Model.TotalPages
                </div>

                <nav aria-label="User admin pagination">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.PageIndex - 1)"
                               asp-route-q="@Model.Query"
                               asp-route-pageSize="@Model.PageSize">
                                Previous
                            </a>
                        </li>

                        @if (firstPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="1"
                                   asp-route-q="@Model.Query"
                                   asp-route-pageSize="@Model.PageSize">
                                    1
                                </a>
                            </li>

                            @if (firstPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (var p = firstPage; p <= lastPage; p++)
                        {
                            <li class="page-item @(p == Model.PageIndex ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@p"
                                   asp-route-q="@Model.Query"
                                   asp-route-pageSize="@Model.PageSize">
                                    @p
                                </a>
                            </li>
                        }

                        @if (lastPage < Model.TotalPages)
                        {
                            @if (lastPage < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            <li class="page-item">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@Model.TotalPages"
                                   asp-route-q="@Model.Query"
                                   asp-route-pageSize="@Model.PageSize">
                                    @Model.TotalPages
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.PageIndex + 1)"
                               asp-route-q="@Model.Query"
                               asp-route-pageSize="@Model.PageSize">
                                Next
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const pageSize = document.getElementById('pageSize');
            const pageNumber = document.getElementById('pageNumber');

            if (pageSize) {
                pageSize.addEventListener('change', function () {
                    if (pageNumber) pageNumber.value = 1;
                    this.form.submit();
                });
            }
        })();
    </script>
}