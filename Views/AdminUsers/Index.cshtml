@model InvenTrack.ViewModels.Admin.UserRolesIndexVM
@using System
@using InvenTrack.Models
@{
    ViewData["Title"] = "User Admin";
    var startItem = Model.TotalCount == 0 ? 0 : ((Model.PageIndex - 1) * Model.PageSize) + 1;
    var endItem = Model.TotalCount == 0 ? 0 : Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount);
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">User Admin</h1>
        </div>
        <div class="text-muted small">Manage identity, role, department, title, and location scope from one place.</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">+ Create User</a>
    </div>
</div>

@if (TempData["RoleMsg"] != null)
{
    <div class="alert alert-success">@TempData["RoleMsg"]</div>
}

<form asp-action="Index" method="get" class="it-panel mb-3">
    <div class="it-panel-body">
        <div class="row g-2 align-items-center">
            <div class="col-lg-6">
                <input name="q" value="@Model.Query" type="search" class="form-control" placeholder="Search by name, email, title, department, username, or location" />
            </div>
            <div class="col-lg-3">
                <select name="pageSize" class="form-select">
                    <option value="10" selected="@(Model.PageSize == 10)">10 per page</option>
                    <option value="25" selected="@(Model.PageSize == 25)">25 per page</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50 per page</option>
                </select>
            </div>
            <div class="col-lg-3 d-flex gap-2 justify-content-lg-end">
                <button type="submit" class="btn btn-primary">Apply</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </div>
        <div class="text-muted small mt-2">Showing @startItem - @endItem of @Model.TotalCount users</div>
    </div>
</form>

<div class="it-panel">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 it-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Profile</th>
                    <th>Role</th>
                    <th>Location</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Users.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-5">No users found.</td></tr>
                }
                else
                {
                    foreach (var u in Model.Users)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@u.FullName</div>
                                <div class="text-muted small">@u.Email</div>
                                <div class="text-muted small">@u.UserName</div>
                            </td>
                            <td>
                                <div>@u.JobTitle</div>
                                <div class="text-muted small">@u.Department</div>
                            </td>
                            <td><span class="badge bg-light text-dark border it-badge">@u.Role</span></td>
                            <td class="text-muted">@u.AssignedLocationName</td>
                            <td>
                                @if (u.IsLockedOut)
                                {
                                    <span class="badge bg-danger-subtle text-danger border it-badge">Locked</span>
                                    <div class="text-muted small mt-1">Until: @(u.LockoutEnd?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
                                }
                                else
                                {
                                    <span class="badge bg-success-subtle text-success border it-badge">Active</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@u.UserId" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <a asp-action="ResetPassword" asp-route-id="@u.UserId" class="btn btn-sm btn-outline-secondary">Reset PW</a>
                                    <a asp-action="Lockout" asp-route-id="@u.UserId" class="btn btn-sm btn-outline-warning">Lock</a>
                                    <a asp-action="Delete" asp-route-id="@u.UserId" class="btn btn-sm btn-outline-danger">Delete</a>
                                </div>
                                @if (u.IsLockedOut)
                                {
                                    <form asp-action="Unlock" asp-route-id="@u.UserId" method="post" class="d-inline ms-2">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-success">Unlock</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
