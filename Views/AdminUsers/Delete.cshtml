@model InvenTrack.ViewModels.Admin.DeleteUserVM

@{
    ViewData["Title"] = "Delete User";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Delete User</h1>
        </div>
        <div class="text-muted small">This action permanently removes the user.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="it-panel">
    <div class="it-panel-header">
        <div>
            <div class="fw-bold">Confirm deletion</div>
            <div class="text-muted small">User will be removed from Identity (roles, logins, claims, tokens).</div>
        </div>
    </div>

    <div class="it-panel-body">
        @if (Model.IsSelf)
        {
            <div class="alert alert-warning mb-3">
                You cannot delete your own account.
            </div>
        }
        else if (Model.IsLastAdmin)
        {
            <div class="alert alert-warning mb-3">
                You cannot delete the last Admin account.
            </div>
        }
        else
        {
            <div class="alert alert-danger mb-3">
                This is permanent. The user will no longer be able to sign in.
            </div>
        }

        <dl class="row mb-0">
            <dt class="col-sm-3 text-muted">Email</dt>
            <dd class="col-sm-9 fw-semibold">@Model.Email</dd>

            <dt class="col-sm-3 text-muted">Username</dt>
            <dd class="col-sm-9">@Model.UserName</dd>

            <dt class="col-sm-3 text-muted">Role</dt>
            <dd class="col-sm-9">@Model.Role</dd>

            <dt class="col-sm-3 text-muted">Status</dt>
            <dd class="col-sm-9">
                @if (Model.IsLockedOut)
                {
                    <span class="badge bg-danger-subtle text-danger border it-badge">Locked</span>
                    <span class="text-muted small ms-2">Until: @(Model.LockoutEnd?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</span>
                }
                else
                {
                    <span class="badge bg-success-subtle text-success border it-badge">Active</span>
                }
            </dd>
        </dl>

        <div class="mt-4 d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>

            <form asp-action="DeleteConfirmed" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserId" />

                <button type="submit" class="btn btn-danger" @(Model.IsSelf || Model.IsLastAdmin ? "disabled" : "")>
                    Delete Permanently
                </button>
            </form>
        </div>
    </div>
</div>