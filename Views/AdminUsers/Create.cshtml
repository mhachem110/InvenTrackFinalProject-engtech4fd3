@model InvenTrack.ViewModels.Admin.CreateUserVM
@using InvenTrack.Models

@{
    ViewData["Title"] = "Create User";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Create User</h1>
        </div>
        <div class="text-muted small">Create a complete user profile with role, department, title, and location scope.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="it-panel">
    <div class="it-panel-body">
        <div class="it-hint mb-3">
            Admin and Regional Manager are global roles. Manager, Supervisor, and Employee must have an assigned location.
        </div>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="UserName" class="form-label"></label>
                    <input asp-for="UserName" class="form-control" />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="JobTitle" class="form-label"></label>
                    <input asp-for="JobTitle" class="form-control" placeholder="Store Manager, Clerk, Supervisor" />
                    <span asp-validation-for="JobTitle" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Department" class="form-label"></label>
                    <input asp-for="Department" class="form-control" placeholder="Operations, Logistics" />
                    <span asp-validation-for="Department" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="SelectedRole" class="form-label"></label>
                    <select asp-for="SelectedRole" class="form-select" id="roleSelect">
                        @foreach (var r in Model.AvailableRoles)
                        {
                            var label = r == AppRoles.RegionalManager ? "Regional Manager" : r;
                            <option value="@r">@label</option>
                        }
                    </select>
                    <span asp-validation-for="SelectedRole" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="AssignedStorageLocationId" class="form-label"></label>
                    <select asp-for="AssignedStorageLocationId" class="form-select" id="locationSelect">
                        <option value="">No assigned location</option>
                        @foreach (var loc in Model.AvailableLocations)
                        {
                            <option value="@loc.Value">@loc.Text</option>
                        }
                    </select>
                    <span asp-validation-for="AssignedStorageLocationId" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <div class="d-flex gap-2 mt-2">
                        <button type="submit" class="btn btn-primary">Create User</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (() => {
            const roleSelect = document.getElementById('roleSelect');
            const locationSelect = document.getElementById('locationSelect');
            const globalRoles = ['@AppRoles.Admin', '@AppRoles.RegionalManager'];

            function applyRoleRules() {
                if (!roleSelect || !locationSelect) return;
                const isGlobal = globalRoles.includes(roleSelect.value);
                if (isGlobal) {
                    locationSelect.value = '';
                    locationSelect.setAttribute('disabled', 'disabled');
                } else {
                    locationSelect.removeAttribute('disabled');
                }
            }

            roleSelect?.addEventListener('change', applyRoleRules);
            applyRoleRules();
        })();
    </script>
}
