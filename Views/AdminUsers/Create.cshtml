@model InvenTrack.ViewModels.Admin.CreateUserVM

@{
    ViewData["Title"] = "Create User";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Create User</h1>
        </div>
        <div class="text-muted small">Admin-only: create an account and assign a role.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="it-panel">
    <div class="it-panel-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="UserName" class="form-label"></label>
                    <input asp-for="UserName" class="form-control" />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="SelectedRole" class="form-label"></label>
                    <select asp-for="SelectedRole" class="form-select">
                        @foreach (var r in Model.AvailableRoles)
                        {
                            <option value="@r">@r</option>
                        }
                    </select>
                    <span asp-validation-for="SelectedRole" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <div class="form-check form-switch mt-4">
                        <input class="form-check-input" asp-for="EmailConfirmed" />
                        <label class="form-check-label" asp-for="EmailConfirmed">Email Confirmed</label>
                    </div>
                </div>

                <div class="col-12">
                    <div class="d-flex gap-2 mt-2">
                        <button type="submit" class="btn btn-primary">Create User</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}