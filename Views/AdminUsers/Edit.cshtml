@model InvenTrack.ViewModels.Admin.EditUserRoleVM

@{
    ViewData["Title"] = "Edit Role";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Edit Role</h1>
        </div>
        <div class="text-muted small">Assign exactly one role to this user.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="row g-3 g-lg-4">
    <div class="col-lg-7">
        <div class="it-panel">
            <div class="it-panel-header">
                <div>
                    <div class="fw-bold">Role assignment</div>
                    <div class="text-muted small">Admin / Manager / Viewer</div>
                </div>
            </div>

            <div class="it-panel-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="UserId" />

                    <div class="mb-2">
                        <div class="text-muted small">Email</div>
                        <div class="fw-semibold">@Model.Email</div>
                    </div>

                    <div class="mb-2">
                        <div class="text-muted small">Username</div>
                        <div class="fw-semibold">@Model.UserName</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Current role</div>
                        <div class="fw-semibold">@Model.CurrentRole</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SelectedRole" class="form-label"></label>
                        <select asp-for="SelectedRole" class="form-select">
                            @foreach (var r in Model.AvailableRoles)
                            {
                                <option value="@r">@r</option>
                            }
                        </select>
                        <span asp-validation-for="SelectedRole" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">Permissions</div>
                <div class="text-muted small">What each role can do.</div>
            </div>

            <div class="it-panel-body">
                <div class="mb-3">
                    <span class="badge bg-primary-subtle text-primary border it-badge">Admin</span>
                    <div class="text-muted small mt-1">Full access, including delete and user admin.</div>
                </div>

                <div class="mb-3">
                    <span class="badge bg-success-subtle text-success border it-badge">Manager</span>
                    <div class="text-muted small mt-1">Can create/edit items and create stock transactions.</div>
                </div>

                <div>
                    <span class="badge bg-secondary-subtle text-secondary border it-badge">Viewer</span>
                    <div class="text-muted small mt-1">Read-only access to inventory and transaction history.</div>
                </div>
            </div>
        </div>
    </div>
</div>