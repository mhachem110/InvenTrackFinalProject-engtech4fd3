@model InvenTrack.ViewModels.Admin.EditUserRoleVM
@using InvenTrack.Models

@{
    ViewData["Title"] = "Edit Access";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Edit Access</h1>
        </div>
        <div class="text-muted small">Update role, location scope, and profile information.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="row g-3 g-lg-4">
    <div class="col-lg-8">
        <div class="it-panel">
            <div class="it-panel-header">
                <div>
                    <div class="fw-bold">User profile and access</div>
                    <div class="text-muted small">Keep user identity and operational scope aligned.</div>
                </div>
            </div>

            <div class="it-panel-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="UserId" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input class="form-control" value="@Model.Email" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Username</label>
                            <input class="form-control" value="@Model.UserName" disabled />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="JobTitle" class="form-label"></label>
                            <input asp-for="JobTitle" class="form-control" />
                            <span asp-validation-for="JobTitle" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Department" class="form-label"></label>
                            <input asp-for="Department" class="form-control" />
                            <span asp-validation-for="Department" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SelectedRole" class="form-label"></label>
                            <select asp-for="SelectedRole" class="form-select" id="roleSelect">
                                @foreach (var r in Model.AvailableRoles)
                                {
                                    var label = r == AppRoles.RegionalManager ? "Regional Manager" : r;
                                    <option value="@r">@label</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AssignedStorageLocationId" class="form-label"></label>
                            <select asp-for="AssignedStorageLocationId" class="form-select" id="locationSelect">
                                <option value="">No assigned location</option>
                                @foreach (var loc in Model.AvailableLocations)
                                {
                                    <option value="@loc.Value">@loc.Text</option>
                                }
                            </select>
                            <span asp-validation-for="AssignedStorageLocationId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="it-panel mb-3">
            <div class="it-panel-header">
                <div class="fw-bold">Current assignment</div>
                <div class="text-muted small">How this user appears in the app.</div>
            </div>
            <div class="it-panel-body">
                <div class="mb-3">
                    <div class="text-muted small">Current role</div>
                    <div class="fw-semibold">@Model.CurrentRole</div>
                </div>
                <div class="mb-3">
                    <div class="text-muted small">Current location</div>
                    <div class="fw-semibold">@Model.CurrentLocationName</div>
                </div>
                <div>
                    <div class="text-muted small">Profile card</div>
                    <div class="rounded-4 border p-3 bg-body-tertiary">
                        <div class="fw-semibold">@Model.FullName</div>
                        <div class="text-muted small">@Model.JobTitle</div>
                        <div class="text-muted small">@Model.Department</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (() => {
            const roleSelect = document.getElementById('roleSelect');
            const locationSelect = document.getElementById('locationSelect');
            const globalRoles = ['@AppRoles.Admin', '@AppRoles.RegionalManager'];
            function applyRoleRules() {
                if (!roleSelect || !locationSelect) return;
                const isGlobal = globalRoles.includes(roleSelect.value);
                if (isGlobal) {
                    locationSelect.value = '';
                    locationSelect.setAttribute('disabled', 'disabled');
                } else {
                    locationSelect.removeAttribute('disabled');
                }
            }
            roleSelect?.addEventListener('change', applyRoleRules);
            applyRoleRules();
        })();
    </script>
}
