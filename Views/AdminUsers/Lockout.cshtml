@model InvenTrack.ViewModels.Admin.LockoutVM

@{
    ViewData["Title"] = "Lock User";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Lock User</h1>
        </div>
        <div class="text-muted small">Admin-only: lock a user for a number of minutes.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="row g-3 g-lg-4">
    <div class="col-lg-7">
        <div class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">Lockout</div>
                <div class="text-muted small">Set lock duration in minutes.</div>
            </div>

            <div class="it-panel-body">
                <form asp-action="Lockout" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="UserId" />

                    <div class="mb-3">
                        <div class="text-muted small">User</div>
                        <div class="fw-semibold">@Model.Email</div>
                        <div class="text-muted small">@Model.UserName</div>
                    </div>

                    @if (Model.IsLockedOut)
                    {
                        <div class="alert alert-warning">
                            Currently locked until: <strong>@(Model.LockoutEnd?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</strong>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Minutes" class="form-label"></label>
                        <input asp-for="Minutes" class="form-control" />
                        <span asp-validation-for="Minutes" class="text-danger small"></span>
                        <div class="form-text">Example: 60 = 1 hour, 1440 = 1 day</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">Lock User</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>

                <form asp-action="Unlock" asp-route-id="@Model.UserId" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-success">Unlock Now</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">What lockout does</div>
                <div class="text-muted small">Prevents login until the lock ends.</div>
            </div>

            <div class="it-panel-body">
                <div class="text-muted small">
                    Lockout is a safe way to disable access without deleting accounts.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}