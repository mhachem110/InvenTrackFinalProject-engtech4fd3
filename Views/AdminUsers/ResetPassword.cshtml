@model InvenTrack.ViewModels.Admin.ResetPasswordVM

@{
    ViewData["Title"] = "Reset Password";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Reset Password</h1>
        </div>
        <div class="text-muted small">Admin-only: set a new password for this user.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="row g-3 g-lg-4">
    <div class="col-lg-7">
        <div class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">Set New Password</div>
                <div class="text-muted small">Use a strong password with at least 8 characters.</div>
            </div>

            <div class="it-panel-body">
                <form asp-action="ResetPassword" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="UserName" />
                    <input type="hidden" asp-for="FullName" />
                    <input type="hidden" asp-for="JobTitle" />
                    <input type="hidden" asp-for="Department" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NewPassword" class="form-label"></label>
                            <input asp-for="NewPassword" class="form-control" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <input asp-for="ConfirmPassword" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="d-flex gap-2 mt-2">
                                <button type="submit" class="btn btn-primary">Reset Password</button>
                                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">User Details</div>
                <div class="text-muted small">Identity information for the selected account.</div>
            </div>

            <div class="it-panel-body">
                <div class="mb-3">
                    <div class="text-muted small">Email</div>
                    <div class="fw-semibold">@Model.Email</div>
                </div>

                <div class="mb-3">
                    <div class="text-muted small">Username</div>
                    <div class="fw-semibold">@Model.UserName</div>
                </div>

                <div class="mb-3">
                    <div class="text-muted small">Full Name</div>
                    <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.FullName) ? Model.FullName : "-")</div>
                </div>

                <div class="mb-3">
                    <div class="text-muted small">Job Title</div>
                    <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.JobTitle) ? Model.JobTitle : "-")</div>
                </div>

                <div class="mb-0">
                    <div class="text-muted small">Department</div>
                    <div class="fw-semibold">@(!string.IsNullOrWhiteSpace(Model.Department) ? Model.Department : "-")</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}