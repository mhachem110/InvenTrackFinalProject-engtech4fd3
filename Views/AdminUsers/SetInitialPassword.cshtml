@model InvenTrack.ViewModels.Admin.SetInitialPasswordVM

@{
    ViewData["Title"] = "Set Password";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Set Your Password</h1>
        </div>
        <div class="text-muted small">Use the temporary password from your email, then choose your own password.</div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-7 col-xl-5">
        <div class="it-panel">
            <div class="it-panel-header">
                <div>
                    <div class="fw-bold">Account setup</div>
                    <div class="text-muted small">This link is used to finish your account setup.</div>
                </div>
            </div>

            <div class="it-panel-body">
                <form asp-action="SetInitialPassword" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Code" />

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" value="@Model.Email" disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="TemporaryPassword" class="form-label"></label>
                        <input asp-for="TemporaryPassword" class="form-control" autocomplete="one-time-code" />
                        <span asp-validation-for="TemporaryPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label"></label>
                        <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Save Password</button>
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-secondary">Back to Login</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}