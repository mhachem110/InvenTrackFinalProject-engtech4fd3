        <div class="it-home-hero__content">
            <div class="it-home-hero__left">
                <div class="it-home-kicker">Employee Dashboard</div>
                <h1 class="it-home-title">Your inventory workspace</h1>
                <p class="it-home-subtitle">
                    You are currently working within <strong>@assignedLocationName</strong>.
                </p>

                <div class="it-home-badges">
                    <span class="badge bg-light text-dark border it-badge">Scope: @assignedLocationName</span>
                    <span class="badge bg-warning-subtle text-warning border it-badge">Requests Enabled</span>
                </div>

                <div class="it-home-actions mt-3">
                    <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-primary">
                        Browse Inventory
                    </a>

                    <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-outline-light position-relative">
                        Transfer Requests
                        @if (openTransferCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                @openTransferCount
                            </span>
                        }
                    </a>
                </div>
            </div>

            <div class="it-home-hero__right">
                <div class="it-home-mini-panel">
                    <div class="it-home-mini-panel__label">Open Requests</div>
                    <div class="it-home-mini-panel__value">@openTransferCount</div>
                    <div class="it-home-mini-panel__text">Still awaiting completion</div>
                </div>

                <div class="it-home-mini-panel">
                    <div class="it-home-mini-panel__label">Low Stock</div>
                    <div class="it-home-mini-panel__value">@lowStockCount</div>
                    <div class="it-home-mini-panel__text">Items below reorder level</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 g-xl-4 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-stat-card it-stat-card--blue">
                <div class="it-stat-card__top">
                    <span class="it-stat-card__icon">📦</span>
                    <span class="it-stat-card__label">Inventory Items</span>
                </div>
                <div class="it-stat-card__value">@itemCount</div>
                <div class="it-stat-card__meta">Items visible in your assigned location scope.</div>
                <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-sm btn-light mt-3">Browse Inventory</a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-stat-card it-stat-card--amber">
                <div class="it-stat-card__top">
                    <span class="it-stat-card__icon">🔁</span>
                    <span class="it-stat-card__label">Open Requests</span>
                </div>
                <div class="it-stat-card__value">@openTransferCount</div>
                <div class="it-stat-card__meta">Requests still awaiting completion.</div>
                <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-sm btn-light mt-3">Open Requests</a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-stat-card it-stat-card--red">
                <div class="it-stat-card__top">
                    <span class="it-stat-card__icon">⚠️</span>
                    <span class="it-stat-card__label">Low Stock</span>
                </div>
                <div class="it-stat-card__value">@lowStockCount</div>
                <div class="it-stat-card__meta">At or below reorder level in your scope.</div>
                <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-sm btn-light mt-3">View Inventory</a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-stat-card it-stat-card--slate">
                <div class="it-stat-card__top">
                    <span class="it-stat-card__icon">🧾</span>
                    <span class="it-stat-card__label">Transactions</span>
                </div>
