@model object
@using InvenTrack.Data
@using InvenTrack.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject InvenTrackContext Db
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Home";

    bool isAdmin = User.IsInRole(AppRoles.Admin);
    bool isRegionalManager = User.IsInRole(AppRoles.RegionalManager);
    bool isManager = User.IsInRole(AppRoles.Manager);
    bool isSupervisor = User.IsInRole(AppRoles.Supervisor);
    bool isEmployee = User.IsInRole(AppRoles.Employee);

    bool canManage = isAdmin || isRegionalManager || isManager || isSupervisor;
    bool canUseTransferRequests = isAdmin || isRegionalManager || isManager || isSupervisor || isEmployee;
    bool hasGlobalLocationAccess = isAdmin || isRegionalManager;

    var currentUser = await UserManager.GetUserAsync(User);
    int? assignedLocationId = currentUser?.AssignedStorageLocationId;
    string assignedLocationName = "All Locations";

    if (!hasGlobalLocationAccess)
    {
        if (assignedLocationId.HasValue)
        {
            assignedLocationName = await Db.StorageLocations
                .AsNoTracking()
                .Where(l => l.ID == assignedLocationId.Value)
                .Select(l => l.Name)
                .FirstOrDefaultAsync() ?? "-";
        }
        else
        {
            assignedLocationName = "-";
        }
    }

    IQueryable<InventoryItem> inventoryQuery = Db.InventoryItems.AsNoTracking();
    IQueryable<StockTransaction> transactionQuery = Db.StockTransactions
        .AsNoTracking()
        .Include(t => t.InventoryItem)
        .Include(t => t.FromStorageLocation)
        .Include(t => t.ToStorageLocation);

    IQueryable<StorageLocation> locationQuery = Db.StorageLocations.AsNoTracking();
    IQueryable<StockTransferRequest> transferRequestQuery = Db.StockTransferRequests
        .AsNoTracking()
        .Include(r => r.InventoryItem)
        .Include(r => r.FromStorageLocation)
        .Include(r => r.ToStorageLocation);

    if (!hasGlobalLocationAccess && assignedLocationId.HasValue)
    {
        var locationId = assignedLocationId.Value;

        inventoryQuery = inventoryQuery.Where(i =>
            i.StorageLocationID == locationId ||
            Db.InventoryItemStocks.Any(s => s.InventoryItemID == i.ID && s.StorageLocationID == locationId));

        transactionQuery = transactionQuery.Where(t =>
            t.FromStorageLocationID == locationId ||
            t.ToStorageLocationID == locationId);

        locationQuery = locationQuery.Where(l => l.ID == locationId);

        transferRequestQuery = transferRequestQuery.Where(r =>
            r.FromStorageLocationID == locationId ||
            r.ToStorageLocationID == locationId);
    }

    var itemCount = await inventoryQuery.CountAsync();
    var categoryCount = await Db.Categories.AsNoTracking().CountAsync();
    var locationCount = await locationQuery.CountAsync();
    var txCount = await transactionQuery.CountAsync();

    var lowStockCount = await inventoryQuery
        .Where(i => i.QuantityOnHand <= i.ReorderLevel)
        .CountAsync();

    var openTransferCount = await transferRequestQuery
        .Where(r => r.Status != TransferRequestStatus.Approved)
        .CountAsync();

    var latestOpenRequests = await transferRequestQuery
        .Where(r => r.Status != TransferRequestStatus.Approved)
        .OrderBy(r => r.Status == TransferRequestStatus.Pending ? 0 : 1)
        .ThenByDescending(r => r.DateRequested)
        .Take(6)
        .ToListAsync();

    var recentTx = await transactionQuery
        .OrderByDescending(t => t.DateCreated)
        .Take(6)
        .ToListAsync();

    var scopeLabel = hasGlobalLocationAccess ? "All Locations" : assignedLocationName;
}

@if (canManage)
{
    <div class="it-home-hero mb-4">
        <div class="it-home-hero__content">
            <div class="it-home-hero__left">
                <div class="it-home-kicker">Operations Dashboard</div>
                <h1 class="it-home-title">Inventory operations at a glance</h1>
                <p class="it-home-subtitle">
                    Monitor stock, requests, movement, and alerts across <strong>@scopeLabel</strong>.
                </p>

                <div class="it-home-badges">
                    <span class="badge bg-light text-dark border it-badge">Scope: @scopeLabel</span>
                    <span class="badge bg-primary-subtle text-primary border it-badge">Live Queue</span>
                </div>

                <div class="it-home-actions mt-3">
                    <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-primary">
                        Open Inventory
                    </a>

                    @if (canUseTransferRequests)
                    {
                        <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-outline-light position-relative">
                            Transfer Requests
                            @if (openTransferCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    @openTransferCount
                                </span>
                            }
                        </a>
                    }
                </div>
            </div>

            <div class="it-home-hero__right">
                <div class="it-home-mini-panel">
                    <div class="it-home-mini-panel__label">Open Requests</div>
                    <div class="it-home-mini-panel__value">@openTransferCount</div>
                    <div class="it-home-mini-panel__text">Needs review or follow-up</div>
                </div>

                <div class="it-home-mini-panel">
                    <div class="it-home-mini-panel__label">Low Stock</div>
                    <div class="it-home-mini-panel__value">@lowStockCount</div>
                    <div class="it-home-mini-panel__text">Below reorder threshold</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 g-xl-4 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-stat-card it-stat-card--blue">
                <div class="it-stat-card__top">
                    <span class="it-stat-card__icon">📦</span>
                    <span class="it-stat-card__label">Inventory Items</span>
                </div>
                <div class="it-stat-card__value">@itemCount</div>
                <div class="it-stat-card__meta">Track quantities, status, and reorder levels.</div>
                <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-sm btn-light mt-3">Open Inventory</a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-stat-card it-stat-card--slate">
                <div class="it-stat-card__top">
                    <span class="it-stat-card__icon">🧾</span>
                    <span class="it-stat-card__label">Transactions</span>
                </div>
                <div class="it-stat-card__value">@txCount</div>
                <div class="it-stat-card__meta">Recent stock movement in your current scope.</div>
                <a asp-controller="StockTransactions" asp-action="Index" class="btn btn-sm btn-light mt-3">View Transactions</a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-stat-card it-stat-card--amber">
                <div class="it-stat-card__top">
                    <span class="it-stat-card__icon">🔁</span>
                    <span class="it-stat-card__label">Open Requests</span>
                </div>
                <div class="it-stat-card__value">@openTransferCount</div>
                <div class="it-stat-card__meta">Transfer requests that still need attention.</div>
                <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-sm btn-light mt-3">Open Requests</a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-stat-card it-stat-card--red">
                <div class="it-stat-card__top">
                    <span class="it-stat-card__icon">⚠️</span>
                    <span class="it-stat-card__label">Low Stock</span>
                </div>
                <div class="it-stat-card__value">@lowStockCount</div>
                <div class="it-stat-card__meta">Items currently at or below reorder level.</div>
                <a asp-controller="Reports" asp-action="LowStock" class="btn btn-sm btn-light mt-3">Open Low Stock</a>
            </div>
        </div>
    </div>

    <div class="row g-3 g-xl-4">
        <div class="col-12 col-xl-8">
            <div class="it-panel h-100">
                <div class="it-panel-header d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2">
                    <div>
                        <div class="fw-bold">Workspace</div>
                        <div class="text-muted small">Your main actions grouped by task type.</div>
                    </div>

                    <span class="badge bg-primary-subtle text-primary border it-badge">Quick Access</span>
                </div>

                <div class="it-panel-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <div class="it-action-card">
                                <div class="it-action-card__icon">➕</div>
                                <div class="it-action-card__content">
                                    <div class="it-action-card__title">Add inventory item</div>
                                    <div class="it-action-card__text">Create new item records with SKU, quantity, and photo.</div>
                                    <div class="it-action-card__buttons">
                                        <a asp-controller="InventoryItems" asp-action="Create" class="btn btn-primary btn-sm">+ Add Item</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-action-card">
                                <div class="it-action-card__icon">📋</div>
                                <div class="it-action-card__content">
                                    <div class="it-action-card__title">Browse inventory</div>
                                    <div class="it-action-card__text">Search items, stock levels, categories, and locations.</div>
                                    <div class="it-action-card__buttons">
                                        <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-outline-primary btn-sm">View Inventory</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-action-card">
                                <div class="it-action-card__icon">🧾</div>
                                <div class="it-action-card__content">
                                    <div class="it-action-card__title">Stock transactions</div>
                                    <div class="it-action-card__text">Review check-ins, check-outs, adjustments, and transfers.</div>
                                    <div class="it-action-card__buttons">
                                        <a asp-controller="StockTransactions" asp-action="Index" class="btn btn-outline-primary btn-sm">Transactions</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-action-card">
                                <div class="it-action-card__icon">🔁</div>
                                <div class="it-action-card__content">
                                    <div class="it-action-card__title">Transfer requests</div>
                                    <div class="it-action-card__text">Approve, reject, or monitor open stock movement requests.</div>
                                    <div class="it-action-card__buttons">
                                        <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-outline-warning btn-sm">Open Requests</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-action-card">
                                <div class="it-action-card__icon">📊</div>
                                <div class="it-action-card__content">
                                    <div class="it-action-card__title">Reports</div>
                                    <div class="it-action-card__text">Open low stock, transaction summaries, and exports.</div>
                                    <div class="it-action-card__buttons">
                                        <a asp-controller="Reports" asp-action="Index" class="btn btn-outline-primary btn-sm">Reports</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-action-card">
                                <div class="it-action-card__icon">📍</div>
                                <div class="it-action-card__content">
                                    <div class="it-action-card__title">Locations</div>
                                    <div class="it-action-card__text">Review and manage storage locations in your scope.</div>
                                    <div class="it-action-card__buttons">
                                        <a asp-controller="StorageLocations" asp-action="Index" class="btn btn-outline-secondary btn-sm">Locations</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="it-dashboard-note mt-4">
                        Notifications and transfer counts update in real time while the app is open.
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="it-panel h-100">
                <div class="it-panel-header d-flex justify-content-between align-items-start gap-2">
                    <div>
                        <div class="fw-bold">Live Queue</div>
                        <div class="text-muted small">Open transfer requests in your current scope.</div>
                    </div>

                    <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-sm btn-outline-secondary">View All</a>
                </div>

                <div class="it-panel-body">
                    @if (!latestOpenRequests.Any())
                    {
                        <div class="it-empty-state">
                            <div class="it-empty-state__icon">✅</div>
                            <div class="it-empty-state__title">No open requests</div>
                            <div class="it-empty-state__text">Everything is clear right now.</div>
                            <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-outline-primary mt-3">Go to Inventory</a>
                        </div>
                    }
                    else
                    {
                        <div class="it-request-list">
                            @foreach (var r in latestOpenRequests)
                            {
                                <div class="it-request-item">
                                    <div class="it-request-item__icon">
                                        @(r.Status == TransferRequestStatus.Pending ? "⏳" : "⛔")
                                    </div>

                                    <div class="it-request-item__content">
                                        <div class="it-request-item__top">
                                            <div class="fw-semibold text-break">@(r.InventoryItem?.ItemName ?? "-")</div>
                                            <div class="text-muted small">@r.DateRequested.ToLocalTime().ToString("MM-dd HH:mm")</div>
                                        </div>

                                        <div class="text-muted small mt-1">
                                            @if (r.Status == TransferRequestStatus.Pending)
                                            {
                                                <span class="badge bg-warning-subtle text-warning border it-badge">Pending</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-subtle text-danger border it-badge">Rejected</span>
                                            }

                                            <span class="ms-2">Qty: <span class="fw-semibold">@r.Quantity</span></span>
                                        </div>

                                        <div class="text-muted small mt-1 text-break">
                                            @(r.FromStorageLocation?.Name ?? "-") → @(r.ToStorageLocation?.Name ?? "-")
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(r.Notes))
                                        {
                                            <div class="text-muted small mt-1 text-break">
                                                "@r.Notes"
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="d-grid gap-2 d-sm-flex flex-wrap mt-4">
                            <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-primary">Open Requests</a>
                            <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-outline-primary">Inventory</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
