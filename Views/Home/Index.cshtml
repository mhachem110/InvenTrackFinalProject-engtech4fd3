@{
    ViewData["Title"] = "Home";
}

<div class="row g-3 g-lg-4 mb-3">
    <div class="col-lg-4">
        <div class="it-kpi">
            <div class="label">Inventory Items</div>
            <div class="value">—</div>
            <div class="text-muted small mt-2">Track quantities, reorder levels, and status.</div>
            <div class="mt-3">
                <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-primary btn-sm">Open Inventory</a>
                <a asp-controller="InventoryItems" asp-action="Create" class="btn btn-outline-primary btn-sm">Add Item</a>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="it-kpi">
            <div class="label">Categories</div>
            <div class="value">—</div>
            <div class="text-muted small mt-2">Keep classification consistent for reporting.</div>
            <div class="mt-3">
                <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary btn-sm">Manage Categories</a>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="it-kpi">
            <div class="label">Locations</div>
            <div class="value">—</div>
            <div class="text-muted small mt-2">Know exactly where stock is stored.</div>
            <div class="mt-3">
                <a asp-controller="StorageLocations" asp-action="Index" class="btn btn-outline-secondary btn-sm">Manage Locations</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 g-lg-4">
    <div class="col-lg-7">
        <div class="it-panel">
            <div class="it-panel-header d-flex align-items-center justify-content-between">
                <div>
                    <div class="fw-bold">Quick Actions</div>
                    <div class="text-muted small">Jump into common inventory tasks.</div>
                </div>
                <span class="badge text-bg-primary-subtle">Dashboard</span>
            </div>

            <div class="it-panel-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="it-panel p-3">
                            <div class="fw-semibold mb-1">Add a new inventory item</div>
                            <div class="text-muted small mb-3">Create item with SKU, quantity, reorder level, and photo.</div>
                            <a asp-controller="InventoryItems" asp-action="Create" class="btn btn-primary btn-sm">+ Add Item</a>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="it-panel p-3">
                            <div class="fw-semibold mb-1">Browse inventory list</div>
                            <div class="text-muted small mb-3">View current items, quantities, category, and location.</div>
                            <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-outline-primary btn-sm">View Inventory</a>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="it-panel p-3">
                            <div class="fw-semibold mb-1">Manage categories</div>
                            <div class="text-muted small mb-3">Add/edit categories for consistent classification.</div>
                            <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary btn-sm">Categories</a>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="it-panel p-3">
                            <div class="fw-semibold mb-1">Manage storage locations</div>
                            <div class="text-muted small mb-3">Add/edit locations (building/room) to organize inventory.</div>
                            <a asp-controller="StorageLocations" asp-action="Index" class="btn btn-outline-secondary btn-sm">Locations</a>
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-muted small">
                    Next step: Low-stock alerts & reporting exports (coming soon).
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="it-panel h-100">
            <div class="it-panel-header">
                <div class="fw-bold">Recent Activity</div>
                <div class="text-muted small">What changed lately (placeholder for now).</div>
            </div>

            <div class="it-panel-body">
                <div class="d-flex gap-3 mb-3">
                    <div class="it-logo" style="width:36px;height:36px;border-radius:12px;">✓</div>
                    <div>
                        <div class="fw-semibold">Seed data loaded</div>
                        <div class="text-muted small">Sample items, categories, and locations are ready.</div>
                    </div>
                </div>

                <div class="d-flex gap-3 mb-3">
                    <div class="it-logo" style="width:36px;height:36px;border-radius:12px;">↺</div>
                    <div>
                        <div class="fw-semibold">Migrations applied</div>
                        <div class="text-muted small">Database is synced with the latest model changes.</div>
                    </div>
                </div>

                <div class="d-flex gap-3">
                    <div class="it-logo" style="width:36px;height:36px;border-radius:12px;">★</div>
                    <div>
                        <div class="fw-semibold">UI improvements</div>
                        <div class="text-muted small">Cleaner layout for inventory workflows.</div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-grid gap-2">
                    <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-outline-primary">Go to Inventory</a>
                    <a asp-controller="InventoryItems" asp-action="Create" class="btn btn-primary">Add Item</a>
                </div>
            </div>
        </div>
    </div>
</div>