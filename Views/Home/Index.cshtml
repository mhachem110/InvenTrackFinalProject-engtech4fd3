        </div>
    </div>

    <div class="row g-3 g-xl-4">
        <div class="col-12 col-xl-8">
            <div class="it-panel h-100">
                <div class="it-panel-header">
                    <div class="fw-bold">Workspace</div>
                    <div class="text-muted small">Actions available in your assigned location.</div>
                </div>

                <div class="it-panel-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <div class="it-action-card">
                                <div class="it-action-card__icon">📋</div>
                                <div class="it-action-card__content">
                                    <div class="it-action-card__title">Browse inventory</div>
                                    <div class="it-action-card__text">Search and open inventory items in your visible scope.</div>
                                    <div class="it-action-card__buttons">
                                        <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-primary btn-sm">Go to Inventory</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-action-card">
                                <div class="it-action-card__icon">🔁</div>
                                <div class="it-action-card__content">
                                    <div class="it-action-card__title">Request transfer</div>
                                    <div class="it-action-card__text">Submit stock transfer requests for approval.</div>
                                    <div class="it-action-card__buttons">
                                        <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-outline-warning btn-sm">Transfer Requests</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-action-card">
                                <div class="it-action-card__icon">🔍</div>
                                <div class="it-action-card__content">
                                    <div class="it-action-card__title">View item details</div>
                                    <div class="it-action-card__text">Inspect stock, location, photo, and recent activity.</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-action-card">
                                <div class="it-action-card__icon">🔔</div>
                                <div class="it-action-card__content">
                                    <div class="it-action-card__title">Watch notifications</div>
                                    <div class="it-action-card__text">Track transfer request activity using the bell indicator.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="it-dashboard-note mt-4">
                        Keep an eye on open requests and low-stock items in your assigned location.
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="it-panel h-100">
                <div class="it-panel-header d-flex justify-content-between align-items-start gap-2">
                    <div>
                        <div class="fw-bold">Live Queue</div>
                        <div class="text-muted small">Requests visible in your current scope.</div>
                    </div>

                    <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-sm btn-outline-secondary">View All</a>
                </div>

                <div class="it-panel-body">
                    @if (!latestOpenRequests.Any())
                    {
                        <div class="it-empty-state">
                            <div class="it-empty-state__icon">✅</div>
                            <div class="it-empty-state__title">No open requests</div>
                            <div class="it-empty-state__text">Nothing pending right now.</div>
                            <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-outline-primary mt-3">Browse Inventory</a>
                        </div>
                    }
                    else
                    {
                        <div class="it-request-list">
                            @foreach (var r in latestOpenRequests)
                            {
                                <div class="it-request-item">
                                    <div class="it-request-item__icon">
                                        @(r.Status == TransferRequestStatus.Pending ? "⏳" : "⛔")
                                    </div>

                                    <div class="it-request-item__content">
                                        <div class="it-request-item__top">
                                            <div class="fw-semibold text-break">@(r.InventoryItem?.ItemName ?? "-")</div>
                                            <div class="text-muted small">@r.DateRequested.ToLocalTime().ToString("MM-dd HH:mm")</div>
                                        </div>

                                        <div class="text-muted small mt-1">
                                            @if (r.Status == TransferRequestStatus.Pending)
                                            {
                                                <span class="badge bg-warning-subtle text-warning border it-badge">Pending</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-subtle text-danger border it-badge">Rejected</span>
                                            }

                                            <span class="ms-2">Qty: <span class="fw-semibold">@r.Quantity</span></span>
                                        </div>

                                        <div class="text-muted small mt-1 text-break">
                                            @(r.FromStorageLocation?.Name ?? "-") → @(r.ToStorageLocation?.Name ?? "-")
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-primary">Open Requests</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}