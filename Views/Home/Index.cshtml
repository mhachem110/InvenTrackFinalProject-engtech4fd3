@model object
@using InvenTrack.Data
@using InvenTrack.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject InvenTrackContext Db
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Home";

    bool isAdmin = User.IsInRole(AppRoles.Admin);
    bool isRegionalManager = User.IsInRole(AppRoles.RegionalManager);
    bool isManager = User.IsInRole(AppRoles.Manager);
    bool isSupervisor = User.IsInRole(AppRoles.Supervisor);
    bool isEmployee = User.IsInRole(AppRoles.Employee);

    bool canManage = isAdmin || isRegionalManager || isManager || isSupervisor;
    bool canUseTransferRequests = isAdmin || isRegionalManager || isManager || isSupervisor || isEmployee;
    bool hasGlobalLocationAccess = isAdmin || isRegionalManager;

    var currentUser = await UserManager.GetUserAsync(User);
    int? assignedLocationId = currentUser?.AssignedStorageLocationId;
    string assignedLocationName = "All Locations";

    if (!hasGlobalLocationAccess)
    {
        if (assignedLocationId.HasValue)
        {
            assignedLocationName = await Db.StorageLocations
                .AsNoTracking()
                .Where(l => l.ID == assignedLocationId.Value)
                .Select(l => l.Name)
                .FirstOrDefaultAsync() ?? "-";
        }
        else
        {
            assignedLocationName = "-";
        }
    }

    IQueryable<InventoryItem> inventoryQuery = Db.InventoryItems.AsNoTracking();
    IQueryable<StockTransaction> transactionQuery = Db.StockTransactions
        .AsNoTracking()
        .Include(t => t.InventoryItem)
        .Include(t => t.FromStorageLocation)
        .Include(t => t.ToStorageLocation);

    IQueryable<StorageLocation> locationQuery = Db.StorageLocations.AsNoTracking();
    IQueryable<StockTransferRequest> transferRequestQuery = Db.StockTransferRequests
        .AsNoTracking()
        .Include(r => r.InventoryItem)
        .Include(r => r.FromStorageLocation)
        .Include(r => r.ToStorageLocation);

    if (!hasGlobalLocationAccess && assignedLocationId.HasValue)
    {
        var locationId = assignedLocationId.Value;

        inventoryQuery = inventoryQuery.Where(i =>
            i.StorageLocationID == locationId ||
            Db.InventoryItemStocks.Any(s => s.InventoryItemID == i.ID && s.StorageLocationID == locationId));

        transactionQuery = transactionQuery.Where(t =>
            t.FromStorageLocationID == locationId ||
            t.ToStorageLocationID == locationId);

        locationQuery = locationQuery.Where(l => l.ID == locationId);

        transferRequestQuery = transferRequestQuery.Where(r =>
            r.FromStorageLocationID == locationId ||
            r.ToStorageLocationID == locationId);
    }

    var itemCount = await inventoryQuery.CountAsync();
    var categoryCount = await Db.Categories.AsNoTracking().CountAsync();
    var locationCount = await locationQuery.CountAsync();
    var txCount = await transactionQuery.CountAsync();

    var lowStockCount = await inventoryQuery
        .Where(i => i.QuantityOnHand <= i.ReorderLevel)
        .CountAsync();

    var openTransferCount = await transferRequestQuery
        .Where(r => r.Status != TransferRequestStatus.Approved)
        .CountAsync();

    var recentTx = await transactionQuery
        .OrderByDescending(t => t.DateCreated)
        .Take(8)
        .ToListAsync();

    var latestOpenRequests = await transferRequestQuery
        .Where(r => r.Status != TransferRequestStatus.Approved)
        .OrderBy(r => r.Status == TransferRequestStatus.Pending ? 0 : 1)
        .ThenByDescending(r => r.DateRequested)
        .Take(6)
        .ToListAsync();
}

@if (canManage)
{
    <div class="it-panel mb-3">
        <div class="it-panel-body d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3">
            <div>
                <div class="fw-bold">Operations Dashboard</div>
                <div class="text-muted small">
                    @(hasGlobalLocationAccess ? "You are viewing all locations." : $"You are scoped to: {assignedLocationName}.")
                </div>
            </div>

            @if (canUseTransferRequests)
            {
                <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-outline-primary position-relative">
                    Open Transfer Requests
                    @if (openTransferCount > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            @openTransferCount
                        </span>
                    }
                </a>
            }
        </div>
    </div>

    <div class="row g-3 g-lg-4 mb-3">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-kpi">
                <div class="label">Inventory Items</div>
                <div class="value">@itemCount</div>
                <div class="text-muted small mt-2">Track quantities, reorder levels, and status.</div>
                <div class="mt-3 d-grid gap-2 d-sm-flex flex-wrap">
                    <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-primary btn-sm">Open Inventory</a>
                    <a asp-controller="InventoryItems" asp-action="Create" class="btn btn-outline-primary btn-sm">Add Item</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-kpi">
                <div class="label">Transactions</div>
                <div class="value">@txCount</div>
                <div class="text-muted small mt-2">Recent stock movement in your current scope.</div>
                <div class="mt-3 d-grid gap-2 d-sm-flex flex-wrap">
                    <a asp-controller="StockTransactions" asp-action="Index" class="btn btn-outline-primary btn-sm">View Transactions</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-kpi">
                <div class="label">Open Requests</div>
                <div class="value">@openTransferCount</div>
                <div class="text-muted small mt-2">Transfer requests that still need attention.</div>
                <div class="mt-3 d-grid gap-2 d-sm-flex flex-wrap">
                    <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-outline-warning btn-sm">Open Requests</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-kpi">
                <div class="label">Low Stock Items</div>
                <div class="value">@lowStockCount</div>
                <div class="text-muted small mt-2">Items currently at or below reorder level.</div>
                <div class="mt-3 d-grid gap-2 d-sm-flex flex-wrap">
                    <a asp-controller="Reports" asp-action="LowStock" class="btn btn-outline-secondary btn-sm">Open Low Stock</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 g-lg-4 align-items-stretch">
        <div class="col-12 col-xl-7">
            <div class="it-panel h-100">
                <div class="it-panel-header d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-2">
                    <div>
                        <div class="fw-bold">Quick Actions</div>
                        <div class="text-muted small">Jump into common inventory and request tasks.</div>
                    </div>
                    <span class="badge text-bg-primary-subtle">Dashboard</span>
                </div>

                <div class="it-panel-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <div class="it-panel p-3 h-100">
                                <div class="fw-semibold mb-1">Add a new inventory item</div>
                                <div class="text-muted small mb-3">Create item with SKU, quantity, reorder level, and photo.</div>
                                <div class="d-grid d-sm-flex gap-2">
                                    <a asp-controller="InventoryItems" asp-action="Create" class="btn btn-primary btn-sm">+ Add Item</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-panel p-3 h-100">
                                <div class="fw-semibold mb-1">Browse inventory list</div>
                                <div class="text-muted small mb-3">View current items, quantities, category, and location.</div>
                                <div class="d-grid d-sm-flex gap-2">
                                    <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-outline-primary btn-sm">View Inventory</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-panel p-3 h-100">
                                <div class="fw-semibold mb-1">Record a stock transaction</div>
                                <div class="text-muted small mb-3">Check in, check out, adjust stock, or transfer items.</div>
                                <div class="d-grid d-sm-flex gap-2">
                                    <a asp-controller="StockTransactions" asp-action="Index" class="btn btn-outline-primary btn-sm">Transactions</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-panel p-3 h-100">
                                <div class="fw-semibold mb-1">Review transfer requests</div>
                                <div class="text-muted small mb-3">Approve, reject, or track requests in real time.</div>
                                <div class="d-grid d-sm-flex gap-2">
                                    <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-outline-warning btn-sm">Transfer Requests</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-panel p-3 h-100">
                                <div class="fw-semibold mb-1">Open reports</div>
                                <div class="text-muted small mb-3">Low stock, location summary, recent transactions, and CSV export.</div>
                                <div class="d-grid d-sm-flex gap-2">
                                    <a asp-controller="Reports" asp-action="Index" class="btn btn-outline-primary btn-sm">Reports</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6">
                            <div class="it-panel p-3 h-100">
                                <div class="fw-semibold mb-1">Manage locations</div>
                                <div class="text-muted small mb-3">Review location setup for your current scope.</div>
                                <div class="d-grid d-sm-flex gap-2">
                                    <a asp-controller="StorageLocations" asp-action="Index" class="btn btn-outline-secondary btn-sm">Locations</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 text-muted small">
                        Notifications and transfer request counts update in real time while this app is open.
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="it-panel h-100">
                <div class="it-panel-header d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-2">
                    <div>
                        <div class="fw-bold">Open Transfer Requests</div>
                        <div class="text-muted small">Live operational queue for your current scope.</div>
                    </div>

                    <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                        View All
                    </a>
                </div>

                <div class="it-panel-body">
                    @if (!latestOpenRequests.Any())
                    {
                        <div class="text-muted small">
                            No open transfer requests right now.
                        </div>

                        <div class="d-grid gap-2 mt-3">
                            <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-outline-primary">Go to Inventory</a>
                        </div>
                    }
                    else
                    {
                        @foreach (var r in latestOpenRequests)
                        {
                            <div class="d-flex align-items-start gap-3 mb-3">
                                <div class="it-logo flex-shrink-0" style="width:36px;height:36px;border-radius:12px;">
                                    @(r.Status == TransferRequestStatus.Pending ? "⏳" : "⛔")
                                </div>

                                <div class="w-100 min-w-0">
                                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start gap-1">
                                        <div class="fw-semibold text-break">@(r.InventoryItem?.ItemName ?? "-")</div>
                                        <div class="text-muted small flex-shrink-0">@r.DateRequested.ToLocalTime().ToString("MM-dd HH:mm")</div>
                                    </div>

                                    <div class="text-muted small text-break">
                                        @if (r.Status == TransferRequestStatus.Pending)
                                        {
                                            <span class="badge bg-warning-subtle text-warning border it-badge">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border it-badge">Rejected</span>
                                        }

                                        <span class="ms-2">Qty: <span class="fw-semibold">@r.Quantity</span></span>
                                        <span class="ms-2">@(r.FromStorageLocation?.Name ?? "-") → @(r.ToStorageLocation?.Name ?? "-")</span>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(r.Notes))
                                    {
                                        <div class="text-muted small mt-1 text-break">
                                            "@r.Notes"
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <hr class="my-3" />

                        <div class="d-grid gap-2 d-sm-flex flex-wrap">
                            <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-primary">Open Requests</a>
                            <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-outline-primary">Go to Inventory</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="it-panel mb-3">
        <div class="it-panel-body d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3">
            <div>
                <div class="fw-bold">Employee Dashboard</div>
                <div class="text-muted small">
                    You are scoped to: @assignedLocationName
                </div>
            </div>

            @if (canUseTransferRequests)
            {
                <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-outline-primary position-relative">
                    Transfer Requests
                    @if (openTransferCount > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            @openTransferCount
                        </span>
                    }
                </a>
            }
        </div>
    </div>

    <div class="row g-3 g-lg-4 mb-3">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-kpi">
                <div class="label">Inventory Items</div>
                <div class="value">@itemCount</div>
                <div class="text-muted small mt-2">Items visible in your assigned location scope.</div>
                <div class="mt-3 d-grid gap-2">
                    <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-primary btn-sm">Browse Inventory</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-kpi">
                <div class="label">Open Requests</div>
                <div class="value">@openTransferCount</div>
                <div class="text-muted small mt-2">Requests still awaiting completion.</div>
                <div class="mt-3 d-grid gap-2">
                    <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-outline-warning btn-sm">Open Requests</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-kpi">
                <div class="label">Low Stock</div>
                <div class="value">@lowStockCount</div>
                <div class="text-muted small mt-2">Items at or below reorder level in your scope.</div>
                <div class="mt-3 d-grid gap-2">
                    <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-outline-secondary btn-sm">View Inventory</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-kpi">
                <div class="label">Transactions</div>
                <div class="value">@txCount</div>
                <div class="text-muted small mt-2">Recent stock movement visible to you.</div>
                <div class="mt-3 d-grid gap-2">
                    <a asp-controller="StockTransactions" asp-action="Index" class="btn btn-outline-secondary btn-sm">View Transactions</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 g-lg-4">
        <div class="col-12 col-xl-7">
            <div class="it-panel h-100">
                <div class="it-panel-header">
                    <div class="fw-bold">Employee Actions</div>
                    <div class="text-muted small">What you can do in your assigned location.</div>
                </div>

                <div class="it-panel-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="it-mini h-100">
                                <div class="it-mini-title">Browse inventory</div>
                                <div class="text-muted small">
                                    Search and open inventory items available in your assigned location scope.
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="it-mini h-100">
                                <div class="it-mini-title">View item details</div>
                                <div class="text-muted small">
                                    Open details pages to inspect stock, photos, and transaction history.
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="it-mini h-100">
                                <div class="it-mini-title">Request stock transfers</div>
                                <div class="text-muted small">
                                    Submit transfer requests when items need to move between locations.
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="it-mini h-100">
                                <div class="it-mini-title">Watch notifications</div>
                                <div class="text-muted small">
                                    Use the bell button at the top to keep track of open transfer requests.
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-sm-flex flex-wrap mt-4">
                        <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-primary">Go to Inventory</a>
                        <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-outline-warning">Transfer Requests</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="it-panel h-100">
                <div class="it-panel-header d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-2">
                    <div>
                        <div class="fw-bold">Open Transfer Requests</div>
                        <div class="text-muted small">Requests visible in your current scope.</div>
                    </div>

                    <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                        View All
                    </a>
                </div>

                <div class="it-panel-body">
                    @if (!latestOpenRequests.Any())
                    {
                        <div class="text-muted small">
                            No open transfer requests right now.
                        </div>

                        <div class="d-grid gap-2 mt-3">
                            <a asp-controller="InventoryItems" asp-action="Index" class="btn btn-outline-primary">Browse Inventory</a>
                        </div>
                    }
                    else
                    {
                        @foreach (var r in latestOpenRequests)
                        {
                            <div class="d-flex align-items-start gap-3 mb-3">
                                <div class="it-logo flex-shrink-0" style="width:36px;height:36px;border-radius:12px;">
                                    @(r.Status == TransferRequestStatus.Pending ? "⏳" : "⛔")
                                </div>

                                <div class="w-100 min-w-0">
                                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start gap-1">
                                        <div class="fw-semibold text-break">@(r.InventoryItem?.ItemName ?? "-")</div>
                                        <div class="text-muted small flex-shrink-0">@r.DateRequested.ToLocalTime().ToString("MM-dd HH:mm")</div>
                                    </div>

                                    <div class="text-muted small text-break">
                                        @if (r.Status == TransferRequestStatus.Pending)
                                        {
                                            <span class="badge bg-warning-subtle text-warning border it-badge">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border it-badge">Rejected</span>
                                        }

                                        <span class="ms-2">Qty: <span class="fw-semibold">@r.Quantity</span></span>
                                        <span class="ms-2">@(r.FromStorageLocation?.Name ?? "-") → @(r.ToStorageLocation?.Name ?? "-")</span>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(r.Notes))
                                    {
                                        <div class="text-muted small mt-1 text-break">
                                            "@r.Notes"
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <hr class="my-3" />

                        <div class="d-grid gap-2">
                            <a asp-controller="StockTransferRequests" asp-action="Index" class="btn btn-primary">Open Requests</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}