@model InvenTrack.ViewModels.Chat.ManageMembersVM
@{
    ViewData["Title"] = "Manage Chat Members";
}
<div class="row g-3">
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header fw-bold">Current Members</div>
            <div class="card-body">
                @foreach (var member in Model.Members)
                {
                    <div class="d-flex justify-content-between align-items-center border rounded p-2 mb-2">
                        <div>@member.DisplayName @(member.IsAdmin ? "• Admin" : "")</div>
                        @if (!member.IsAdmin)
                        {
                            <form asp-action="RemoveMember" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="conversationId" value="@Model.ConversationId" />
                                <input type="hidden" name="memberUserId" value="@member.UserId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header fw-bold">Add Members</div>
            <div class="card-body">
                <form asp-action="AddMembers" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ConversationId" />
                    @foreach (var user in Model.AvailableUsers)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="SelectedUserIds" value="@user.UserId" id="add_@user.UserId" />
                            <label class="form-check-label" for="add_@user.UserId">@user.DisplayName <span class="text-muted">(@user.Email)</span></label>
                        </div>
                    }
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">Add Selected</button>
                        <a asp-action="Index" asp-route-id="@Model.ConversationId" class="btn btn-outline-secondary">Back to Chat</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
