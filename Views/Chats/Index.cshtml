@model InvenTrack.ViewModels.Chat.ChatConversationPageVM
@{
    ViewData["Title"] = "Chat";
}

<div class="it-chat-page">
    <section class="it-chat-shell">
        <aside class="it-chat-sidebar">
            <div class="it-chat-panel it-chat-panel--sidebar">
                <div class="it-chat-sidebar__head">
                    <div>
                        <div class="it-chat-kicker">Messaging</div>
                        <h1 class="it-chat-title">Conversations</h1>
                        <div class="it-chat-subtitle">Direct and group discussions for inventory coordination.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="CreateDirect" class="btn btn-sm btn-outline-primary">Direct</a>
                        <a asp-action="CreateGroup" class="btn btn-sm btn-primary">Group</a>
                    </div>
                </div>

                <div class="it-chat-conversation-list">
                    @foreach (var c in Model.SidebarConversations)
                    {
                        var isActive = c.ConversationId == Model.ConversationId;
                        var initial = !string.IsNullOrWhiteSpace(c.Name) ? c.Name.Substring(0, 1).ToUpperInvariant() : "C";

                        <a asp-action="Index"
                           asp-route-id="@c.ConversationId"
                           class="it-chat-conversation @(isActive ? "is-active" : "")">
                            <div class="it-chat-conversation__avatar">@initial</div>

                            <div class="it-chat-conversation__body">
                                <div class="it-chat-conversation__top">
                                    <div class="it-chat-conversation__name">@c.Name</div>
                                    <div class="it-chat-conversation__time">@((c.LastMessageAt?.ToLocalTime().ToString("MM-dd HH:mm")) ?? "")</div>
                                </div>

                                <div class="it-chat-conversation__preview">@c.LastMessagePreview</div>
                            </div>

                            @if (c.UnreadCount > 0)
                            {
                                <span class="it-chat-conversation__badge">@c.UnreadCount</span>
                            }
                        </a>
                    }
                </div>
            </div>
        </aside>

        <main class="it-chat-main">
            <section class="it-chat-panel it-chat-panel--main">
                <header class="it-chat-thread-head">
                    <div class="it-chat-thread-head__identity">
                        <div class="it-chat-thread-head__avatar">
                            @(string.IsNullOrWhiteSpace(Model.ConversationName) ? "C" : Model.ConversationName.Substring(0, 1).ToUpperInvariant())
                        </div>
                        <div>
                            <div class="it-chat-thread-head__title">@Model.ConversationName</div>
                            <div class="it-chat-thread-head__meta">@Model.CurrentUserMemberCount member(s) in this conversation</div>
                        </div>
                    </div>

                    @if (Model.CurrentUserCanManageMembers)
                    {
                        <a asp-action="ManageMembers" asp-route-id="@Model.ConversationId" class="btn btn-sm btn-outline-secondary">Manage Members</a>
                    }
                </header>

                <div id="chatMessages" class="it-chat-messages">
                    @foreach (var m in Model.Messages)
                    {
                        var alignClass = m.IsMine ? "is-mine" : "is-theirs";
                        var toneClass = m.IsSystemMessage ? "is-system" : (m.IsMine ? "is-mine" : "is-theirs");
                        var senderInitial = !string.IsNullOrWhiteSpace(m.SenderDisplayName) ? m.SenderDisplayName.Substring(0, 1).ToUpperInvariant() : "U";

                        <div class="it-chat-message-row @alignClass">
                            @if (!m.IsMine)
                            {
                                <div class="it-chat-message__avatar">@senderInitial</div>
                            }

                            <article class="it-chat-bubble @toneClass">
                                <div class="it-chat-bubble__sender">@m.SenderDisplayName</div>
                                <div class="it-chat-bubble__body">@m.Body</div>
                                <div class="it-chat-bubble__meta">@m.DateSentDisplay</div>
                            </article>
                        </div>
                    }
                </div>

                <footer class="it-chat-composer">
                    <div id="chatAlert" class="alert alert-info py-2 px-3 d-none mb-3"></div>

                    <form asp-action="SendMessage" method="post" class="it-chat-composer__form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="conversationId" value="@Model.ConversationId" />

                        <div class="it-chat-composer__field">
                            <label class="it-chat-composer__label" for="chatBody">Message</label>
                            <textarea id="chatBody"
                                      name="body"
                                      class="form-control it-chat-composer__textarea"
                                      rows="2"
                                      placeholder="Type your message..."
                                      required></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary it-chat-composer__button">Send</button>
                    </form>
                </footer>
            </section>

            <section class="it-chat-panel it-chat-panel--members">
                <div class="it-chat-members__head">
                    <div class="fw-bold">Members</div>
                    <div class="text-muted small">People currently in this conversation.</div>
                </div>

                <div class="it-chat-members">
                    @foreach (var member in Model.Members)
                    {
                        var memberInitial = !string.IsNullOrWhiteSpace(member.DisplayName) ? member.DisplayName.Substring(0, 1).ToUpperInvariant() : "U";

                        <div class="it-chat-member-chip">
                            <span class="it-chat-member-chip__avatar">@memberInitial</span>
                            <span class="it-chat-member-chip__name">@member.DisplayName@(member.IsAdmin ? " - Admin" : "")</span>
                        </div>
                    }
                </div>
            </section>
        </main>
    </section>
</div>

@section Scripts {
<script>
(() => {
    const messages = document.getElementById('chatMessages');
    const alertBox = document.getElementById('chatAlert');

    function escapeHtml(text) {
        return (text || '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    function scrollToBottom() {
        if (messages) messages.scrollTop = messages.scrollHeight;
    }

    function getInitial(text) {
        const value = (text || '').trim();
        return value ? value.substring(0, 1).toUpperCase() : 'U';
    }

    function appendMessage(payload) {
        if (!messages || !payload) return;

        const wrap = document.createElement('div');
        const rowClass = payload.isMine ? 'is-mine' : 'is-theirs';
        const bubbleClass = payload.isSystemMessage ? 'is-system' : (payload.isMine ? 'is-mine' : 'is-theirs');

        wrap.className = `it-chat-message-row ${rowClass}`;

        wrap.innerHTML = `
            ${payload.isMine ? '' : `<div class="it-chat-message__avatar">${escapeHtml(getInitial(payload.senderDisplayName))}</div>`}
            <article class="it-chat-bubble ${bubbleClass}">
                <div class="it-chat-bubble__sender">${escapeHtml(payload.senderDisplayName)}</div>
                <div class="it-chat-bubble__body">${escapeHtml(payload.body)}</div>
                <div class="it-chat-bubble__meta">${escapeHtml(payload.dateSent)}</div>
            </article>`;

        messages.appendChild(wrap);
        scrollToBottom();
    }

    function showAlert(message) {
        if (!alertBox) return;
        alertBox.textContent = message;
        alertBox.classList.remove('d-none');
        setTimeout(() => alertBox.classList.add('d-none'), 3500);
    }

    scrollToBottom();

    if (window.invenTrackChat && typeof window.invenTrackChat.registerActiveConversation === 'function') {
        window.invenTrackChat.registerActiveConversation(@Model.ConversationId);
    }

    document.addEventListener('inventrack:chat-message', async (event) => {
        const payload = event.detail;
        if (!payload || Number(payload.conversationId) !== @Model.ConversationId) return;

        appendMessage({
            senderDisplayName: payload.senderDisplayName,
            body: payload.body,
            dateSent: payload.dateSent,
            isMine: payload.senderUserId === '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value',
            isSystemMessage: payload.isSystemMessage
        });

        try {
            await fetch(`/Chats/MarkRead?conversationId=@Model.ConversationId`, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
        } catch {
        }
    });

    document.addEventListener('inventrack:chat-members-changed', (event) => {
        const payload = event.detail;
        if (!payload || Number(payload.conversationId) !== @Model.ConversationId) return;
        showAlert('Conversation members were updated. Refreshing chat...');
        setTimeout(() => window.location.reload(), 800);
    });
})();
</script>
}
