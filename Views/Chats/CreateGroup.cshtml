@model InvenTrack.ViewModels.Chat.CreateGroupChatVM
@{
    ViewData["Title"] = "New Group Chat";
}
<div class="card shadow-sm mx-auto" style="max-width:800px;">
    <div class="card-header fw-bold">Create Group Chat</div>
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="GroupName" class="form-label"></label>
                <input asp-for="GroupName" class="form-control" />
                <span asp-validation-for="GroupName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Members</label>
                @foreach (var user in Model.Users)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="SelectedUserIds" value="@user.UserId" id="user_@user.UserId" />
                        <label class="form-check-label" for="user_@user.UserId">@user.DisplayName <span class="text-muted">(@user.Email)</span></label>
                    </div>
                }
                <span asp-validation-for="SelectedUserIds" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Group</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </div>
        </form>
    </div>
</div>
