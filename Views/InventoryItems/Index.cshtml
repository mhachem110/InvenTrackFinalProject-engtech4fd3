@model IEnumerable<InvenTrack.Models.InventoryItem>
@using System

@{
    ViewData["Title"] = "Inventory";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Inventory</h1>
        </div>
        <div class="text-muted small">Browse and manage items, quantities, and locations.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">
            + Add Item
        </a>
    </div>
</div>

<div class="it-panel mb-3">
    <div class="it-panel-body">
        <div class="row g-2 align-items-center">
            <div class="col-lg-6">
                <div class="it-input">
                    <span class="it-input-ico">🔎</span>
                    <input id="invSearch" type="search" class="form-control it-input-field"
                           placeholder="Search by name, SKU, category, location..." />
                </div>
            </div>

            <div class="col-lg-3">
                <select id="invStatus" class="form-select">
                    <option value="all" selected>All statuses</option>
                    <option value="active">Active only</option>
                    <option value="inactive">Inactive only</option>
                </select>
            </div>

            <div class="col-lg-3 text-lg-end">
                <span class="text-muted small" id="invCount"></span>
            </div>
        </div>
    </div>
</div>

<div class="it-panel">
    <div class="it-panel-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 it-table" id="invTable">
                <thead>
                    <tr>
                        <th style="width:92px;">Photo</th>
                        <th>Item</th>
                        <th style="width:150px;">SKU</th>
                        <th style="width:140px;">On Hand</th>
                        <th style="width:180px;">Category</th>
                        <th style="width:190px;">Location</th>
                        <th style="width:120px;">Status</th>
                        <th class="text-end" style="width:220px;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <div class="fw-semibold mb-1">No inventory items yet</div>
                                <div class="small mb-3">Create your first item to start tracking inventory.</div>
                                <a asp-action="Create" class="btn btn-primary btn-sm">+ Add Item</a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var status = item.IsActive ? "active" : "inactive";
                            <tr class="inv-row" data-status="@status">
                                <td>
                                    @if (item.ItemThumbnail?.Content != null && item.ItemThumbnail.Content.Length > 0)
                                    {
                                        var imageBase64 = Convert.ToBase64String(item.ItemThumbnail.Content);
                                        var imageSrc = $"data:{item.ItemThumbnail.MimeType};base64,{imageBase64}";

                                        <img src="@imageSrc"
                                             alt="Thumbnail of @item.ItemName"
                                             class="it-thumb" />
                                    }
                                    else
                                    {
                                        <div class="it-thumb it-thumb-empty">📦</div>
                                    }
                                </td>

                                <td>
                                    <div class="fw-semibold">@item.ItemName</div>
                                    <div class="text-muted small">
                                        Reorder: <span class="fw-semibold">@item.ReorderLevel</span>
                                    </div>
                                </td>

                                <td class="text-muted">@item.SKU</td>

                                <td>
                                    <span class="it-qty">@item.QuantityOnHand</span>
                                    @if (item.QuantityOnHand <= item.ReorderLevel)
                                    {
                                        <span class="badge text-bg-warning ms-2">Low</span>
                                    }
                                </td>

                                <td class="text-muted">@(item.Category?.Name ?? "-")</td>
                                <td class="text-muted">@(item.StorageLocation?.Name ?? "-")</td>

                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success border it-badge">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border it-badge">Inactive</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-secondary">
                                            Details
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary">
                                            Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>

            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const search = document.getElementById('invSearch');
            const status = document.getElementById('invStatus');
            const rows = Array.from(document.querySelectorAll('.inv-row'));
            const count = document.getElementById('invCount');

            function apply() {
                const q = (search.value || '').toLowerCase().trim();
                const s = status.value;

                let visible = 0;

                rows.forEach(r => {
                    const text = r.innerText.toLowerCase();
                    const okText = !q || text.includes(q);
                    const rowStatus = r.getAttribute('data-status');
                    const okStatus = (s === 'all') || (rowStatus === s);

                    const show = okText && okStatus;
                    r.style.display = show ? '' : 'none';
                    if (show) visible++;
                });

                count.textContent = rows.length ? `${visible} of ${rows.length} items` : '';
            }

            if (search) search.addEventListener('input', apply);
            if (status) status.addEventListener('change', apply);
            apply();
        })();
    </script>
}