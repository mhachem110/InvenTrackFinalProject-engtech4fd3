@model InvenTrack.Utilities.PaginatedList<InvenTrack.Models.InventoryItem>
@using System
@using System.Linq

@{
    ViewData["Title"] = "Inventory";

    var locationCounts = ViewData["LocationCounts"] as Dictionary<int, int> ?? new Dictionary<int, int>();
    var currentFilter = ViewData["CurrentFilter"] as string ?? string.Empty;
    var currentStatus = ViewData["CurrentStatus"] as string ?? "all";
    var currentPageSize = ViewData["CurrentPageSize"] is int ps ? ps : 10;

    var startItem = Model.TotalCount == 0 ? 0 : ((Model.PageIndex - 1) * Model.PageSize) + 1;
    var endItem = Model.TotalCount == 0 ? 0 : Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount);

    var firstPage = Math.Max(1, Model.PageIndex - 2);
    var lastPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Inventory</h1>
        </div>
        <div class="text-muted small">Browse and manage items, quantities, and locations.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">+ Add Item</a>
    </div>
</div>

<form asp-action="Index" method="get" class="it-panel mb-3">
    <div class="it-panel-body">
        <input type="hidden" id="pageNumber" name="page" value="1" />

        <div class="row g-2 align-items-center">
            <div class="col-lg-5">
                <div class="it-input">
                    <span class="it-input-ico">🔎</span>
                    <input name="searchString"
                           value="@currentFilter"
                           type="search"
                           class="form-control it-input-field"
                           placeholder="Search by name, SKU, category, location..." />
                </div>
            </div>

            <div class="col-lg-2">
                <select name="statusFilter" class="form-select">
                    <option value="all" selected="@(currentStatus == "all")">All statuses</option>
                    <option value="active" selected="@(currentStatus == "active")">Active only</option>
                    <option value="inactive" selected="@(currentStatus == "inactive")">Inactive only</option>
                </select>
            </div>

            <div class="col-lg-2">
                <select id="pageSize" name="pageSize" class="form-select">
                    <option value="10" selected="@(currentPageSize == 10)">10 per page</option>
                    <option value="25" selected="@(currentPageSize == 25)">25 per page</option>
                    <option value="50" selected="@(currentPageSize == 50)">50 per page</option>
                </select>
            </div>

            <div class="col-lg-3 d-flex justify-content-lg-end gap-2">
                <button type="submit" class="btn btn-primary">Apply</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </div>

        <div class="mt-2 text-muted small">
            Showing @startItem - @endItem of @Model.TotalCount items
        </div>
    </div>
</form>

<div class="it-panel">
    <div class="it-panel-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 it-table" id="invTable">
                <thead>
                    <tr>
                        <th style="width:92px;">Photo</th>
                        <th>Item</th>
                        <th style="width:150px;">SKU</th>
                        <th style="width:140px;">On Hand</th>
                        <th style="width:180px;">Category</th>
                        <th style="width:210px;">Locations</th>
                        <th style="width:120px;">Status</th>
                        <th class="text-end" style="width:220px;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <div class="fw-semibold mb-1">No inventory items found</div>
                                <div class="small mb-3">Try changing the filters or create a new inventory item.</div>
                                <a asp-action="Create" class="btn btn-primary btn-sm">+ Add Item</a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var status = item.IsActive ? "active" : "inactive";
                            var locCount = locationCounts.TryGetValue(item.ID, out var c) ? c : 0;

                            <tr data-status="@status">
                                <td>
                                    @if (item.ItemThumbnail?.Content != null && item.ItemThumbnail.Content.Length > 0)
                                    {
                                        var imageBase64 = Convert.ToBase64String(item.ItemThumbnail.Content);
                                        var imageSrc = $"data:{item.ItemThumbnail.MimeType};base64,{imageBase64}";
                                        <img src="@imageSrc" alt="Thumbnail of @item.ItemName" class="it-thumb" />
                                    }
                                    else
                                    {
                                        <div class="it-thumb it-thumb-empty">📦</div>
                                    }
                                </td>

                                <td>
                                    <div class="fw-semibold">@item.ItemName</div>
                                    <div class="text-muted small">
                                        Reorder: <span class="fw-semibold">@item.ReorderLevel</span>
                                    </div>
                                </td>

                                <td class="text-muted">@item.SKU</td>

                                <td>
                                    <span class="it-qty">@item.QuantityOnHand</span>
                                    @if (item.QuantityOnHand <= item.ReorderLevel)
                                    {
                                        <span class="badge text-bg-warning ms-2">Low</span>
                                    }
                                </td>

                                <td class="text-muted">@(item.Category?.Name ?? "-")</td>

                                <td class="text-muted">
                                    @{
                                        var primary = item.StorageLocation?.Name ?? "-";
                                        if (locCount > 1)
                                        {
                                            <span>@primary</span>
                                            <span class="badge bg-primary-subtle text-primary border it-badge ms-2"
                                                  data-bs-toggle="tooltip"
                                                  data-bs-placement="top"
                                                  title="This item currently has stock in @locCount locations.">
                                                +@(locCount - 1) more
                                            </span>
                                        }
                                        else
                                        {
                                            <span>@primary</span>
                                        }
                                    }
                                </td>

                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success border it-badge">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border it-badge">Inactive</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-secondary">Details</a>
                                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 p-3 border-top">
                <div class="text-muted small">
                    Page @Model.PageIndex of @Model.TotalPages
                </div>

                <nav aria-label="Inventory pagination">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.PageIndex - 1)"
                               asp-route-searchString="@currentFilter"
                               asp-route-statusFilter="@currentStatus"
                               asp-route-pageSize="@currentPageSize">
                                Previous
                            </a>
                        </li>

                        @if (firstPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="1"
                                   asp-route-searchString="@currentFilter"
                                   asp-route-statusFilter="@currentStatus"
                                   asp-route-pageSize="@currentPageSize">
                                    1
                                </a>
                            </li>

                            @if (firstPage > 2)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }
                        }

                        @for (var p = firstPage; p <= lastPage; p++)
                        {
                            <li class="page-item @(p == Model.PageIndex ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@p"
                                   asp-route-searchString="@currentFilter"
                                   asp-route-statusFilter="@currentStatus"
                                   asp-route-pageSize="@currentPageSize">
                                    @p
                                </a>
                            </li>
                        }

                        @if (lastPage < Model.TotalPages)
                        {
                            @if (lastPage < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled">
                                    <span class="page-link">...</span>
                                </li>
                            }

                            <li class="page-item">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@Model.TotalPages"
                                   asp-route-searchString="@currentFilter"
                                   asp-route-statusFilter="@currentStatus"
                                   asp-route-pageSize="@currentPageSize">
                                    @Model.TotalPages
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.PageIndex + 1)"
                               asp-route-searchString="@currentFilter"
                               asp-route-statusFilter="@currentStatus"
                               asp-route-pageSize="@currentPageSize">
                                Next
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.forEach(function (el) {
                new bootstrap.Tooltip(el);
            });

            const pageSize = document.getElementById('pageSize');
            const pageNumber = document.getElementById('pageNumber');

            if (pageSize) {
                pageSize.addEventListener('change', function () {
                    if (pageNumber) pageNumber.value = 1;
                    this.form.submit();
                });
            }
        })();
    </script>
}