@model InvenTrack.Models.InventoryItem

@{
    ViewData["Title"] = "Item Details";
}

<h1>Item Details</h1>

<div>
    <h4>Inventory Item</h4>
    <hr />

    @if (Model.ItemPhoto?.Content != null)
    {
        var imageBase64 = Convert.ToBase64String(Model.ItemPhoto.Content);
        var imageSrc = $"data:{Model.ItemPhoto.MimeType};base64,{imageBase64}";

        <div>
            <img src="@imageSrc"
                 alt="Photo of @Model.ItemName"
                 title="Photo of @Model.ItemName"
                 class="img-fluid rounded" />
        </div>
        <hr />
    }


    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.ItemName)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.ItemName)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.SKU)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.SKU)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Description)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Description)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.QuantityOnHand)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.QuantityOnHand)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.ReorderLevel)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.ReorderLevel)</dd>

        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@(Model.Category?.Name ?? "-")</dd>

        <dt class="col-sm-2">Location</dt>
        <dd class="col-sm-10">@(Model.StorageLocation?.Name ?? "-")</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.IsActive)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.IsActive)</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.ID">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
