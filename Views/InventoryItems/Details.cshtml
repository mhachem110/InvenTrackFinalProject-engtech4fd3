@model InvenTrack.Models.InventoryItem
@using System
@using System.Linq
@using InvenTrack.Models
@using InvenTrack.ViewModels.AI

@{
    ViewData["Title"] = "Item Details";

    var stocks = ViewData["LocationStocks"] as List<InventoryItemStock> ?? new List<InventoryItemStock>();
    var locCount = (ViewData["LocationCount"] as int?) ?? stocks.Count(s => s.QuantityOnHand > 0);

    var history = (Model.StockTransactions ?? new List<InvenTrack.Models.StockTransaction>())
        .OrderByDescending(t => t.DateCreated)
        .ToList();

    var aiPrediction = ViewData["AiPrediction"] as InventoryAiPredictionVM;
    var reorderVm = ViewData["ReorderVm"] as InvenTrack.ViewModels.Orders.ReorderRequestCreateVM;

    bool isAdmin = User.IsInRole(AppRoles.Admin);
    bool isRegionalManager = User.IsInRole(AppRoles.RegionalManager);
    bool isManager = User.IsInRole(AppRoles.Manager);
    bool isSupervisor = User.IsInRole(AppRoles.Supervisor);
    bool isEmployee = User.IsInRole(AppRoles.Employee);

    bool canCreateEditInventory = isAdmin || isRegionalManager || isManager || isSupervisor;
    bool canDeleteInventory = canCreateEditInventory;

    bool canCreateTransactions = isAdmin || isRegionalManager || isManager || isSupervisor;
    bool canRequestTransfers = isAdmin || isRegionalManager || isManager || isSupervisor || isEmployee;
    bool canRequestOrders = isAdmin || isRegionalManager || isManager || isSupervisor || isEmployee;
    bool canApproveOrders = isAdmin || isRegionalManager || isManager;

    bool showRequestTransfer = canRequestTransfers && !canCreateTransactions;

    string? imgSrc = null;
    if (Model.ItemPhoto?.Content != null && Model.ItemPhoto.Content.Length > 0)
    {
        imgSrc = $"data:{Model.ItemPhoto.MimeType};base64,{Convert.ToBase64String(Model.ItemPhoto.Content)}";
    }

    bool isLowStock = Model.QuantityOnHand <= Model.ReorderLevel;
}

<style>
    .it-item-details-page {
        display: grid;
        gap: 1.25rem;
    }

    .it-item-details-hero {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(15,23,42,.08);
        border-radius: 24px;
        padding: 1.25rem;
        background:
            radial-gradient(circle at top right, rgba(13,110,253,.12), transparent 30%),
            linear-gradient(135deg, #ffffff 0%, #f8fbff 55%, #eef5ff 100%);
        box-shadow: 0 14px 32px rgba(15,23,42,.06);
    }

    .it-item-details-hero .it-pagehead {
        align-items: flex-start;
    }

    .it-item-details-subtitle {
        margin-top: .5rem;
        color: #64748b;
        max-width: 52rem;
        line-height: 1.55;
    }

    .it-item-details-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
        margin-top: .9rem;
    }

    .it-item-details-meta span {
        display: inline-flex;
        align-items: center;
        padding: .45rem .75rem;
        border-radius: 999px;
        border: 1px solid rgba(15,23,42,.08);
        background: rgba(255,255,255,.78);
        color: #475569;
        font-size: .82rem;
        font-weight: 600;
    }

    .it-item-sidebar {
        display: grid;
        gap: 1rem;
    }

    .it-item-sidebar .it-panel,
    .it-item-main .it-panel,
    .it-item-main .it-mini {
        border-radius: 22px;
    }

    .it-item-sidebar .it-panel-body,
    .it-item-main .it-panel-body {
        padding: 1.1rem;
    }

    .it-item-photo-wrap {
        border: 1px solid rgba(15,23,42,.08);
        border-radius: 20px;
        overflow: hidden;
        background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    }

    .it-item-photo-wrap img {
        display: block;
        width: 100%;
        max-height: 280px;
        object-fit: cover;
    }

    .it-item-sidebar .it-field {
        height: 100%;
        padding: .9rem 1rem;
        border: 1px solid rgba(15,23,42,.08);
        border-radius: 16px;
        background: linear-gradient(180deg, rgba(255,255,255,.98), rgba(248,250,252,.92));
    }

    .it-item-main .it-mini {
        padding: 1rem 1.05rem;
        background:
            radial-gradient(circle at top right, rgba(13,110,253,.08), transparent 36%),
            linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border-color: rgba(15,23,42,.08);
        box-shadow: 0 10px 24px rgba(15,23,42,.05);
    }

    .it-item-main .nav-pills .nav-link {
        border-radius: 999px;
        border: 1px solid rgba(15,23,42,.08);
        background: #f8fafc;
        color: #475569;
        font-weight: 700;
        padding: .55rem .95rem;
    }

    .it-item-main .nav-pills .nav-link.active {
        background: #0d6efd;
        border-color: #0d6efd;
        color: #fff;
        box-shadow: 0 10px 20px rgba(13,110,253,.22);
    }

    .it-item-description {
        font-size: .95rem;
        line-height: 1.7;
        color: #475569;
        white-space: pre-line;
    }

    .it-barcode-preview {
        border-radius: 18px;
        border: 1px solid rgba(15,23,42,.10);
        background: #fff;
        padding: .85rem;
    }

   
    }
</style>

<div class="it-item-details-page">
    <section class="it-item-details-hero">
        <div class="it-pagehead mb-0">
            <div class="min-w-0">
                <div class="d-flex align-items-center gap-2">
                    <div class="it-page-dot"></div>
                    <h1 class="h3 mb-0 fw-bold text-truncate">Item Details</h1>
                </div>
                <div class="it-item-details-subtitle">
                    Review inventory status, barcode access, movement history, and reorder insight for <span class="fw-semibold text-dark">@Model.ItemName</span>.
                </div>
                <div class="it-item-details-meta">
                    <span>SKU: @(string.IsNullOrWhiteSpace(Model.SKU) ? "—" : Model.SKU)</span>
                    <span>Category: @(Model.Category?.Name ?? "—")</span>
                    <span>Primary Location: @(Model.StorageLocation?.Name ?? "—")</span>
                </div>
            </div>

            <div class="d-flex gap-2 flex-wrap justify-content-end">
                @if (Model.IsActive)
                {
                    <span class="badge bg-success-subtle text-success border it-badge align-self-center">Active</span>
                }
                else
                {
                    <span class="badge bg-secondary-subtle text-secondary border it-badge align-self-center">Inactive</span>
                }

                @if (isLowStock)
                {
                    <span class="badge text-bg-warning it-badge align-self-center">Low Stock</span>
                }

                @if (canCreateEditInventory)
                {
                    <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-outline-primary">Edit</a>
                }

                @if (showRequestTransfer)
                {
                    <a asp-controller="StockTransferRequests" asp-action="Create" asp-route-inventoryItemId="@Model.ID" class="btn btn-outline-dark">Request Transfer</a>
                }
                @if (canRequestOrders)
                {
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#reorderModal">@(canApproveOrders ? "Restock" : "Request Restock")</button>
                }

                <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </div>
        </div>
    </section>

@if (TempData["OrderMsg"] != null)
{
    <div class="alert alert-info">@TempData["OrderMsg"]</div>
}

<div class="row g-3 g-lg-4 align-items-start">
    <div class="col-12 col-xl-4">
        <div class="it-item-sidebar">
        <div class="it-panel">
            <div class="it-panel-header"><div class="fw-bold">Barcode</div><div class="text-muted small">Unique identifier for scanning and quick lookup.</div></div>
            <div class="it-panel-body text-center">
                <img src="@Url.Action("BarcodeImage", new { id = Model.ID })" class="img-fluid it-barcode-preview" alt="Barcode for @Model.ItemName" />
                <div class="fw-semibold mt-3">@Model.Barcode</div>
                <div class="d-grid mt-3">
                    <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#barcodeModalMain">Show Barcode</button>
                </div>
            </div>
        </div>

    <!-- Left: Photo + basics -->
        <div class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">Overview</div>
                <div class="text-muted small">Photo and key identifiers.</div>
            </div>

            <div class="it-panel-body">
                <div class="it-item-photo-wrap mb-3">
                    @if (!string.IsNullOrWhiteSpace(imgSrc))
                    {
                        <img src="@imgSrc"
                             class="img-fluid w-100"
                             alt="Photo of @Model.ItemName"
                             style="max-height:260px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="it-empty-photo w-100" style="min-height:260px;">
                            📦
                            <div class="small text-muted mt-2">No photo</div>
                        </div>
                    }
                </div>

                <div class="it-field mb-3">
                    <div class="label">Item</div>
                    <div class="value fw-semibold text-break">@Model.ItemName</div>
                </div>

                <div class="row g-2">
                    <div class="col-12 col-md-6 col-xl-12">
                        <div class="it-field">
                            <div class="label">SKU</div>
                            <div class="value">@(string.IsNullOrWhiteSpace(Model.SKU) ? "—" : Model.SKU)</div>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-xl-12">
                        <div class="it-field">
                            <div class="label">Category</div>
                            <div class="value">@(Model.Category?.Name ?? "—")</div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="it-field">
                            <div class="label">Primary Location</div>
                            <div class="value">@(Model.StorageLocation?.Name ?? "—")</div>
                        </div>
                    </div>
                </div>

                @if (showRequestTransfer)
                {
                    <div class="it-hint mt-3">
                        You can’t move stock directly. Submit a transfer request for approval.
                    </div>
                }

                <div class="d-flex flex-wrap gap-2 mt-3">
                    @if (canCreateEditInventory)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-primary">Edit Item</a>
                    }

                    @if (canDeleteInventory)
                    {
                        <a asp-action="Delete" asp-route-id="@Model.ID" class="btn btn-outline-danger">Delete</a>
                    }
                </div>
            </div>
        </div>
        </div>
    </div>

    <!-- Right: KPI + Description + Tabs -->
    <div class="col-12 col-xl-8">
        <div class="it-item-main">
        <!-- KPIs -->
        <div class="row g-3 mb-3">
            <div class="col-12 col-md-4">
                <div class="it-mini h-100">
                    <div class="it-mini-title">Total On Hand</div>
                    <div class="fw-bold fs-3">@Model.QuantityOnHand</div>
                    <div class="text-muted small">Visible total for this item</div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="it-mini h-100">
                    <div class="it-mini-title">Reorder Level</div>
                    <div class="fw-bold fs-3">@Model.ReorderLevel</div>
                    <div class="text-muted small">Alert threshold</div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="it-mini h-100">
                    <div class="it-mini-title">Locations with Stock</div>
                    <div class="fw-bold fs-3">@locCount</div>
                    <div class="text-muted small">Where quantity &gt; 0</div>
                </div>
            </div>

            <div class="col-12">
                <div class="it-panel">
                    <div class="it-panel-header">
                        <div class="fw-bold">Description</div>
                        <div class="text-muted small">Notes and usage details.</div>
                    </div>
                    <div class="it-panel-body">
                        <div class="it-item-description">
                            @(!string.IsNullOrWhiteSpace(Model.Description) ? Model.Description : "No description provided for this item.")
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs to reduce clutter -->
        <div class="it-panel">
            <div class="it-panel-header d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-2">
                <div>
                    <div class="fw-bold">Details</div>
                    <div class="text-muted small">Stock, activity, and AI insight.</div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Scan" class="btn btn-outline-secondary">Scan Barcode</a>
                    @if (canCreateTransactions)
                    {
                        <a asp-controller="StockTransactions" asp-action="Create" asp-route-inventoryItemId="@Model.ID"
                           class="btn btn-sm btn-primary">
                            + New Transaction
                        </a>
                    }

                    @if (showRequestTransfer)
                    {
                        <a asp-controller="StockTransferRequests" asp-action="Create" asp-route-inventoryItemId="@Model.ID"
                           class="btn btn-sm btn-outline-dark">
                            Request Transfer
                        </a>
                    }
                </div>
            </div>

            <div class="it-panel-body">
                <ul class="nav nav-pills gap-2" id="detailsTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="tab-stock" data-bs-toggle="pill" data-bs-target="#pane-stock" type="button" role="tab">
                            Stock
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-activity" data-bs-toggle="pill" data-bs-target="#pane-activity" type="button" role="tab">
                            Activity
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-ai" data-bs-toggle="pill" data-bs-target="#pane-ai" type="button" role="tab">
                            AI Insight
                        </button>
                    </li>
                </ul>

                <div class="tab-content mt-3">
                    <!-- Stock -->
                    <div class="tab-pane fade show active" id="pane-stock" role="tabpanel" aria-labelledby="tab-stock">
                        <div class="text-muted small mb-2">Per-location quantities (supports partial transfers).</div>

                        <div class="table-responsive">
                            <table id="stockTable" class="table table-hover align-middle mb-0 it-table">
                                <thead>
                                    <tr>
                                        <th>Location</th>
                                        <th style="width:140px;" class="text-end">Qty</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!stocks.Any())
                                    {
                                        <tr>
                                            <td colspan="2" class="text-center text-muted py-4">No stock rows found.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var s in stocks.OrderByDescending(x => x.QuantityOnHand))
                                        {
                                            <tr>
                                                <td class="text-muted">@((s.StorageLocation?.Name) ?? "—")</td>
                                                <td class="text-end"><span class="it-qty">@s.QuantityOnHand</span></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="it-table-pager border-top p-3 d-flex flex-column flex-md-row gap-2 align-items-center justify-content-between">
                            <div class="text-muted small" id="stockInfo"></div>

                            <div class="d-flex gap-2 align-items-center">
                                <label class="text-muted small mb-0">Rows</label>
                                <select id="stockPageSize" class="form-select form-select-sm" style="width:auto;">
                                    <option value="5">5</option>
                                    <option value="10" selected>10</option>
                                    <option value="25">25</option>
                                </select>

                                <nav aria-label="Stock pagination">
                                    <ul class="pagination pagination-sm mb-0" id="stockPagination"></ul>
                                </nav>
                            </div>
                        </div>
                    </div>

                    <!-- Activity -->
                    <div class="tab-pane fade" id="pane-activity" role="tabpanel" aria-labelledby="tab-activity">
                        <div class="text-muted small mb-2">Latest visible activity for this item.</div>

                        <div class="table-responsive">
                            <table id="txTable" class="table table-hover align-middle mb-0 it-table">
                                <thead>
                                    <tr>
                                        <th style="width:170px;">Date</th>
                                        <th style="width:140px;">Action</th>
                                        <th style="width:90px;">Qty</th>
                                        <th class="d-none d-lg-table-cell" style="width:190px;">From</th>
                                        <th class="d-none d-lg-table-cell" style="width:190px;">To</th>
                                        <th class="d-none d-md-table-cell" style="width:150px;">By</th>
                                        <th>Notes</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @if (!history.Any())
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-5">
                                                <div class="fw-semibold mb-1">No transactions yet</div>
                                                <div class="small">Transactions appear here once created.</div>
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var t in history)
                                        {
                                            <tr>
                                                <td class="text-muted">@t.DateCreated.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>

                                                <td>
                                                    @if (t.ActionType == StockActionType.CheckIn)
                                                    {
                                                        <span class="badge bg-success-subtle text-success border it-badge">Check In</span>
                                                    }
                                                    else if (t.ActionType == StockActionType.CheckOut)
                                                    {
                                                        <span class="badge bg-danger-subtle text-danger border it-badge">Check Out</span>
                                                    }
                                                    else if (t.ActionType == StockActionType.Transfer)
                                                    {
                                                        <span class="badge bg-primary-subtle text-primary border it-badge">Transfer</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary-subtle text-secondary border it-badge">Adjustment</span>
                                                    }
                                                </td>

                                                <td><span class="it-qty">@t.QuantityChange</span></td>
                                                <td class="text-muted d-none d-lg-table-cell">@(t.FromStorageLocation?.Name ?? "—")</td>
                                                <td class="text-muted d-none d-lg-table-cell">@(t.ToStorageLocation?.Name ?? "—")</td>
                                                <td class="text-muted d-none d-md-table-cell">@(t.PerformedBy ?? "—")</td>
                                                <td class="text-muted">@(!string.IsNullOrWhiteSpace(t.Notes) ? t.Notes : "—")</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="it-table-pager border-top p-3 d-flex flex-column flex-md-row gap-2 align-items-center justify-content-between">
                            <div class="text-muted small" id="txInfo"></div>

                            <div class="d-flex gap-2 align-items-center">
                                <label class="text-muted small mb-0">Rows</label>
                                <select id="txPageSize" class="form-select form-select-sm" style="width:auto;">
                                    <option value="10" selected>10</option>
                                    <option value="25">25</option>
                                    <option value="50">50</option>
                                </select>

                                <nav aria-label="Transaction pagination">
                                    <ul class="pagination pagination-sm mb-0" id="txPagination"></ul>
                                </nav>
                            </div>
                        </div>
                    </div>

                    <!-- AI -->
                    <div class="tab-pane fade" id="pane-ai" role="tabpanel" aria-labelledby="tab-ai">
                        @if (aiPrediction == null)
                        {
                            <div class="text-muted">
                                AI insight is not available for this item right now.
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap mb-3">
                                <div class="text-muted small">
                                    This forecast uses recent check-outs and negative adjustments to estimate reorder timing.
                                </div>
                                <span class="badge @aiPrediction.BadgeClass it-badge">@aiPrediction.AlertLabel</span>
                            </div>

                            <div class="row g-3">
                                <div class="col-12 col-md-3">
                                    <div class="it-mini h-100">
                                        <div class="it-mini-title">Avg Daily Usage</div>
                                        <div class="fw-bold fs-4">@aiPrediction.AverageDailyUsageDisplay</div>
                                        <div class="text-muted small">@aiPrediction.LookbackDays day lookback</div>
                                    </div>
                                </div>

                                <div class="col-12 col-md-3">
                                    <div class="it-mini h-100">
                                        <div class="it-mini-title">Days Until Reorder</div>
                                        <div class="fw-bold fs-4">@aiPrediction.DaysUntilReorderDisplay</div>
                                        <div class="text-muted small">Estimated time</div>
                                    </div>
                                </div>

                                <div class="col-12 col-md-3">
                                    <div class="it-mini h-100">
                                        <div class="it-mini-title">Reorder Date</div>
                                        <div class="fw-bold fs-4">@aiPrediction.PredictedReorderDateDisplay</div>
                                        <div class="text-muted small">Predicted</div>
                                    </div>
                                </div>

                                <div class="col-12 col-md-3">
                                    <div class="it-mini h-100">
                                        <div class="it-mini-title">Suggested Qty</div>
                                        <div class="fw-bold fs-4">@aiPrediction.SuggestedReorderQuantity</div>
                                        <div class="text-muted small">Recommended</div>
                                    </div>
                                </div>

                                <div class="col-12 col-lg-8">
                                    <div class="it-field h-100">
                                        <div class="label">AI Summary</div>
                                        <div class="value">@aiPrediction.InsightSummary</div>
                                    </div>
                                </div>

                                <div class="col-12 col-lg-4">
                                    <div class="it-field h-100">
                                        <div class="label">Recommended Action</div>
                                        <div class="value">@aiPrediction.RecommendedAction</div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-3 text-muted small">
                                Demand signals used: <span class="fw-semibold">@aiPrediction.DemandSignalCount</span>
                                <span class="mx-2">•</span>
                                Days with usage: <span class="fw-semibold">@aiPrediction.DaysWithUsage</span>
                                <span class="mx-2">•</span>
                                Units consumed: <span class="fw-semibold">@aiPrediction.TotalUnitsConsumed</span>
                            </div>

                            @if (aiPrediction.LocationPredictions != null && aiPrediction.LocationPredictions.Any())
                            {
                                <div class="mt-4">
                                    <div class="fw-semibold mb-2">Per-Location Forecast</div>
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle">
                                            <thead>
                                                <tr>
                                                    <th>Location</th>
                                                    <th class="text-end">Stock</th>
                                                    <th class="text-end">Avg Usage</th>
                                                    <th class="text-end">Days Until Reorder</th>
                                                    <th class="text-end">Suggested Qty</th>
                                                    <th>Status</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var lp in aiPrediction.LocationPredictions)
                                                {
                                                    <tr>
                                                        <td>@lp.LocationName</td>
                                                        <td class="text-end">@lp.CurrentQuantityOnHand</td>
                                                        <td class="text-end">@lp.AverageDailyUsageDisplay</td>
                                                        <td class="text-end">@lp.DaysUntilReorderDisplay</td>
                                                        <td class="text-end">@lp.SuggestedReorderQuantity</td>
                                                        <td><span class="badge bg-light text-dark border">@lp.AlertLabel</span></td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
        </div>
    </div>
</div>
</div>

<div class="modal fade" id="barcodeModalMain" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header"><h5 class="modal-title">@Model.ItemName barcode</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body text-center">
        <img src="@Url.Action("BarcodeImage", new { id = Model.ID })" class="img-fluid border rounded p-2 bg-white" alt="Barcode for @Model.ItemName" />
        <div class="fw-semibold mt-3">@Model.Barcode</div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
(function () {

  function paginateTable(options) {
    const table = document.getElementById(options.tableId);
    if (!table) return;

    const tbody = table.querySelector("tbody");
    if (!tbody) return;

    const rows = Array.from(tbody.querySelectorAll("tr"));
    const pagination = document.getElementById(options.paginationId);
    const info = document.getElementById(options.infoId);
    const pageSizeSelect = document.getElementById(options.pageSizeSelectId);

    const realRows = rows.filter(r => !r.querySelector("td[colspan]"));
    if (realRows.length <= 1) {
      if (pagination) pagination.innerHTML = "";
      if (info) info.textContent = realRows.length ? `Showing 1 of 1` : "";
      return;
    }

    let pageSize = parseInt(pageSizeSelect?.value || options.defaultPageSize || 10, 10);
    let currentPage = 1;

    function render() {
      pageSize = parseInt(pageSizeSelect?.value || pageSize, 10);

      const total = realRows.length;
      const totalPages = Math.max(1, Math.ceil(total / pageSize));
      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;

      const startIdx = (currentPage - 1) * pageSize;
      const endIdx = Math.min(startIdx + pageSize, total);

      realRows.forEach(r => r.style.display = "none");
      realRows.slice(startIdx, endIdx).forEach(r => r.style.display = "");

      if (info) info.textContent = `Showing ${startIdx + 1} - ${endIdx} of ${total}`;

      if (!pagination) return;
      pagination.innerHTML = "";

      function addPage(label, page, disabled, active) {
        const li = document.createElement("li");
        li.className = `page-item ${disabled ? "disabled" : ""} ${active ? "active" : ""}`;

        const a = document.createElement("a");
        a.className = "page-link";
        a.href = "#";
        a.textContent = label;

        a.addEventListener("click", (e) => {
          e.preventDefault();
          if (disabled) return;
          currentPage = page;
          render();
        });

        li.appendChild(a);
        pagination.appendChild(li);
      }

      addPage("Prev", currentPage - 1, currentPage === 1, false);

      const windowSize = 2;
      const first = Math.max(1, currentPage - windowSize);
      const last = Math.min(totalPages, currentPage + windowSize);

      if (first > 1) {
        addPage("1", 1, false, false);
        if (first > 2) {
          const li = document.createElement("li");
          li.className = "page-item disabled";
          li.innerHTML = `<span class="page-link">...</span>`;
          pagination.appendChild(li);
        }
      }

      for (let p = first; p <= last; p++) {
        addPage(String(p), p, false, p === currentPage);
      }

      if (last < totalPages) {
        if (last < totalPages - 1) {
          const li = document.createElement("li");
          li.className = "page-item disabled";
          li.innerHTML = `<span class="page-link">...</span>`;
          pagination.appendChild(li);
        }
        addPage(String(totalPages), totalPages, false, false);
      }

      addPage("Next", currentPage + 1, currentPage === totalPages, false);
    }

    if (pageSizeSelect) {
      pageSizeSelect.addEventListener("change", () => {
        currentPage = 1;
        render();
      });
    }

    render();
  }

  paginateTable({
    tableId: "stockTable",
    paginationId: "stockPagination",
    infoId: "stockInfo",
    pageSizeSelectId: "stockPageSize",
    defaultPageSize: 10
  });

  paginateTable({
    tableId: "txTable",
    paginationId: "txPagination",
    infoId: "txInfo",
    pageSizeSelectId: "txPageSize",
    defaultPageSize: 10
  });

})();
</script>
}

@if (canRequestOrders && reorderVm != null)
{
    <div class="modal fade" id="reorderModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow">
                <form asp-controller="OrderRequests" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header border-0 pb-0">
                        <div>
                            <h5 class="modal-title mb-1">@reorderVm.RequestModeLabel</h5>
                            <div class="text-muted small">AI-assisted reorder suggestion for @reorderVm.ItemName.</div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="InventoryItemID" value="@reorderVm.InventoryItemID" />
                        <input type="hidden" name="CurrentVisibleQuantity" value="@reorderVm.CurrentVisibleQuantity" />
                        <input type="hidden" name="SuggestedQuantity" value="@reorderVm.SuggestedQuantity" />
                        <div class="row g-3 mb-3">
                            <div class="col-md-3"><div class="it-mini h-100"><div class="it-mini-title">Current Qty</div><div class="fw-bold fs-3">@reorderVm.CurrentVisibleQuantity</div></div></div>
                            <div class="col-md-3"><div class="it-mini h-100"><div class="it-mini-title">Reorder Level</div><div class="fw-bold fs-3">@reorderVm.ReorderLevel</div></div></div>
                            <div class="col-md-3"><div class="it-mini h-100"><div class="it-mini-title">Suggested Qty</div><div class="fw-bold fs-3">@reorderVm.SuggestedQuantity</div><div class="small text-muted">@reorderVm.SuggestedByLabel</div></div></div>
                            <div class="col-md-3"><div class="it-mini h-100"><div class="it-mini-title">Confidence</div><div class="fw-bold fs-5">@reorderVm.AiConfidenceLabel</div></div></div>
                        </div>
                        <div class="alert alert-primary-subtle border text-primary-emphasis">@reorderVm.AiInsightSummary</div>
                        <div class="row g-3">
                            <div class="col-md-6"><label class="form-label">Item</label><input class="form-control" value="@reorderVm.ItemName" readonly /></div>
                            <div class="col-md-6"><label class="form-label">SKU</label><input class="form-control" value="@reorderVm.SKU" readonly /></div>
                            <div class="col-md-4"><label class="form-label">Quantity to Order</label><input class="form-control" type="number" name="RequestedQuantity" min="1" value="@reorderVm.SuggestedQuantity" required /></div>
                            <div class="col-md-8"><label class="form-label">Add stock to location</label><select class="form-select" name="DestinationStorageLocationID" required>@foreach (var l in reorderVm.AvailableLocations){<option value="@l.ID" selected="@(l.ID == reorderVm.DestinationStorageLocationID)">@l.Name (@l.QuantityOnHand on hand)</option>}</select><div class="text-muted small mt-1">@reorderVm.DestinationHint</div></div>
                            <div class="col-12"><label class="form-label">Locations included in this order</label><select class="form-select" name="RelatedLocationIds" multiple size="5">@foreach (var l in reorderVm.AvailableLocations){<option value="@l.ID" selected="@(reorderVm.RelatedLocationIds.Contains(l.ID))">@l.Name (@l.QuantityOnHand on hand)</option>}</select></div>
                            <div class="col-12"><label class="form-label">Notes</label><textarea class="form-control" name="Notes" rows="3" placeholder="Supplier, urgency, reason, or purchase details"></textarea></div>
                        </div>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">@(canApproveOrders ? "Complete Restock" : "Submit Request")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
