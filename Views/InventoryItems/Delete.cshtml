@model InvenTrack.Models.InventoryItem

@{
    ViewData["Title"] = "Delete Item";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold text-danger">Delete Item</h1>
        </div>
        <div class="text-muted small">This action cannot be undone.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="it-panel">
    <div class="it-panel-body">
        <div class="alert alert-danger mb-4">
            <div class="fw-semibold">Are you sure you want to delete this item?</div>
            <div class="small">Item will be permanently removed.</div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="it-field">
                    <div class="label">Item Name</div>
                    <div class="value">@Model.ItemName</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="it-field">
                    <div class="label">SKU</div>
                    <div class="value">@Model.SKU</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="it-field">
                    <div class="label">Quantity On Hand</div>
                    <div class="value">@Model.QuantityOnHand</div>
                </div>
            </div>
        </div>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="ID" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>