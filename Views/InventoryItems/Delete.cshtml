@model InvenTrack.Models.InventoryItem

@{
    ViewData["Title"] = "Delete Item";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this item?</h3>
<div>
    <h4>Inventory Item</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.ItemName)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.ItemName)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.SKU)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.SKU)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.QuantityOnHand)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.QuantityOnHand)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="ID" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-link">Back</a>
    </form>
</div>
