@model InvenTrack.Models.InventoryItem
@using System

@{
    ViewData["Title"] = "Edit Item";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Edit Item</h1>
        </div>
        <div class="text-muted small">Update item details and photo. Stock and location are managed via Transactions.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Details" asp-route-id="@Model.ID" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="ID" />

    <div class="row g-3 g-lg-4">
        <div class="col-lg-8">
            <div class="it-panel">
                <div class="it-panel-header">
                    <div class="fw-bold">Item details</div>
                    <div class="text-muted small">Name, SKU, description, reorder settings, and classification.</div>
                </div>

                <div class="it-panel-body">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="ItemName" class="form-label"></label>
                            <input asp-for="ItemName" class="form-control" />
                            <span asp-validation-for="ItemName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="SKU" class="form-label"></label>
                            <input asp-for="SKU" class="form-control" />
                            <span asp-validation-for="SKU" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">Barcode</label>
                            <input class="form-control" value="Will be generated automatically when the item is saved." readonly />
                            <div class="form-text">Every item receives a unique barcode for scanning and quick actions.</div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description" class="form-control" />
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ReorderLevel" class="form-label"></label>
                            <input asp-for="ReorderLevel" class="form-control" />
                            <span asp-validation-for="ReorderLevel" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CategoryID" class="form-label"></label>
                            <select asp-for="CategoryID" class="form-select" asp-items="ViewBag.CategoryID">
                                <option value="0">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Barcode</label>
                            <input class="form-control" value="@Model.Barcode" readonly />
                            <div class="form-text">Barcode stays stable after creation.</div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Total Quantity On Hand</label>
                            <input asp-for="QuantityOnHand" class="form-control" readonly />
                            <span asp-validation-for="QuantityOnHand" class="text-danger small"></span>
                            <div class="form-text">Managed via Stock Transactions (check in/out/adjust/transfer).</div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Primary Location</label>
                            <select asp-for="StorageLocationID" class="form-select" asp-items="ViewBag.StorageLocationID" disabled>
                                <option value="0">-- Select Location --</option>
                            </select>
                            <input type="hidden" asp-for="StorageLocationID" />
                            <span asp-validation-for="StorageLocationID" class="text-danger small"></span>
                            <div class="form-text">Primary location updates automatically based on per-location stock.</div>
                        </div>

                        <div class="col-12">
                            <div class="it-hint">
                                Tip: To move stock between locations or change quantities, use <strong>Transactions</strong> on the item details page.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="it-panel">
                <div class="it-panel-header">
                    <div class="fw-bold">Status & photo</div>
                    <div class="text-muted small">Replace image or remove it.</div>
                </div>

                <div class="it-panel-body">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" asp-for="IsActive" />
                        <label class="form-check-label" asp-for="IsActive">Active</label>
                    </div>

                    @if (Model.ItemThumbnail?.Content != null && Model.ItemThumbnail.Content.Length > 0)
                    {
                        var img = $"data:{Model.ItemThumbnail.MimeType};base64,{Convert.ToBase64String(Model.ItemThumbnail.Content)}";
                        <div class="mb-3">
                            <div class="text-muted small mb-2">Current thumbnail</div>
                            <img src="@img" class="it-thumb it-thumb-lg" alt="Thumbnail" />
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="chkRemoveImage" name="chkRemoveImage" />
                            <label class="form-check-label" for="chkRemoveImage">Remove current image</label>
                        </div>
                    }

                    <label class="form-label">Replace Photo (optional)</label>
                    <input type="file" name="thePicture" class="form-control" accept="image/*" />
                    <div class="text-danger small mt-1">@Html.ValidationMessage("thePicture")</div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-action="Details" asp-route-id="@Model.ID" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </div>
            </div>

            <div class="it-panel mt-3">
                <div class="it-panel-body text-center border-bottom">
                    <img src="@Url.Action("BarcodeImage", "InventoryItems", new { id = Model.ID })" class="img-fluid border rounded p-2 bg-white" alt="Barcode for @Model.ItemName" />
                    <div class="small fw-semibold mt-2">@Model.Barcode</div>
                </div>
                <div class="it-panel-body">
                    <div class="fw-semibold mb-1">Need to update stock?</div>
                    <div class="text-muted small mb-3">Use transactions for check in/out, adjustments, and partial transfers.</div>
                    <a asp-controller="StockTransactions" asp-action="Create" asp-route-inventoryItemId="@Model.ID" class="btn btn-outline-primary w-100">
                        + New Transaction
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}