@model InvenTrack.ViewModels.StockTransactionCreateVM
@using InvenTrack.Models
@using System.Linq

@{
    ViewData["Title"] = "New Transaction";
    var fromList = Model.Locations.Where(x => x.QuantityOnHand > 0).OrderBy(x => x.LocationName).ToList();
    var allList = Model.Locations.OrderBy(x => x.LocationName).ToList();
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">New Transaction</h1>
        </div>
        <div class="text-muted small">
            @(Model.AllowTransfer
                        ? "Check in, check out, adjust, or transfer inventory for this item."
                        : "Check in, check out, or adjust inventory for this item. Transfers must be requested separately.")
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        @if (!Model.AllowTransfer)
        {
            <a asp-controller="StockTransferRequests"
               asp-action="Create"
               asp-route-inventoryItemId="@Model.InventoryItemID"
               class="btn btn-outline-dark">
                Request Transfer Instead
            </a>
        }

        <a asp-controller="InventoryItems" asp-action="Details" asp-route-id="@Model.InventoryItemID" class="btn btn-outline-secondary">
            Back
        </a>
    </div>
</div>

<div class="row g-3 g-lg-4">
    <div class="col-lg-8">
        <div class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">Transaction</div>
                <div class="text-muted small">Choose an action and apply the change.</div>
            </div>

            <div class="it-panel-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="InventoryItemID" />
                    <input type="hidden" asp-for="ItemName" />
                    <input type="hidden" asp-for="SKU" />
                    <input type="hidden" asp-for="TotalQuantityOnHand" id="totalHidden" />
                    <input type="hidden" asp-for="AllowTransfer" />

                    @if (!Model.AllowTransfer)
                    {
                        <div class="it-hint mb-3">
                            Your role cannot directly confirm stock transfers between locations. Use a transfer request instead.
                        </div>
                    }

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ActionType" class="form-label"></label>
                            <select asp-for="ActionType" class="form-select" id="actionSelect">
                                <option value="@((int)StockActionType.CheckIn)" selected="@(Model.ActionType == StockActionType.CheckIn ? "selected" : null)">CheckIn</option>
                                <option value="@((int)StockActionType.CheckOut)" selected="@(Model.ActionType == StockActionType.CheckOut ? "selected" : null)">CheckOut</option>
                                <option value="@((int)StockActionType.Adjustment)" selected="@(Model.ActionType == StockActionType.Adjustment ? "selected" : null)">Adjustment</option>
                                @if (Model.AllowTransfer)
                                {
                                    <option value="@((int)StockActionType.Transfer)" selected="@(Model.ActionType == StockActionType.Transfer ? "selected" : null)">Transfer</option>
                                }
                            </select>
                            <span asp-validation-for="ActionType" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity" class="form-control" id="qtyInput" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                            <div class="form-text" id="qtyHelp"></div>
                        </div>

                        <div class="col-12" id="fromBlock">
                            <label class="form-label" id="fromLabel">From Location</label>
                            <select asp-for="FromLocationID" class="form-select" id="fromSelect">
                                <option value="">-- Select Location --</option>
                                @foreach (var l in fromList)
                                {
                                    <option value="@l.LocationID"
                                            data-qty="@l.QuantityOnHand"
                                            selected="@(Model.FromLocationID == l.LocationID ? "selected" : null)">
                                        @l.LocationName (@l.QuantityOnHand)
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="FromLocationID" class="text-danger small"></span>
                            <div class="form-text" id="fromHelp"></div>
                        </div>

                        <div class="col-12" id="toBlock">
                            <label asp-for="ToLocationID" class="form-label"></label>
                            <select asp-for="ToLocationID" class="form-select" id="toSelect">
                                <option value="">-- Select Location --</option>
                                @foreach (var l in allList)
                                {
                                    <option value="@l.LocationID" selected="@(Model.ToLocationID == l.LocationID ? "selected" : null)">
                                        @l.LocationName
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="ToLocationID" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <input asp-for="Notes" class="form-control" placeholder="Optional (required for Adjustment)" />
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PerformedBy" class="form-label"></label>
                            <input asp-for="PerformedBy" class="form-control" placeholder="Optional (e.g., Moayed)" />
                            <span asp-validation-for="PerformedBy" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="d-flex gap-2 mt-2 flex-wrap">
                                <button type="submit" class="btn btn-primary">Apply Transaction</button>

                                @if (!Model.AllowTransfer)
                                {
                                    <a asp-controller="StockTransferRequests"
                                       asp-action="Create"
                                       asp-route-inventoryItemId="@Model.InventoryItemID"
                                       class="btn btn-outline-dark">
                                        Request Transfer
                                    </a>
                                }

                                <a asp-controller="InventoryItems" asp-action="Details" asp-route-id="@Model.InventoryItemID" class="btn btn-outline-secondary">
                                    Cancel
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">Item summary</div>
                <div class="text-muted small">Current stock by location.</div>
            </div>

            <div class="it-panel-body">
                <div class="it-field mb-3">
                    <div class="label">Item</div>
                    <div class="value fw-semibold">@Model.ItemName</div>
                    <div class="text-muted small">SKU: <span class="fw-semibold">@Model.SKU</span></div>
                </div>

                <div class="it-field mb-3">
                    <div class="label">Total quantity</div>
                    <div class="value"><span class="it-qty">@Model.TotalQuantityOnHand</span></div>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="text-muted small">Location</th>
                                <th class="text-muted small text-end">Qty</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var l in allList)
                            {
                                <tr>
                                    <td class="text-muted">@l.LocationName</td>
                                    <td class="text-end"><span class="it-qty">@l.QuantityOnHand</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="it-hint mt-3">
                    @if (Model.AllowTransfer)
                    {
                        <span>Tip: Transfer supports partial quantities. Checkout/Transfer is limited by available stock in the selected source location.</span>
                    }
                    else
                    {
                        <span>Tip: Supervisors can check in, check out, and adjust stock. Transfers should be submitted through Transfer Requests.</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            const action = document.getElementById('actionSelect');
            const qty = document.getElementById('qtyInput');
            const fromBlock = document.getElementById('fromBlock');
            const toBlock = document.getElementById('toBlock');
            const fromSelect = document.getElementById('fromSelect');
            const toSelect = document.getElementById('toSelect');
            const fromLabel = document.getElementById('fromLabel');
            const fromHelp = document.getElementById('fromHelp');
            const qtyHelp = document.getElementById('qtyHelp');
            const allowTransfer = '@Model.AllowTransfer'.toLowerCase() === 'true';

            function availableFrom() {
                const opt = fromSelect?.selectedOptions?.[0];
                const v = opt ? parseInt(opt.getAttribute('data-qty') || "0", 10) : 0;
                return isNaN(v) ? 0 : v;
            }

            function refresh() {
                const v = action.value;

                if (v === "1") {
                    fromBlock.style.display = "none";
                    toBlock.style.display = "";
                    qty.readOnly = false;
                    qtyHelp.innerText = "Enter a positive quantity to add.";
                    fromHelp.innerText = "";
                    qty.removeAttribute("max");
                }
                else if (v === "2") {
                    fromBlock.style.display = "";
                    toBlock.style.display = "none";
                    fromLabel.innerText = "Location";
                    qty.readOnly = false;

                    const av = availableFrom();
                    qty.max = av > 0 ? av : "";
                    fromHelp.innerText = av > 0 ? `Available in selected location: ${av}` : "";
                    qtyHelp.innerText = "Enter a positive quantity to remove.";
                }
                else if (v === "3") {
                    fromBlock.style.display = "";
                    toBlock.style.display = "none";
                    fromLabel.innerText = "Location";
                    qty.readOnly = false;
                    qty.removeAttribute("max");
                    fromHelp.innerText = "";
                    qtyHelp.innerText = "Can be positive or negative (notes required).";
                }
                else if (v === "4" && allowTransfer) {
                    fromBlock.style.display = "";
                    toBlock.style.display = "";
                    fromLabel.innerText = "From Location";
                    qty.readOnly = false;

                    const av = availableFrom();
                    qty.max = av > 0 ? av : "";
                    fromHelp.innerText = av > 0 ? `Available in selected location: ${av}` : "";
                    qtyHelp.innerText = "Enter a positive quantity to move.";

                    const fromVal = fromSelect.value;
                    Array.from(toSelect.options).forEach(o => {
                        o.disabled = fromVal && o.value === fromVal;
                    });
                }
                else {
                    fromBlock.style.display = "none";
                    toBlock.style.display = "none";
                    qty.removeAttribute("max");
                    fromHelp.innerText = "";
                    qtyHelp.innerText = "";
                }
            }

            if (action) action.addEventListener('change', refresh);
            if (fromSelect) fromSelect.addEventListener('change', refresh);
            refresh();
        })();
    </script>
}