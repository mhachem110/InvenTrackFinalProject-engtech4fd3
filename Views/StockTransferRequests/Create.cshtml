@model InvenTrack.ViewModels.TransferRequests.TransferRequestCreateVM

@{
    ViewData["Title"] = "Request Transfer";

    bool isAdmin = User.IsInRole(InvenTrack.Models.AppRoles.Admin);
    bool isRegionalManager = User.IsInRole(InvenTrack.Models.AppRoles.RegionalManager);
    bool isManager = User.IsInRole(InvenTrack.Models.AppRoles.Manager);
    bool isSupervisor = User.IsInRole(InvenTrack.Models.AppRoles.Supervisor);
    bool isEmployee = User.IsInRole(InvenTrack.Models.AppRoles.Employee);

    var assignedLocationName = User.FindFirst("AssignedLocationName")?.Value ?? "";
    var isScopedUser = isManager || isSupervisor || isEmployee;
    var scopeLabel = isScopedUser
        ? (string.IsNullOrWhiteSpace(assignedLocationName) ? "Assigned location" : assignedLocationName)
        : "All locations";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Request Transfer</h1>
        </div>
        <div class="text-muted small">Submit a stock transfer request for review.</div>
        <div class="text-muted small mt-1">
            <span class="badge bg-light text-dark border it-badge">Scope: @scopeLabel</span>
        </div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="it-panel mb-3">
    <div class="it-panel-body">
        <div class="row g-2 align-items-end">
            <div class="col-lg-6">
                <label class="form-label">Scan barcode</label>
                <form asp-controller="InventoryItems" asp-action="LookupByBarcode" method="get" class="d-flex gap-2">
                    <input type="hidden" name="returnTo" value="/StockTransferRequests/Create" />
                    <input class="form-control" name="barcode" placeholder="Scan or type barcode to load item" />
                    <button class="btn btn-outline-primary" type="submit">Load Item</button>
                </form>
            </div>
            <div class="col-lg-6 text-lg-end">
                <a asp-controller="InventoryItems" asp-action="Scan" class="btn btn-outline-secondary">Open Scanner</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 g-lg-4">
    <div class="col-lg-8">
        <div class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">Transfer request</div>
                <div class="text-muted small">Choose locations and quantity, then submit for review.</div>
            </div>

            <div class="it-panel-body">
                @if (isScopedUser && !string.IsNullOrWhiteSpace(assignedLocationName))
                {
                    <div class="it-hint mb-3">
                        You are scoped to <strong>@assignedLocationName</strong>. Available locations may be limited by your role.
                    </div>
                }

                <form asp-action="Create" method="post" id="trCreateForm">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="InventoryItemID" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Item</label>
                            <input class="form-control" value="@Model.ItemName" disabled />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">SKU</label>
                            <input class="form-control" value="@Model.SKU" disabled />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity" class="form-control" id="qtyInput" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                            <div class="form-text" id="qtyHelp">Enter a positive number (how many units to move).</div>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="FromStorageLocationID" class="form-label"></label>
                            <select asp-for="FromStorageLocationID"
                                    asp-items="Model.AvailableLocations"
                                    class="form-select"
                                    id="fromSelect"></select>
                            <span asp-validation-for="FromStorageLocationID" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="ToStorageLocationID" class="form-label"></label>
                            <select asp-for="ToStorageLocationID"
                                    asp-items="Model.AvailableLocations"
                                    class="form-select"
                                    id="toSelect"></select>
                            <span asp-validation-for="ToStorageLocationID" class="text-danger small"></span>
                            <div class="form-text text-danger d-none" id="sameLocWarn">From and To locations must be different.</div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Optional: reason for transfer, urgency, etc."></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="d-flex gap-2 flex-wrap">
                                <button type="submit" class="btn btn-primary" id="submitBtn">Submit Request</button>
                                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </div>
                    </div>
                </form>

                <hr class="my-4" />

                <div class="it-hint">
                    Tip: If the transfer is urgent, include a short reason in Notes (e.g., “required for operations today”).
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">What happens next</div>
                <div class="text-muted small">Approval & processing.</div>
            </div>

            <div class="it-panel-body">
                <div class="it-mini mb-3">
                    <div class="it-mini-title">1) Submit request</div>
                    <div class="text-muted small">Your request is logged as <span class="fw-semibold">Pending</span>.</div>
                </div>

                <div class="it-mini mb-3">
                    <div class="it-mini-title">2) Review</div>
                    <div class="text-muted small">A Manager/Admin reviews and approves or rejects it.</div>
                </div>

                <div class="it-mini">
                    <div class="it-mini-title">3) Stock updated</div>
                    <div class="text-muted small">If approved, stock movement is applied between locations.</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            const fromSelect = document.getElementById('fromSelect');
            const toSelect = document.getElementById('toSelect');
            const warn = document.getElementById('sameLocWarn');
            const submitBtn = document.getElementById('submitBtn');

            function validateDifferent() {
                const fromVal = fromSelect ? fromSelect.value : "";
                const toVal = toSelect ? toSelect.value : "";
                const bad = fromVal && toVal && fromVal === toVal;

                if (warn) warn.classList.toggle('d-none', !bad);
                if (submitBtn) submitBtn.disabled = bad;
            }

            if (fromSelect) fromSelect.addEventListener('change', validateDifferent);
            if (toSelect) toSelect.addEventListener('change', validateDifferent);
            validateDifferent();
        })();
    </script>
}