@model InvenTrack.ViewModels.TransferRequests.TransferRequestCreateVM

@{
    ViewData["Title"] = "Request Transfer";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Request Transfer</h1>
        </div>
        <div class="text-muted small">Submit a stock transfer request for review.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="it-panel">
    <div class="it-panel-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="InventoryItemID" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Item</label>
                    <input class="form-control" value="@Model.ItemName" disabled />
                </div>

                <div class="col-md-6">
                    <label class="form-label">SKU</label>
                    <input class="form-control" value="@Model.SKU" disabled />
                </div>

                <div class="col-md-4">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" class="form-control" />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="FromStorageLocationID" class="form-label"></label>
                    <select asp-for="FromStorageLocationID" asp-items="Model.AvailableLocations" class="form-select"></select>
                    <span asp-validation-for="FromStorageLocationID" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="ToStorageLocationID" class="form-label"></label>
                    <select asp-for="ToStorageLocationID" asp-items="Model.AvailableLocations" class="form-select"></select>
                    <span asp-validation-for="ToStorageLocationID" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Notes" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Submit Request</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}