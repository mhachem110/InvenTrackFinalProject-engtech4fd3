@model InvenTrack.ViewModels.Reports.ReportIndexVM

@{
    ViewData["Title"] = "Reports";
    var aiPredictedIssuesCount = (ViewData["AiPredictedIssuesCount"] as int?) ?? 0;
    var aiUrgentIssuesCount = (ViewData["AiUrgentIssuesCount"] as int?) ?? 0;
}

<div class="it-report-shell">

    <div class="it-report-hero mb-4">
        <div class="it-report-hero__left">
            <div class="it-report-kicker">Reporting Workspace</div>
            <h1 class="it-report-title">Reports</h1>
            <p class="it-report-subtitle">
                Review stock health, location coverage, movement history, and AI-based replenishment insights.
            </p>
        </div>

        <div class="it-report-hero__right">
            <div class="it-report-hero-stat">
                <span class="label">Available modules</span>
                <span class="value">6</span>
            </div>
            <div class="it-report-hero-stat">
                <span class="label">AI alerts</span>
                <span class="value">@aiUrgentIssuesCount</span>
            </div>
        
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-report-card">
                <div class="it-report-card__icon">🗂️</div>
                <div class="it-report-card__label">Category Summary</div>
                <div class="it-report-card__value">@Model.CategoryCount</div>
                <div class="it-report-card__text">Inventory concentration, low stock counts, and totals by category.</div>
                <div class="it-report-card__actions">
                    <a asp-action="CategorySummary" class="btn btn-primary btn-sm">Open Report</a>
                    <a asp-action="ExportCategorySummaryCsv" class="btn btn-outline-secondary btn-sm">Export</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-report-card">
                <div class="it-report-card__icon">📈</div>
                <div class="it-report-card__label">Movement Summary</div>
                <div class="it-report-card__value">@Model.MovementSummaryCount</div>
                <div class="it-report-card__text">Shows the busiest inventory items across recent stock activity.</div>
                <div class="it-report-card__actions">
                    <a asp-action="MovementSummary" class="btn btn-primary btn-sm">Open Report</a>
                    <a asp-action="ExportMovementSummaryCsv" class="btn btn-outline-secondary btn-sm">Export</a>
                </div>
            </div>
        </div>

    </div>

    <div class="row g-3 g-xl-4 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-report-card">
                <div class="it-report-card__icon">📦</div>
                <div class="it-report-card__label">Inventory Export</div>
                <div class="it-report-card__value">@Model.InventoryItemCount</div>
                <div class="it-report-card__text">Complete inventory list prepared for export and review.</div>
                <div class="it-report-card__actions">
                    <a asp-action="ExportInventoryCsv" class="btn btn-primary btn-sm">Export CSV</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-report-card">
                <div class="it-report-card__icon">⚠️</div>
                <div class="it-report-card__label">Low Stock</div>
                <div class="it-report-card__value">@Model.LowStockItemCount</div>
                <div class="it-report-card__text">Items currently at or below their reorder threshold.</div>
                <div class="it-report-card__actions">
                    <a asp-action="LowStock" class="btn btn-primary btn-sm">Open Report</a>
                    <a asp-action="ExportLowStockCsv" class="btn btn-outline-secondary btn-sm">Export</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-report-card">
                <div class="it-report-card__icon">📍</div>
                <div class="it-report-card__label">Location Summary</div>
                <div class="it-report-card__value">@Model.StorageLocationCount</div>
                <div class="it-report-card__text">Active item counts and stock totals by storage location.</div>
                <div class="it-report-card__actions">
                    <a asp-action="LocationSummary" class="btn btn-primary btn-sm">Open Report</a>
                    <a asp-action="ExportLocationSummaryCsv" class="btn btn-outline-secondary btn-sm">Export</a>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="it-report-card">
                <div class="it-report-card__icon">🧾</div>
                <div class="it-report-card__label">Transactions</div>
                <div class="it-report-card__value">@Model.RecentTransactionCount</div>
                <div class="it-report-card__text">Audit-friendly movement history with search and filtering.</div>
                <div class="it-report-card__actions">
                    <a asp-action="RecentTransactions" class="btn btn-primary btn-sm">Open Report</a>
                    <a asp-action="ExportRecentTransactionsCsv" class="btn btn-outline-secondary btn-sm">Export</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 g-xl-4 mb-4">
        <div class="col-12 col-xl-8">
            <div class="it-panel h-100">
                <div class="it-panel-header d-flex justify-content-between align-items-start gap-2 flex-wrap">
                    <div>
                        <div class="fw-bold">AI Replenishment Intelligence</div>
                        <div class="text-muted small">Forecast near-term stock risk using transaction history and reorder logic.</div>
                    </div>
                    <span class="badge bg-primary-subtle text-primary border it-badge">Live Analysis</span>
                </div>

                <div class="it-panel-body">
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-4">
                            <div class="it-report-mini">
                                <div class="it-report-mini__label">Predicted Issues</div>
                                <div class="it-report-mini__value">@aiPredictedIssuesCount</div>
                                <div class="it-report-mini__text">Items already low or expected to drop soon.</div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <div class="it-report-mini">
                                <div class="it-report-mini__label">Urgent Alerts</div>
                                <div class="it-report-mini__value">@aiUrgentIssuesCount</div>
                                <div class="it-report-mini__text">Items needing immediate replenishment attention.</div>
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <div class="it-report-mini">
                                <div class="it-report-mini__label">Signal Source</div>
                                <div class="it-report-mini__value fs-6 mt-1">Usage History</div>
                                <div class="it-report-mini__text">Based on check-outs and negative adjustments.</div>
                            </div>
                        </div>
                    </div>

                    <div class="it-hint mb-3">
                        This AI view is designed for demo use and manager review. It builds on your current transaction data without needing a separate machine learning service.
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="AiInsights" class="btn btn-dark">Open AI Insights</a>
                        <a asp-action="ExportAiInsightsCsv" class="btn btn-outline-dark">Export AI CSV</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="it-panel h-100">
                <div class="it-panel-header">
                    <div class="fw-bold">Export Center</div>
                    <div class="text-muted small">Download clean CSV files for demos, Excel, and instructor review.</div>
                </div>

                <div class="it-panel-body">
                    <div class="it-report-export-list">
                        <a asp-action="ExportInventoryCsv" class="it-report-export-link">Inventory CSV</a>
                        <a asp-action="ExportLowStockCsv" class="it-report-export-link">Low Stock CSV</a>
                        <a asp-action="ExportLocationSummaryCsv" class="it-report-export-link">Location Summary CSV</a>
                        <a asp-action="ExportRecentTransactionsCsv" class="it-report-export-link">Recent Transactions CSV</a>
                        <a asp-action="ExportCategorySummaryCsv" class="it-report-export-link">Category Summary CSV</a>
                        <a asp-action="ExportMovementSummaryCsv" class="it-report-export-link">Movement Summary CSV</a>
                        <a asp-action="ExportAiInsightsCsv" class="it-report-export-link">AI Insights CSV</a>
                    </div>

                    <div class="it-hint mt-3">
                        CSV remains the best demo-friendly export format because it opens easily in Excel and requires no extra setup.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 g-xl-4">
        <div class="col-12 col-xl-6">
            <div class="it-panel h-100">
                <div class="it-panel-header">
                    <div class="fw-bold">Available Report Views</div>
                    <div class="text-muted small">Core reporting screens in the current system.</div>
                </div>

                <div class="it-panel-body">
                    <div class="it-report-list">
                        <div class="it-report-list__item">
                            <div class="it-report-list__num">1</div>
                            <div>
                                <div class="fw-semibold">Low Stock</div>
                                <div class="text-muted small">Shows items currently at or below reorder level.</div>
                            </div>
                        </div>

                        <div class="it-report-list__item">
                            <div class="it-report-list__num">2</div>
                            <div>
                                <div class="fw-semibold">Location Summary</div>
                                <div class="text-muted small">Shows active item count and total units per location.</div>
                            </div>
                        </div>

                        <div class="it-report-list__item">
                            <div class="it-report-list__num">3</div>
                            <div>
                                <div class="fw-semibold">Recent Transactions</div>
                                <div class="text-muted small">Shows filtered movement history for audit and review.</div>
                            </div>
                        </div>

                        <div class="it-report-list__item">
                            <div class="it-report-list__num">6</div>
                            <div>
                                <div class="fw-semibold">AI Insights</div>
                                <div class="text-muted small">Shows forecasted inventory risk and suggested actions.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="it-panel h-100">
                <div class="it-panel-header">
                    <div class="fw-bold">Why This Report Area Matters</div>
                    <div class="text-muted small">Good talking points for presentation and demo.</div>
                </div>

                <div class="it-panel-body">
                    <div class="it-report-list">
                        <div class="it-report-list__item">
                            <div class="it-report-list__num">A</div>
                            <div>
                                <div class="fw-semibold">Operational visibility</div>
                                <div class="text-muted small">Managers can quickly review stock health and movement trends.</div>
                            </div>
                        </div>

                        <div class="it-report-list__item">
                            <div class="it-report-list__num">B</div>
                            <div>
                                <div class="fw-semibold">Audit support</div>
                                <div class="text-muted small">Transactions and summaries are exportable for review and proof.</div>
                            </div>
                        </div>

                        <div class="it-report-list__item">
                            <div class="it-report-list__num">C</div>
                            <div>
                                <div class="fw-semibold">Decision support</div>
                                <div class="text-muted small">AI insights help move from static reporting to smarter replenishment planning.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>