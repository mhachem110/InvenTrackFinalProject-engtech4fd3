        font-weight: 800;
        text-decoration: none;
    }

        .ai-chip strong {
            color: var(--ai-text);
        }

    .ai-chip-link {
        text-decoration: none;
        transition: .18s ease;
    }

        .ai-chip-link:hover {
            transform: translateY(-1px);
        }

        .ai-chip-link.is-active .ai-chip {
            background: var(--ai-text);
            color: #fff;
            border-color: var(--ai-text);
        }

            .ai-chip-link.is-active .ai-chip strong {
                color: #fff;
            }

