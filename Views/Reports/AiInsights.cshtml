            color: var(--ai-text);
        }

    .ai-detail-row {
        display: none;
        background: #fcfdff;
    }

        .ai-detail-row.is-open {
            display: table-row;
        }

    .ai-detail-cell {
        padding: 0 !important;
        background: #fcfdff;
    }

    .ai-detail-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr;
        gap: .65rem;
        padding: .85rem;
    }

    .ai-detail-card {
        background: #fff;
        border: 1px solid var(--ai-border);
        border-radius: 12px;
        padding: .78rem;
    }

    .ai-detail-label {
        font-size: .71rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        font-weight: 900;
        color: var(--ai-text-soft);
        margin-bottom: .25rem;
    }

    .ai-detail-text {
        color: var(--ai-text);
        font-size: .83rem;
        line-height: 1.48;
    }

    .ai-detail-list {
        display: grid;
        gap: .38rem;
    }

    .ai-detail-kv {
        display: flex;
        justify-content: space-between;
        gap: .65rem;
        font-size: .79rem;
        color: var(--ai-text-soft);
    }

        .ai-detail-kv strong {
            color: var(--ai-text);
            font-weight: 900;
        }

    .ai-pagination {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .8rem;
        flex-wrap: wrap;
        margin-top: .85rem;
    }

    .ai-pagination-text {
        color: var(--ai-text-soft);
        font-size: .82rem;
    }

    .ai-pagination-list {
        display: flex;
        gap: .38rem;
        flex-wrap: wrap;
    }

    .ai-page-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        height: 36px;
        padding: 0 .72rem;
        border-radius: 10px;
        border: 1px solid var(--ai-border);
        background: #fff;
        color: var(--ai-text);
        font-size: .8rem;
        font-weight: 900;
        text-decoration: none;
    }

        .ai-page-link:hover {
            color: var(--ai-text);
            background: var(--ai-surface-soft);
        }

        .ai-page-link.is-active {
            background: var(--ai-text);
            color: #fff;
            border-color: var(--ai-text);
        }

        .ai-page-link.is-disabled {
            pointer-events: none;
            opacity: .45;
        }

    .ai-empty {
        padding: 1.8rem .8rem;
        text-align: center;
        color: var(--ai-text-soft);
    }

    .ai-empty-title {
        color: var(--ai-text);
        font-size: .94rem;
        font-weight: 900;
    }

    .ai-empty-text {
        margin-top: .28rem;
        font-size: .84rem;
        line-height: 1.5;
    }

    @@media (max-width: 1280px) {
        .ai-filter-grid

    {
        grid-template-columns: 1.8fr 1fr 1fr 1fr;
    }

    .ai-filter-actions {
        grid-column: span 4;
    }

    .ai-advanced-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ai-stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ai-main-grid {
        grid-template-columns: 1fr;
    }

    .ai-detail-grid {
        grid-template-columns: 1fr;
    }

    }

    @@media (max-width: 860px) {
        .ai-filter-grid, .ai-advanced-grid

    {
        grid-template-columns: 1fr 1fr;
    }

    .ai-filter-actions {
        grid-column: span 2;
    }

    }

    @@media (max-width: 640px) {
        .ai-hero, .ai-panel-body

    {
        padding: .9rem;
    }

    .ai-panel-head {
        padding: .8rem .9rem 0;
    }

    .ai-stats,
    .ai-filter-grid,
    .ai-advanced-grid {
        grid-template-columns: 1fr;
    }

    .ai-filter-actions {
        grid-column: auto;
    }

    .ai-table-wrap,
    .ai-panel,
    .ai-hero {
        border-radius: 16px;
    }

    }
</style>

<div class="ai-page">

    <section class="ai-hero">
        <div class="ai-hero-top">
            <div>
                <div class="ai-eyebrow">
                    <span class="ai-eyebrow-dot"></span>
                    <span>Reports / Inventory Intelligence</span>
                </div>

                <h1 class="ai-title">AI Insights</h1>

                <p class="ai-subtitle">
                    A compact view of inventory risk, reorder timing, and the next action that matters most.
                </p>
            </div>

            <div class="ai-actions">
                <a href="@exportUrl" class="ai-btn ai-btn-primary">Export CSV</a>
                <a href="@backUrl" class="ai-btn ai-btn-secondary">Back</a>
            </div>
        </div>

        <div class="ai-stats">
            <div class="ai-stat">
                <div class="ai-stat-label">Analyzed</div>
                <div class="ai-stat-value">@Model.TotalItemsAnalyzed</div>
                <div class="ai-stat-note">Items in current AI scope.</div>
            </div>

            <a href="@reorderNowUrl" class="ai-stat">
                <div class="ai-stat-label">Now</div>
                <div class="ai-stat-value">@Model.ReorderNowCount</div>
                <div class="ai-stat-note">Need immediate replenishment.</div>
            </a>

            <a href="@reorderSoonUrl" class="ai-stat">
                <div class="ai-stat-label">Soon</div>
                <div class="ai-stat-value">@Model.ReorderSoonCount</div>
                <div class="ai-stat-note">Approaching reorder threshold.</div>
            </a>

            <a href="@watchUrl" class="ai-stat">
                <div class="ai-stat-label">Watch</div>
                <div class="ai-stat-value">@Model.WatchCount</div>
                <div class="ai-stat-note">Trending toward risk.</div>
            </a>
        </div>
    </section>

    <section class="ai-panel">
        <div class="ai-panel-head">
            <h2 class="ai-panel-title">Filters</h2>
            <p class="ai-panel-subtitle">
                Cleaner controls with a smaller footprint.
            </p>
        </div>

        <div class="ai-panel-body">
            <form method="get" class="ai-filter-form">
                <div class="ai-filter-grid">
                    <div class="ai-field">
                        <label class="ai-label">Search</label>
                        <input type="text"
                               name="q"
                               value="@Model.Query"
                               class="form-control ai-control"
                               placeholder="Search item, SKU, category..." />
                    </div>

                    <div class="ai-field">
                        <label class="ai-label">Status</label>
                        <select name="alertFilter" class="form-select ai-select">
                            <option value="all" selected="@(string.Equals(Model.AlertFilter, "all", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">All</option>
                            <option value="ReorderNow" selected="@(string.Equals(Model.AlertFilter, "ReorderNow", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Reorder Now</option>
                            <option value="ReorderSoon" selected="@(string.Equals(Model.AlertFilter, "ReorderSoon", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Reorder Soon</option>
                            <option value="Watch" selected="@(string.Equals(Model.AlertFilter, "Watch", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Watch</option>
                            <option value="Stable" selected="@(string.Equals(Model.AlertFilter, "Stable", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Stable</option>
                            <option value="InsufficientData" selected="@(string.Equals(Model.AlertFilter, "InsufficientData", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Insufficient Data</option>
                        </select>
                    </div>

                    <div class="ai-field">
                        <label class="ai-label">Category</label>
                        <select name="categoryFilter" class="form-select ai-select">
                            <option value="all" selected="@(string.Equals(Model.CategoryFilter, "all", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">All</option>
                            @foreach (var category in categories)
                            {
                                <option value="@category" selected="@(string.Equals(Model.CategoryFilter, category, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                                    @category
                                </option>
                            }
                        </select>
                    </div>

                    <div class="ai-field">
                        <label class="ai-label">Location</label>
                        <select name="locationFilter" class="form-select ai-select">
                            <option value="all" selected="@(string.Equals(Model.LocationFilter, "all", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">All</option>
                            @foreach (var location in locations)
                            {
                                <option value="@location" selected="@(string.Equals(Model.LocationFilter, location, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                                    @location
                                </option>
                            }
                        </select>
                    </div>

                    <div class="ai-field">
                        <label class="ai-label">Sort</label>
                        <select name="sortBy" class="form-select ai-select">
                            <option value="urgency" selected="@(string.Equals(Model.SortBy, "urgency", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Urgency</option>
                            <option value="soonest" selected="@(string.Equals(Model.SortBy, "soonest", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Soonest Reorder</option>
                            <option value="usage_desc" selected="@(string.Equals(Model.SortBy, "usage_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Highest Usage</option>
                            <option value="reorder_qty_desc" selected="@(string.Equals(Model.SortBy, "reorder_qty_desc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Largest Reorder</option>
                            <option value="stock_asc" selected="@(string.Equals(Model.SortBy, "stock_asc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Lowest Stock</option>
                            <option value="item_asc" selected="@(string.Equals(Model.SortBy, "item_asc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Item A-Z</option>
                            <option value="category_asc" selected="@(string.Equals(Model.SortBy, "category_asc", StringComparison.OrdinalIgnoreCase) ? "selected" : null)">Category A-Z</option>
                        </select>
                    </div>

                    <div class="ai-filter-actions">
                        <button type="submit" class="ai-btn ai-btn-primary">Apply</button>
                        <a href="@resetUrl" class="ai-btn ai-btn-secondary">Reset</a>
                    </div>
                </div>

                <details class="ai-advanced">
                    <summary>Advanced settings</summary>
                    <div class="ai-advanced-grid">
                        <div class="ai-field">
                            <label class="ai-label">Lookback Days</label>
                            <input type="number"
                                   name="lookbackDays"
                                   value="@Model.LookbackDays"
                                   min="14"
                                   max="180"
                                   class="form-control ai-control" />
                        </div>

                        <div class="ai-field">
                            <label class="ai-label">Target Coverage</label>
                            <input type="number"
                                   name="targetCoverageDays"
                                   value="@Model.TargetCoverageDays"
                                   min="7"
                                   max="60"
                                   class="form-control ai-control" />
                        </div>

                        <div class="ai-field">
                            <label class="ai-label">Reorder Soon Window</label>
                            <input type="number"
                                   name="reorderSoonDays"
                                   value="@Model.ReorderSoonDays"
                                   min="3"
                                   max="45"
                                   class="form-control ai-control" />
                        </div>

                        <div class="ai-field">
                            <label class="ai-label">Page Size</label>
                            <select name="pageSize" class="form-select ai-select">
                                <option value="10" selected="@(Model.PageSize == 10 ? "selected" : null)">10</option>
                                <option value="25" selected="@(Model.PageSize == 25 ? "selected" : null)">25</option>
                                <option value="50" selected="@(Model.PageSize == 50 ? "selected" : null)">50</option>
                                <option value="100" selected="@(Model.PageSize == 100 ? "selected" : null)">100</option>
                            </select>
                        </div>
                    </div>
                </details>

                <input type="hidden" name="page" value="1" />

                <div class="ai-active">
                    <a href="@allUrl" class="ai-chip-link @(string.Equals(Model.AlertFilter, "all", StringComparison.OrdinalIgnoreCase) ? "is-active" : "")">
                        <span class="ai-chip"><strong>All</strong> @Model.TotalFilteredItems</span>
                    </a>

                    <a href="@reorderNowUrl" class="ai-chip-link @(string.Equals(Model.AlertFilter, "ReorderNow", StringComparison.OrdinalIgnoreCase) ? "is-active" : "")">
                        <span class="ai-chip"><strong>Now</strong> @Model.ReorderNowCount</span>
                    </a>

                    <a href="@reorderSoonUrl" class="ai-chip-link @(string.Equals(Model.AlertFilter, "ReorderSoon", StringComparison.OrdinalIgnoreCase) ? "is-active" : "")">
                        <span class="ai-chip"><strong>Soon</strong> @Model.ReorderSoonCount</span>
                    </a>

                    <a href="@watchUrl" class="ai-chip-link @(string.Equals(Model.AlertFilter, "Watch", StringComparison.OrdinalIgnoreCase) ? "is-active" : "")">
                        <span class="ai-chip"><strong>Watch</strong> @Model.WatchCount</span>
                    </a>

                    <a href="@stableUrl" class="ai-chip-link @(string.Equals(Model.AlertFilter, "Stable", StringComparison.OrdinalIgnoreCase) ? "is-active" : "")">
                        <span class="ai-chip"><strong>Stable</strong> @Model.StableCount</span>
                    </a>

                    @if (hasAnyFilters)
                    {
                        if (hasSearch)
                        {
                            <span class="ai-chip">Search: <strong>@Model.Query</strong></span>
                        }

                        if (hasCategoryFilter)
                        {
                            <span class="ai-chip">Category: <strong>@Model.CategoryFilter</strong></span>
                        }

                        if (hasLocationFilter)
                        {
                            <span class="ai-chip">Location: <strong>@Model.LocationFilter</strong></span>
                        }

                        if (hasNonDefaultSort)
                        {
                            <span class="ai-chip">Sort: <strong>@Model.SortLabel</strong></span>
                        }

                        <a href="@resetUrl" class="ai-clear">Clear all</a>
                    }
                </div>
            </form>
        </div>
    </section>

    <section class="ai-main-grid">
        <div class="ai-panel">
            <div class="ai-panel-head">
                <h2 class="ai-panel-title">Priority Actions</h2>
                <p class="ai-panel-subtitle">
                    Smaller cards, quicker decisions.
                </p>
            </div>

            <div class="ai-panel-body">
                @if (!priorityItems.Any())
                {
                    <div class="ai-empty">
                        <div class="ai-empty-title">No priority items found</div>
                        <div class="ai-empty-text">Try broadening your filters.</div>
                    </div>
                }
                else
                {
                    <div class="ai-priority-list">
                        @foreach (var item in priorityItems)
                        {
                            var statusClass = GetStatusClass(item.AlertLevel);

                            <article class="ai-priority-card">
                                <div class="ai-priority-top">
                                    <div>
                                        <h3 class="ai-priority-name">@item.ItemName</h3>
                                        <div class="ai-priority-meta">@item.SKU • @item.CategoryName • @item.PrimaryLocationName</div>
                                    </div>

                                    <div class="ai-badges">
                                        <span class="ai-badge @statusClass">@item.AlertLabel</span>
                                        <span class="ai-pill">@item.ConfidenceLabel</span>
                                    </div>
                                </div>

                                <div class="ai-kv-row">
                                    <span class="ai-kv"><small>On Hand</small> @item.CurrentQuantityOnHand</span>
                                    <span class="ai-kv"><small>Gap</small> @item.UnitsAboveReorderDisplay</span>
                                    <span class="ai-kv"><small>Usage</small> @item.AverageDailyUsageDisplay</span>
                                    <span class="ai-kv"><small>Reorder</small> @item.SuggestedReorderQuantity</span>
                                </div>

                                <p class="ai-priority-summary">@item.InsightSummary</p>
                                <p class="ai-priority-action">@item.RecommendedAction</p>

                                <div class="ai-link-row">
                                    <a asp-controller="InventoryItems"
                                       asp-action="Details"
                                       asp-route-id="@item.ItemId"
                                       class="ai-link-btn is-primary">
                                        Open Item
                                    </a>

                                    <span class="ai-chip">Confidence <strong>@item.ConfidenceScore / 100</strong></span>
                                </div>
                            </article>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="ai-panel">
            <div class="ai-panel-head">
                <h2 class="ai-panel-title">Quick Snapshot</h2>
                <p class="ai-panel-subtitle">
                    High-signal highlights only.
                </p>
            </div>

            <div class="ai-panel-body">
                <div class="ai-mini-grid">
                    <div class="ai-mini-card">
                        <div class="ai-mini-icon">U</div>
                        <div>
                            <div class="ai-mini-label">Highest Usage</div>
                            @if (Model.HighestUsageItem != null)
                            {
                                <div class="ai-mini-title">@Model.HighestUsageItem.ItemName</div>
                                <div class="ai-mini-meta">@Model.HighestUsageItem.SKU • @Model.HighestUsageItem.PrimaryLocationName</div>
                                <div class="ai-mini-value">Avg daily usage: @Model.HighestUsageItem.AverageDailyUsageDisplay</div>
                            }
                            else
                            {
                                <div class="ai-mini-title">No item available</div>
                                <div class="ai-mini-meta">No high-usage item is available for the current filters.</div>
                            }
                        </div>
                    </div>

                    <div class="ai-mini-card">
                        <div class="ai-mini-icon">T</div>
                        <div>
                            <div class="ai-mini-label">Closest to Reorder</div>
                            @if (Model.ClosestToReorderItem != null)
                            {
                                <div class="ai-mini-title">@Model.ClosestToReorderItem.ItemName</div>
                                <div class="ai-mini-meta">@Model.ClosestToReorderItem.SKU • @Model.ClosestToReorderItem.PrimaryLocationName</div>
                                <div class="ai-mini-value">Days until reorder: @Model.ClosestToReorderItem.DaysUntilReorderDisplay</div>
                            }
                            else
                            {
                                <div class="ai-mini-title">No countdown available</div>
                                <div class="ai-mini-meta">No current filtered item has a countdown-based signal.</div>
                            }
                        </div>
                    </div>

                    <div class="ai-mini-card">
                        <div class="ai-mini-icon">R</div>
                        <div>
                            <div class="ai-mini-label">Largest Reorder</div>
                            @if (Model.LargestSuggestedReorderItem != null)
                            {
                                <div class="ai-mini-title">@Model.LargestSuggestedReorderItem.ItemName</div>
                                <div class="ai-mini-meta">@Model.LargestSuggestedReorderItem.SKU • @Model.LargestSuggestedReorderItem.PrimaryLocationName</div>
                                <div class="ai-mini-value">Suggested reorder: @Model.LargestSuggestedReorderItem.SuggestedReorderQuantity</div>
                            }
                            else
                            {
                                <div class="ai-mini-title">No recommendation available</div>
                                <div class="ai-mini-meta">No reorder suggestion is available in the current result set.</div>
                            }
                        </div>
                    </div>

                    <div class="ai-note">
                        <span class="ai-note-dot"></span>
                        <span>
                            <strong>@riskCount</strong> items are at risk, while
                            <strong>@stableLearningCount</strong> are stable or still learning.
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="ai-panel">
        <div class="ai-panel-head">
            <h2 class="ai-panel-title">Forecasted Inventory</h2>
            <p class="ai-panel-subtitle">
                Compact rows first, expandable detail only when needed.
            </p>
        </div>

        <div class="ai-panel-body">
            <div class="ai-table-top">
                <div class="ai-table-summary">
                    Showing <strong>@Model.StartItemNumber-@Model.EndItemNumber</strong> of <strong>@Model.TotalFilteredItems</strong> results
                </div>

                <div class="ai-active">
                    <span class="ai-chip">Sorted <strong>@Model.SortLabel</strong></span>
                    <span class="ai-chip">Risk <strong>@riskCount</strong></span>
                    <span class="ai-chip">Stable/Learning <strong>@stableLearningCount</strong></span>
                </div>
            </div>

            @if (!items.Any())
            {
                <div class="ai-empty">
                    <div class="ai-empty-title">No items matched your current filters</div>
                    <div class="ai-empty-text">Try clearing one or more filters.</div>
                </div>
            }
            else
            {
                <div class="ai-table-wrap">
                    <table class="ai-table">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Status</th>
                                <th>Confidence</th>
                                <th>Stock</th>
                                <th>Forecast</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < items.Count; i++)
                            {
                                var item = items[i];
                                var statusClass = GetStatusClass(item.AlertLevel);
                                var gapClass = GetGapClass(item.UnitsAboveReorder);
                                var scoreClass = GetScoreClass(item.ConfidenceLabel);
                                var detailId = "aiDetailRow" + i;
                                var toggleId = "aiDetailToggle" + i;

                                <tr>
                                    <td>
                                        <div class="ai-item-name">@item.ItemName</div>
                                        <div class="ai-item-meta">@item.SKU • @item.CategoryName • @item.PrimaryLocationName</div>
                                    </td>

                                    <td>
                                        <div class="ai-stack">
                                            <span class="ai-badge @statusClass">@item.AlertLabel</span>
                                            <span class="ai-sub">@item.ShortActionLabel</span>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="ai-score">
                                            <div class="ai-score-top">
                                                <span class="ai-score-label">@item.ConfidenceLabel</span>
                                                <span class="ai-score-value">@item.ConfidenceScore / 100</span>
                                            </div>
                                            <div class="ai-score-bar">
                                                <div class="ai-score-fill @scoreClass" style="width:@(item.ConfidenceScore)%"></div>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="ai-stack">
                                            <span class="ai-value">@item.CurrentQuantityOnHand</span>
                                            <span class="ai-sub">Current</span>
                                        </div>

                                        <div class="ai-stack" style="margin-top:.42rem;">
                                            <span class="ai-value @gapClass">@item.UnitsAboveReorderDisplay</span>
                                            <span class="ai-sub">Gap to reorder</span>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="ai-stack">
                                            <span class="ai-value">@item.DaysUntilReorderDisplay</span>
                                            <span class="ai-sub">Days until reorder</span>
                                        </div>

                                        <div class="ai-stack" style="margin-top:.42rem;">
                                            <span class="ai-value">@item.SuggestedReorderQuantity</span>
                                            <span class="ai-sub">Suggested qty</span>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="ai-action-text">@item.RecommendedAction</div>

                                        <div class="ai-table-actions">
                                            <a asp-controller="InventoryItems"
                                               asp-action="Details"
                                               asp-route-id="@item.ItemId"
                                               class="ai-link-btn is-primary">
                                                Open
                                            </a>

                                            <button type="button"
                                                    id="@toggleId"
                                                    class="ai-row-toggle"
                                                    data-target="#@detailId"
                                                    aria-expanded="false"
                                                    aria-controls="@detailId">
                                                Details
                                            </button>
                                        </div>
                                    </td>
                                </tr>

                                <tr id="@detailId" class="ai-detail-row">
                                    <td colspan="6" class="ai-detail-cell">
                                        <div class="ai-detail-grid">
                                            <div class="ai-detail-card">
                                                <div class="ai-detail-label">AI Summary</div>
                                                <div class="ai-detail-text">@item.InsightSummary</div>

                                                <div class="ai-detail-label" style="margin-top:.85rem;">Recommended Action</div>
                                                <div class="ai-detail-text">@item.RecommendedAction</div>
                                            </div>

                                            <div class="ai-detail-card">
                                                <div class="ai-detail-label">Demand Signals</div>
                                                <div class="ai-detail-list">
                                                    <div class="ai-detail-kv"><span>Demand signals</span><strong>@item.DemandSignalCount</strong></div>
                                                    <div class="ai-detail-kv"><span>Usage days</span><strong>@item.DaysWithUsage</strong></div>
                                                    <div class="ai-detail-kv"><span>Units consumed</span><strong>@item.TotalUnitsConsumed</strong></div>
                                                    <div class="ai-detail-kv"><span>Average daily usage</span><strong>@item.AverageDailyUsageDisplay</strong></div>
                                                </div>
                                            </div>

                                            <div class="ai-detail-card">
                                                <div class="ai-detail-label">Prediction Detail</div>
                                                <div class="ai-detail-list">
                                                    <div class="ai-detail-kv"><span>Predicted reorder date</span><strong>@item.PredictedReorderDateDisplay</strong></div>
                                                    <div class="ai-detail-kv"><span>Days until reorder</span><strong>@item.DaysUntilReorderDisplay</strong></div>
                                                    <div class="ai-detail-kv"><span>Reorder level</span><strong>@item.ReorderLevel</strong></div>
                                                    <div class="ai-detail-kv"><span>Suggested reorder</span><strong>@item.SuggestedReorderQuantity</strong></div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="ai-pagination">
                    <div class="ai-pagination-text">
                        Showing @Model.StartItemNumber-@Model.EndItemNumber of @Model.TotalFilteredItems results
                    </div>

                    <div class="ai-pagination-list">
                        <a class="ai-page-link @(Model.HasPreviousPage ? "" : "is-disabled")"
                           asp-action="AiInsights"
                           asp-route-q="@Model.Query"
                           asp-route-lookbackDays="@Model.LookbackDays"
                           asp-route-targetCoverageDays="@Model.TargetCoverageDays"
                           asp-route-reorderSoonDays="@Model.ReorderSoonDays"
                           asp-route-alertFilter="@Model.AlertFilter"
                           asp-route-categoryFilter="@Model.CategoryFilter"
                           asp-route-locationFilter="@Model.LocationFilter"
                           asp-route-sortBy="@Model.SortBy"
                           asp-route-page="@(Model.Page - 1)"
                           asp-route-pageSize="@Model.PageSize">
                            Prev
                        </a>

                        @for (int p = pagerStart; p <= pagerEnd; p++)
                        {
                            <a class="ai-page-link @(p == Model.Page ? "is-active" : "")"
                               asp-action="AiInsights"
                               asp-route-q="@Model.Query"
                               asp-route-lookbackDays="@Model.LookbackDays"
                               asp-route-targetCoverageDays="@Model.TargetCoverageDays"
                               asp-route-reorderSoonDays="@Model.ReorderSoonDays"
                               asp-route-alertFilter="@Model.AlertFilter"
                               asp-route-categoryFilter="@Model.CategoryFilter"
                               asp-route-locationFilter="@Model.LocationFilter"
                               asp-route-sortBy="@Model.SortBy"
                               asp-route-page="@p"
                               asp-route-pageSize="@Model.PageSize">
                                @p
                            </a>
                        }

                        <a class="ai-page-link @(Model.HasNextPage ? "" : "is-disabled")"
                           asp-action="AiInsights"
                           asp-route-q="@Model.Query"
                           asp-route-lookbackDays="@Model.LookbackDays"
                           asp-route-targetCoverageDays="@Model.TargetCoverageDays"
                           asp-route-reorderSoonDays="@Model.ReorderSoonDays"
                           asp-route-alertFilter="@Model.AlertFilter"
                           asp-route-categoryFilter="@Model.CategoryFilter"
                           asp-route-locationFilter="@Model.LocationFilter"
                           asp-route-sortBy="@Model.SortBy"
                           asp-route-page="@(Model.Page + 1)"
                           asp-route-pageSize="@Model.PageSize">
                            Next
                        </a>
                    </div>
                </div>
            }
        </div>
    </section>
</div>

@functions {
    public string GetStatusClass(string alertLevel)
    {
        if (string.Equals(alertLevel, "ReorderNow", StringComparison.OrdinalIgnoreCase))
            return "ai-status-critical";

        if (string.Equals(alertLevel, "ReorderSoon", StringComparison.OrdinalIgnoreCase))
            return "ai-status-soon";

        if (string.Equals(alertLevel, "Watch", StringComparison.OrdinalIgnoreCase))
            return "ai-status-watch";

        if (string.Equals(alertLevel, "Stable", StringComparison.OrdinalIgnoreCase))
            return "ai-status-stable";

        return "ai-status-neutral";
    }

    public string GetGapClass(int unitsAboveReorder)
    {
        if (unitsAboveReorder < 0)
            return "ai-gap-negative";

        if (unitsAboveReorder == 0)
            return "ai-gap-zero";

        return "ai-gap-positive";
    }

    public string GetScoreClass(string confidenceLabel)
    {
        if (string.Equals(confidenceLabel, "High", StringComparison.OrdinalIgnoreCase))
            return "high";

        if (string.Equals(confidenceLabel, "Medium", StringComparison.OrdinalIgnoreCase))
            return "medium";

        return "low";
    }
}

<script>
    (function () {
        document.querySelectorAll('.ai-row-toggle').forEach(function (button) {
            button.addEventListener('click', function () {
                var selector = button.getAttribute('data-target');
                var row = selector ? document.querySelector(selector) : null;

                if (!row) return;

                var isOpen = row.classList.toggle('is-open');
                button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                button.textContent = isOpen ? 'Hide' : 'Details';
            });
        });
    })();
</script>