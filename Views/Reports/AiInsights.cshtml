    .ai-panel-head {
        padding: .9rem 1rem 0;
    }

    .ai-panel-title {
        margin: 0;
        font-size: .96rem;
        font-weight: 900;
        letter-spacing: -0.02em;
    }

    .ai-panel-subtitle {
        margin: .22rem 0 0;
