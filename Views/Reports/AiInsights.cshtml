        line-height: 1.38;
        color: var(--ai-text);
        font-weight: 800;
    }

    .ai-table-actions {
        display: flex;
        gap: .45rem;
        flex-wrap: wrap;
        margin-top: .38rem;
    }

    .ai-row-toggle {
