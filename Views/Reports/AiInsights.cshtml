        min-height: 40px;
        border: 1px solid var(--ai-border);
        border-radius: 10px;
        background: #fbfdff;
        padding: 0 .8rem;
        color: var(--ai-text);
        font-size: .88rem;
        box-shadow: none !important;
    }

