    .ai-hero-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: .85rem;
        flex-wrap: wrap;
    }

    .ai-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        margin-bottom: .35rem;
        color: var(--ai-text-soft);
        font-size: .76rem;
        font-weight: 800;
        letter-spacing: .05em;
        text-transform: uppercase;
    }

    .ai-eyebrow-dot {
        width: 9px;
