        gap: .5rem;
        flex-wrap: wrap;
    }

    .ai-advanced {
        border: 1px solid var(--ai-border);
        border-radius: 12px;
        background: var(--ai-surface-soft);
        overflow: hidden;
    }

        .ai-advanced summary {
            list-style: none;
            cursor: pointer;
            padding: .7rem .85rem;
            font-size: .84rem;
            font-weight: 800;
            color: var(--ai-primary);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

            .ai-advanced summary::-webkit-details-marker {
                display: none;
            }

            .ai-advanced summary::after {
                content: "＋";
                font-size: 1rem;
                font-weight: 900;
            }

        .ai-advanced[open] summary::after {
            content: "−";
        }

    .ai-advanced-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: .65rem;
        padding: 0 .85rem .85rem;
    }

