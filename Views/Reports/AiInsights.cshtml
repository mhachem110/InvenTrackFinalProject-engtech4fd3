        font-size: .75rem;
        font-weight: 800;
        color: var(--ai-text);
    }

        .ai-kv small {
            color: var(--ai-text-soft);
            font-size: .69rem;
            font-weight: 800;
        }

    .ai-priority-summary {
        margin: .65rem 0 0;
