@model InvenTrack.Utilities.PaginatedList<InvenTrack.ViewModels.Reports.CategoryStockSummaryRowVM>
@using System
@using System.Linq

@{
    ViewData["Title"] = "Category Summary";
    var q = ViewData["CurrentFilter"]?.ToString() ?? "";
    var pageSize = (ViewData["CurrentPageSize"] as int?) ?? 10;

    var startItem = Model.TotalCount == 0 ? 0 : ((Model.PageIndex - 1) * Model.PageSize) + 1;
    var endItem = Model.TotalCount == 0 ? 0 : Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount);
    var firstPage = Math.Max(1, Model.PageIndex - 2);
    var lastPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);

    var visibleUnits = Model.Any() ? Model.Sum(x => x.TotalUnits) : 0;
    var visibleLowStock = Model.Any() ? Model.Sum(x => x.LowStockCount) : 0;
    var visibleActiveItems = Model.Any() ? Model.Sum(x => x.ActiveItemCount) : 0;
}

<div class="it-report-page">
    <div class="it-report-head mb-3">
        <div>
            <div class="it-report-kicker">Report</div>
            <h1 class="it-report-page-title">Category Summary</h1>
            <div class="text-muted small">Inventory totals, active items, and low-stock pressure by category.</div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="ExportCategorySummaryCsv" asp-route-q="@q" class="btn btn-primary">Export CSV</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Reports</a>
        </div>
    </div>

    <div class="it-report-summary-grid">
        <div class="it-report-summary-card">
            <div class="it-report-summary-card__label">Categories</div>
            <div class="it-report-summary-card__value">@Model.TotalCount</div>
            <div class="it-report-summary-card__text">Categories matching the current filter.</div>
        </div>
        <div class="it-report-summary-card">
            <div class="it-report-summary-card__label">Visible Active Items</div>
            <div class="it-report-summary-card__value">@visibleActiveItems</div>
            <div class="it-report-summary-card__text">Active item count across the current page.</div>
        </div>
        <div class="it-report-summary-card">
            <div class="it-report-summary-card__label">Visible Units</div>
            <div class="it-report-summary-card__value">@visibleUnits</div>
            <div class="it-report-summary-card__text">Total stock units shown in the current results.</div>
        </div>
        <div class="it-report-summary-card">
            <div class="it-report-summary-card__label">Visible Low Stock</div>
            <div class="it-report-summary-card__value">@visibleLowStock</div>
            <div class="it-report-summary-card__text">Items under pressure in the visible category set.</div>
        </div>
    </div>

    <form method="get" class="it-panel">
        <div class="it-panel-body">
            <input type="hidden" id="pageNumber" name="page" value="1" />

            <div class="row g-2 align-items-center">
                <div class="col-lg-7">
                    <div class="it-input">
                        <span class="it-input-ico">&#128269;</span>
                        <input type="text"
                               name="q"
                               value="@q"
                               class="form-control it-input-field"
                               placeholder="Search category..." />
                    </div>
                </div>

                <div class="col-lg-2">
                    <select id="pageSize" name="pageSize" class="form-select">
                        <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10 per page</option>
                        <option value="25" selected="@(pageSize == 25 ? "selected" : null)">25 per page</option>
                        <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50 per page</option>
                    </select>
                </div>

                <div class="col-lg-3 d-flex justify-content-lg-end gap-2">
                    <button class="btn btn-primary" type="submit">Apply</button>
                    <a asp-action="CategorySummary" class="btn btn-outline-secondary">Clear</a>
                </div>
            </div>

            <div class="mt-2 text-muted small">
                Showing @startItem - @endItem of @Model.TotalCount categories
            </div>
        </div>
    </form>

    <div class="it-panel">
        <div class="it-panel-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
            <div>
                <div class="fw-bold">Category Totals</div>
                <div class="text-muted small">Operational stock distribution by category.</div>
            </div>
            <span class="badge bg-primary-subtle text-primary border it-badge">@Model.TotalCount categories</span>
        </div>

        <div class="it-panel-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 it-table">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th class="text-end">Items</th>
                            <th class="text-end">Active</th>
                            <th class="text-end">Units</th>
                            <th class="text-end">Low Stock</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <div class="fw-semibold mb-1">No categories found</div>
                                    <div class="small">Try a different search.</div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var row in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@row.CategoryName</td>
                                    <td class="text-end">@row.ItemCount</td>
                                    <td class="text-end">@row.ActiveItemCount</td>
                                    <td class="text-end"><span class="it-qty">@row.TotalUnits</span></td>
                                    <td class="text-end">@row.LowStockCount</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 p-3 border-top">
                    <div class="text-muted small">Page @Model.PageIndex of @Model.TotalPages</div>

                    <nav aria-label="Category summary pagination">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link"
                                   asp-action="CategorySummary"
                                   asp-route-page="@(Model.PageIndex - 1)"
                                   asp-route-q="@q"
                                   asp-route-pageSize="@pageSize">Previous</a>
                            </li>

                            @if (firstPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link"
                                       asp-action="CategorySummary"
                                       asp-route-page="1"
                                       asp-route-q="@q"
                                       asp-route-pageSize="@pageSize">1</a>
                                </li>

                                @if (firstPage > 2)
                                {
                                    <li class="page-item disabled"><span class="page-link">...</span></li>
                                }
                            }

                            @for (var p = firstPage; p <= lastPage; p++)
                            {
                                <li class="page-item @(p == Model.PageIndex ? "active" : "")">
                                    <a class="page-link"
                                       asp-action="CategorySummary"
                                       asp-route-page="@p"
                                       asp-route-q="@q"
                                       asp-route-pageSize="@pageSize">@p</a>
                                </li>
                            }

                            @if (lastPage < Model.TotalPages)
                            {
                                @if (lastPage < Model.TotalPages - 1)
                                {
                                    <li class="page-item disabled"><span class="page-link">...</span></li>
                                }

                                <li class="page-item">
                                    <a class="page-link"
                                       asp-action="CategorySummary"
                                       asp-route-page="@Model.TotalPages"
                                       asp-route-q="@q"
                                       asp-route-pageSize="@pageSize">@Model.TotalPages</a>
                                </li>
                            }

                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link"
                                   asp-action="CategorySummary"
                                   asp-route-page="@(Model.PageIndex + 1)"
                                   asp-route-q="@q"
                                   asp-route-pageSize="@pageSize">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const pageSize = document.getElementById('pageSize');
            const pageNumber = document.getElementById('pageNumber');

            if (pageSize) {
                pageSize.addEventListener('change', function () {
                    if (pageNumber) pageNumber.value = 1;
                    this.form.submit();
                });
            }
        })();
    </script>
}
