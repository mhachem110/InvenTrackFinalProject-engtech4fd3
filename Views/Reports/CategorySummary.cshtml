@model InvenTrack.Utilities.PaginatedList<InvenTrack.ViewModels.Reports.CategoryStockSummaryRowVM>
@{
    ViewData["Title"] = "Category Summary";
    var q = ViewData["CurrentFilter"]?.ToString() ?? "";
    var pageSize = (ViewData["CurrentPageSize"] as int?) ?? 10;
}
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <div class="fw-bold">Category Summary</div>
            <div class="small text-muted">Inventory totals, active items, and low-stock counts by category.</div>
        </div>
        <a asp-action="ExportCategorySummaryCsv" asp-route-q="@q" class="btn btn-sm btn-outline-secondary">Export CSV</a>
    </div>
    <div class="card-body">
        <form method="get" class="row g-2 mb-3">
            <div class="col-sm-8">
                <input type="text" name="q" value="@q" class="form-control" placeholder="Search category..." />
            </div>
            <div class="col-sm-2">
                <select name="pageSize" class="form-select">
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="25" selected="@(pageSize == 25)">25</option>
                    <option value="50" selected="@(pageSize == 50)">50</option>
                </select>
            </div>
            <div class="col-sm-2">
                <button class="btn btn-primary w-100">Apply</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead><tr><th>Category</th><th class="text-end">Items</th><th class="text-end">Active</th><th class="text-end">Units</th><th class="text-end">Low Stock</th></tr></thead>
                <tbody>
                @foreach (var row in Model)
                {
                    <tr>
                        <td>@row.CategoryName</td>
                        <td class="text-end">@row.ItemCount</td>
                        <td class="text-end">@row.ActiveItemCount</td>
                        <td class="text-end">@row.TotalUnits</td>
                        <td class="text-end">@row.LowStockCount</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
