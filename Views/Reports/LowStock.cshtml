@model InvenTrack.Utilities.PaginatedList<InvenTrack.ViewModels.Reports.LowStockReportRowVM>
@using System

@{
    ViewData["Title"] = "Low Stock";

    var currentFilter = ViewData["CurrentFilter"] as string ?? string.Empty;
    var currentPageSize = ViewData["CurrentPageSize"] is int ps ? ps : 10;

    var startItem = Model.TotalCount == 0 ? 0 : ((Model.PageIndex - 1) * Model.PageSize) + 1;
    var endItem = Model.TotalCount == 0 ? 0 : Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount);

    var firstPage = Math.Max(1, Model.PageIndex - 2);
    var lastPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
}

<div class="it-report-page">
    <div class="it-report-head mb-3">
        <div>
            <div class="it-report-kicker">Report</div>
            <h1 class="it-report-page-title">Low Stock</h1>
            <div class="text-muted small">Items currently at or below their reorder level, ready for review and export.</div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="ExportLowStockCsv" asp-route-q="@currentFilter" class="btn btn-primary">Export CSV</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Reports</a>
        </div>
    </div>

    <form asp-action="LowStock" method="get" class="it-panel mb-3">
        <div class="it-panel-body">
            <input type="hidden" id="pageNumber" name="page" value="1" />

            <div class="row g-2 align-items-center">
                <div class="col-lg-7">
                    <div class="it-input">
                        <span class="it-input-ico">🔎</span>
                        <input name="q"
                               value="@currentFilter"
                               type="search"
                               class="form-control it-input-field"
                               placeholder="Search item, SKU, category, or location..." />
                    </div>
                </div>

                <div class="col-lg-2">
                    <select id="pageSize" name="pageSize" class="form-select">
                        <option value="10" selected="@(currentPageSize == 10 ? "selected" : null)">10 per page</option>
                        <option value="25" selected="@(currentPageSize == 25 ? "selected" : null)">25 per page</option>
                        <option value="50" selected="@(currentPageSize == 50 ? "selected" : null)">50 per page</option>
                    </select>
                </div>

                <div class="col-lg-3 d-flex justify-content-lg-end gap-2">
                    <button type="submit" class="btn btn-primary">Apply</button>
                    <a asp-action="LowStock" class="btn btn-outline-secondary">Clear</a>
                </div>
            </div>

            <div class="mt-2 text-muted small">
                Showing @startItem - @endItem of @Model.TotalCount low-stock items
            </div>
        </div>
    </form>

    <div class="it-panel">
        <div class="it-panel-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
            <div>
                <div class="fw-bold">Low Stock Queue</div>
                <div class="text-muted small">Stock pressure by item with reorder thresholds and location coverage.</div>
            </div>
            <span class="badge bg-warning-subtle text-warning-emphasis border it-badge">@Model.TotalCount flagged items</span>
        </div>

        <div class="it-panel-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 it-table">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th style="width:150px;">Category</th>
                            <th style="width:180px;">Primary Location</th>
                            <th style="width:110px;" class="text-end">On Hand</th>
                            <th style="width:120px;" class="text-end">Reorder</th>
                            <th style="width:120px;" class="text-end">Locations</th>
                            <th style="width:110px;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    <div class="fw-semibold mb-1">No low-stock items found</div>
                                    <div class="small">Try a different filter.</div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var row in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">
                                            <a asp-controller="InventoryItems"
                                               asp-action="Details"
                                               asp-route-id="@row.ItemId"
                                               class="text-decoration-none">
                                                @row.ItemName
                                            </a>
                                        </div>
                                        <div class="text-muted small">SKU: <span class="fw-semibold">@row.SKU</span></div>
                                    </td>
                                    <td class="text-muted">@row.CategoryName</td>
                                    <td class="text-muted">@row.PrimaryLocationName</td>
                                    <td class="text-end"><span class="it-qty">@row.TotalQuantityOnHand</span></td>
                                    <td class="text-end">@row.ReorderLevel</td>
                                    <td class="text-end">@row.LocationCount</td>
                                    <td>
                                        @if (row.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success border it-badge">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary border it-badge">Inactive</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 p-3 border-top">
                    <div class="text-muted small">
                        Page @Model.PageIndex of @Model.TotalPages
                    </div>

                    <nav aria-label="Low stock pagination">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link"
                                   asp-action="LowStock"
                                   asp-route-page="@(Model.PageIndex - 1)"
                                   asp-route-q="@currentFilter"
                                   asp-route-pageSize="@currentPageSize">Previous</a>
                            </li>

                            @if (firstPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link"
                                       asp-action="LowStock"
                                       asp-route-page="1"
                                       asp-route-q="@currentFilter"
                                       asp-route-pageSize="@currentPageSize">1</a>
                                </li>

                                @if (firstPage > 2)
                                {
                                    <li class="page-item disabled"><span class="page-link">...</span></li>
                                }
                            }

                            @for (var p = firstPage; p <= lastPage; p++)
                            {
                                <li class="page-item @(p == Model.PageIndex ? "active" : "")">
                                    <a class="page-link"
                                       asp-action="LowStock"
                                       asp-route-page="@p"
                                       asp-route-q="@currentFilter"
                                       asp-route-pageSize="@currentPageSize">@p</a>
                                </li>
                            }

                            @if (lastPage < Model.TotalPages)
                            {
                                @if (lastPage < Model.TotalPages - 1)
                                {
                                    <li class="page-item disabled"><span class="page-link">...</span></li>
                                }

                                <li class="page-item">
                                    <a class="page-link"
                                       asp-action="LowStock"
                                       asp-route-page="@Model.TotalPages"
                                       asp-route-q="@currentFilter"
                                       asp-route-pageSize="@currentPageSize">@Model.TotalPages</a>
                                </li>
                            }

                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link"
                                   asp-action="LowStock"
                                   asp-route-page="@(Model.PageIndex + 1)"
                                   asp-route-q="@currentFilter"
                                   asp-route-pageSize="@currentPageSize">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const pageSize = document.getElementById('pageSize');
            const pageNumber = document.getElementById('pageNumber');

            if (pageSize) {
                pageSize.addEventListener('change', function () {
                    if (pageNumber) pageNumber.value = 1;
                    this.form.submit();
                });
            }
        })();
    </script>
}
