@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="it-subpage">
    <section class="it-subhero">
        <div class="it-subhero__content">
            <div class="it-subhero__kicker">System Status</div>
            <h1 class="it-subhero__title">Something went wrong</h1>
            <p class="it-subhero__text">
                The request could not be completed. You can return to the dashboard or use the request details below while debugging locally.
            </p>
        </div>

        <div class="it-subhero__actions">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Back to Dashboard</a>
            <a asp-controller="Home" asp-action="Privacy" class="btn btn-outline-secondary">Open Privacy</a>
        </div>
    </section>

    <div class="it-subgrid">
        <section class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">Request details</div>
                <div class="text-muted small">Useful information for local troubleshooting.</div>
            </div>

            <div class="it-panel-body">
                <div class="it-tip-list">
                    <div class="it-tip-card">
                        <div class="it-tip-card__title">Status</div>
                        <div class="it-tip-card__text">An unexpected error occurred while processing the current request.</div>
                    </div>

                    @if (Model.ShowRequestId)
                    {
                        <div class="it-tip-card">
                            <div class="it-tip-card__title">Request ID</div>
                            <div class="it-tip-card__text"><code>@Model.RequestId</code></div>
                        </div>
                    }
                </div>
            </div>
        </section>

        <aside class="it-substack">
            <section class="it-panel">
                <div class="it-panel-header">
                    <div class="fw-bold">Development mode</div>
                    <div class="text-muted small">When to enable detailed exception output.</div>
                </div>

                <div class="it-panel-body">
                    <div class="it-tip-list">
                        <div class="it-tip-card">
                            <div class="it-tip-card__title">Use only for local debugging</div>
                            <div class="it-tip-card__text">
                                Switching to <strong>Development</strong> shows full exception details, which is helpful locally but not appropriate for deployed environments.
                            </div>
                        </div>

                        <div class="it-tip-card">
                            <div class="it-tip-card__title">Environment variable</div>
                            <div class="it-tip-card__text">
                                Set <code>ASPNETCORE_ENVIRONMENT</code> to <strong>Development</strong> and restart the app when you need full diagnostics during local troubleshooting.
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </aside>
    </div>
</div>
