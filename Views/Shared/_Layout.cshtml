@using Microsoft.AspNetCore.Identity
@using InvenTrack.Models
@inject SignInManager<ApplicationUser> SignInManager

@{
    var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
    bool IsActive(string c) => controller == (c ?? "").ToLowerInvariant();

    bool signedIn = SignInManager.IsSignedIn(User);

    bool isAdmin = User.IsInRole(AppRoles.Admin);
    bool isRegionalManager = User.IsInRole(AppRoles.RegionalManager);
    bool isManager = User.IsInRole(AppRoles.Manager);
    bool isSupervisor = User.IsInRole(AppRoles.Supervisor);
    bool isEmployee = User.IsInRole(AppRoles.Employee);

    bool canCreateEditInventory = isAdmin || isRegionalManager || isManager || isSupervisor;
    bool canUseTransferRequests = isAdmin || isRegionalManager || isManager || isSupervisor || isEmployee;
    bool canSeeUserAdmin = isAdmin;
    bool canSeeReports = signedIn;
    bool canUseChat = signedIn;
    bool canUseOrders = signedIn;

    string roleLabel =
        isAdmin ? "Admin" :
        isRegionalManager ? "Regional Manager" :
        isManager ? "Manager" :
        isSupervisor ? "Supervisor" :
        isEmployee ? "Employee" : "User";

    var assignedLocationName = User.FindFirst("AssignedLocationName")?.Value ?? "";
    var displayName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "User";
    var titleName = User.FindFirst("JobTitle")?.Value ?? "";
    var isScopedUser = isManager || isSupervisor || isEmployee;
    var scopeLabel = isScopedUser
        ? (string.IsNullOrWhiteSpace(assignedLocationName) ? "Assigned location" : assignedLocationName)
        : "All locations";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InvenTrack</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InvenTrack.styles.css" asp-append-version="true" />
</head>

<body class="it-body">
    @if (!signedIn)
    {
        <div class="it-public-shell">
            <header class="it-topbar">
                <div class="container-fluid px-3 px-lg-4 d-flex align-items-center justify-content-between gap-3">
                    <a class="d-flex align-items-center gap-2 text-decoration-none" asp-controller="Home" asp-action="Index">
                        <span class="it-logo">IT</span>
                        <span class="fw-semibold text-dark">InvenTrack</span>
                    </a>

                    <div class="d-flex flex-wrap gap-2 justify-content-end">
                        <a class="btn btn-sm btn-outline-primary" asp-area="Identity" asp-page="/Account/Login">Login</a>
                    </div>
                </div>
            </header>

            <main role="main" class="it-content">
                <div class="container-fluid px-3 px-lg-4 py-4">
                    @RenderBody()
                </div>
            </main>

            <footer class="it-footer mt-auto">
                <div class="container-fluid px-3 px-lg-4 py-3 d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                    <div class="text-muted small text-center text-md-start">
                        &copy; 2026 <span class="fw-semibold">InvenTrack</span> - Inventory Management Platform
                    </div>
                    <div class="small">
                        <a class="text-decoration-none" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </div>
                </div>
            </footer>
        </div>
    }
    else
    {
        <div class="it-auth-shell">
            <header class="it-topbar d-lg-none">
                <div class="container-fluid px-3 d-flex align-items-center justify-content-between gap-2">
                    <button class="btn btn-outline-secondary it-icon-btn" type="button"
                            data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas" aria-controls="sidebarOffcanvas">
                        ☰
                    </button>

                    <a class="d-flex align-items-center gap-2 text-decoration-none flex-grow-1 justify-content-center justify-content-sm-start"
                       asp-controller="Home" asp-action="Index">
                        <span class="it-logo">IT</span>
                        <span class="fw-semibold text-dark">InvenTrack</span>
                    </a>

                    <div class="d-flex align-items-center gap-2">
                        @if (canUseChat)
                        {
                            <a id="topChatButtonMobile"
                               class="btn btn-outline-secondary it-icon-btn position-relative"
                               asp-controller="Chats"
                               asp-action="Index"
                               title="Chat notifications">
                                💬
                                <span id="chatBadgeTopMobile"
                                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary d-none">0</span>
                            </a>
                        }
                        @if (canUseTransferRequests)
                        {
                            <a id="topTransferButtonMobile"
                               class="btn btn-outline-secondary it-icon-btn position-relative"
                               asp-controller="StockTransferRequests"
                               asp-action="Index"
                               title="Transfer request notifications">
                                🔔
                                <span id="transferRequestsBadgeTopMobile"
                                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                            </a>
                        }
                        @if (canUseOrders)
                        {
                            <a id="topOrderButtonMobile"
                               class="btn btn-outline-secondary it-icon-btn position-relative"
                               asp-controller="OrderRequests"
                               asp-action="Index"
                               title="Restock order notifications">
                                🛒
                                <span id="orderRequestsBadgeTopMobile"
                                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark d-none">0</span>
                            </a>
                        }
                        @if (!canUseChat && !canUseTransferRequests && !canUseOrders)
                        {
                            <div style="width:40px;"></div>
                        }
                    </div>
                </div>
            </header>

            <div class="it-shell">
                <aside class="it-sidebar d-none d-lg-flex">
                    <div class="it-sidebar-inner">
                        <a class="d-flex align-items-center gap-2 text-decoration-none mb-4" asp-controller="Home" asp-action="Index">
                            <span class="it-logo">IT</span>
                            <div>
                                <div class="fw-bold text-dark">InvenTrack</div>
                                <div class="text-muted small">Inventory dashboard</div>
                                <div class="text-muted small mt-1">
                                    <span class="badge bg-light text-dark border it-badge">@roleLabel</span>
                                    <span class="badge bg-primary-subtle text-primary border it-badge ms-1">@scopeLabel</span>
                                </div>
                            </div>
                        </a>

                        <nav class="it-nav">
                            <a class="it-nav-link @(IsActive("Home") ? "active" : "")" asp-controller="Home" asp-action="Index">
                                <span class="it-nav-ico">🏠</span> Home
                            </a>

                            <a class="it-nav-link @(IsActive("InventoryItems") ? "active" : "")" asp-controller="InventoryItems" asp-action="Index">
                                <span class="it-nav-ico">📦</span> Inventory
                            </a>

                            <a class="it-nav-link @(IsActive("StockTransactions") ? "active" : "")" asp-controller="StockTransactions" asp-action="Index">
                                <span class="it-nav-ico">🧾</span> Transactions
                            </a>

                            @if (canUseTransferRequests)
                            {
                                <a class="it-nav-link @(IsActive("StockTransferRequests") ? "active" : "") d-flex justify-content-between align-items-center" asp-controller="StockTransferRequests" asp-action="Index">
                                    <span class="d-inline-flex align-items-center gap-2"><span class="it-nav-ico">🔁</span> Transfer Requests</span>
                                    <span id="transferRequestsBadgeDesktop" class="badge bg-danger-subtle text-danger border it-badge d-none">0</span>
                                </a>
                            }

                            @if (canUseOrders)
                            {
                                <a class="it-nav-link @(IsActive("OrderRequests") ? "active" : "") d-flex justify-content-between align-items-center" asp-controller="OrderRequests" asp-action="Index">
                                    <span class="d-inline-flex align-items-center gap-2"><span class="it-nav-ico">🛒</span> Restock Orders</span>
                                    <span id="orderRequestsBadgeDesktop" class="badge bg-warning-subtle text-warning-emphasis border it-badge d-none">0</span>
                                </a>
                            }

                            @if (canSeeReports)
                            {
                                <a class="it-nav-link @(IsActive("Reports") ? "active" : "")" asp-controller="Reports" asp-action="Index">
                                    <span class="it-nav-ico">📊</span> Reports
                                </a>
                            }

                            <a class="it-nav-link @(IsActive("Categories") ? "active" : "")" asp-controller="Categories" asp-action="Index">
                                <span class="it-nav-ico">🗂️</span> Categories
                            </a>

                            <a class="it-nav-link @(IsActive("StorageLocations") ? "active" : "")" asp-controller="StorageLocations" asp-action="Index">
                                <span class="it-nav-ico">📍</span> Locations
                            </a>

                            @if (canSeeUserAdmin)
                            {
                                <div class="it-nav-divider"></div>
                                <a class="it-nav-link @(IsActive("AdminUsers") ? "active" : "")" asp-controller="AdminUsers" asp-action="Index">
                                    <span class="it-nav-ico">🛡️</span> User Admin
                                </a>
                            }

                            <div class="it-nav-divider"></div>

                            <a class="it-nav-link" asp-controller="Home" asp-action="Privacy">
                                <span class="it-nav-ico">🔒</span> Privacy
                            </a>

                            <div class="it-nav-divider"></div>

                            <partial name="_LoginPartial" />
                        </nav>

                        <div class="it-sidebar-footer mt-auto">
                            <div class="small text-muted">
                                Tip: scoped users only see data for their assigned location.
                            </div>
                        </div>
                    </div>
                </aside>

                <div class="it-main">
                    <header class="it-topbar d-none d-lg-flex">
                        <div class="container-fluid px-4 d-flex align-items-center justify-content-between gap-3">
                            <div class="d-flex align-items-center gap-2 min-w-0">
                                <div class="it-page-dot"></div>
                                <div class="fw-semibold text-truncate">@ViewData["Title"]</div>
                            </div>

                            <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                                <span class="badge bg-light text-dark border it-badge">
                                    @displayName@if (!string.IsNullOrWhiteSpace(titleName)) { <text> • @titleName</text> } • @scopeLabel
                                </span>

                                @if (canUseChat)
                                {
                                    <a id="topChatButtonDesktop"
                                       class="btn btn-sm btn-outline-secondary position-relative"
                                       asp-controller="Chats"
                                       asp-action="Index"
                                       title="Chat notifications">
                                        <span class="me-1">💬</span>
                                        <span class="d-none d-md-inline">Chat</span>
                                        <span id="chatBadgeTopDesktop"
                                              class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary d-none">0</span>
                                    </a>
                                }

                                @if (canUseTransferRequests)
                                {
                                    <a id="topTransferButtonDesktop" class="btn btn-sm btn-outline-secondary position-relative" asp-controller="StockTransferRequests" asp-action="Index" title="Transfer request notifications">
                                        <span class="me-1">🔔</span><span class="d-none d-md-inline">Transfers</span><span id="transferRequestsBadgeTopDesktop" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                                    </a>
                                }

                                @if (canUseOrders)
                                {
                                    <a id="topOrderButtonDesktop" class="btn btn-sm btn-outline-secondary position-relative" asp-controller="OrderRequests" asp-action="Index" title="Restock order notifications">
                                        <span class="me-1">🛒</span><span class="d-none d-md-inline">Orders</span><span id="orderRequestsBadgeTopDesktop" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark d-none">0</span>
                                    </a>
                                }

                                @if (canCreateEditInventory)
                                {
                                    <a class="btn btn-sm btn-primary" asp-controller="InventoryItems" asp-action="Create">+ Add Item</a>
                                }
                            </div>
                        </div>
                    </header>

                    <main role="main" class="it-content">
                        <div class="container-fluid px-3 px-lg-4 py-4">
                            @RenderBody()
                        </div>
                    </main>

                    <footer class="it-footer mt-auto">
                        <div class="container-fluid px-3 px-lg-4 py-3 d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                            <div class="text-muted small text-center text-md-start">
                                &copy; 2026 <span class="fw-semibold">InvenTrack</span> - Inventory Management Platform
                            </div>
                            <div class="small">
                                <a class="text-decoration-none" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            </div>
                        </div>
                    </footer>
                </div>
            </div>
        </div>

        <div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarOffcanvas" aria-labelledby="sidebarOffcanvasLabel">
            <div class="offcanvas-header">
                <div class="d-flex align-items-center gap-2">
                    <span class="it-logo">IT</span>
                    <div>
                        <div class="fw-bold" id="sidebarOffcanvasLabel">InvenTrack</div>
                        <div class="text-muted small">Inventory dashboard</div>
                        <div class="text-muted small mt-1">
                            <span class="badge bg-light text-dark border it-badge">@roleLabel</span>
                            <span class="badge bg-primary-subtle text-primary border it-badge ms-1">@scopeLabel</span>
                        </div>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>

            <div class="offcanvas-body d-flex flex-column">
                <nav class="it-nav">
                    <a class="it-nav-link @(IsActive("Home") ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <span class="it-nav-ico">🏠</span> Home
                    </a>

                    <a class="it-nav-link @(IsActive("InventoryItems") ? "active" : "")" asp-controller="InventoryItems" asp-action="Index">
                        <span class="it-nav-ico">📦</span> Inventory
                    </a>

                    <a class="it-nav-link @(IsActive("StockTransactions") ? "active" : "")" asp-controller="StockTransactions" asp-action="Index">
                        <span class="it-nav-ico">🧾</span> Transactions
                    </a>

                    @if (canUseTransferRequests)
                    {
                        <a class="it-nav-link @(IsActive("StockTransferRequests") ? "active" : "") d-flex justify-content-between align-items-center" asp-controller="StockTransferRequests" asp-action="Index">
                            <span class="d-inline-flex align-items-center gap-2"><span class="it-nav-ico">🔁</span> Transfer Requests</span>
                            <span id="transferRequestsBadgeMobile" class="badge bg-danger-subtle text-danger border it-badge d-none">0</span>
                        </a>
                    }

                    @if (canUseOrders)
                    {
                        <a class="it-nav-link @(IsActive("OrderRequests") ? "active" : "") d-flex justify-content-between align-items-center" asp-controller="OrderRequests" asp-action="Index">
                            <span class="d-inline-flex align-items-center gap-2"><span class="it-nav-ico">🛒</span> Restock Orders</span>
                            <span id="orderRequestsBadgeMobile" class="badge bg-warning-subtle text-warning-emphasis border it-badge d-none">0</span>
                        </a>
                    }

                    @if (canSeeReports)
                    {
                        <a class="it-nav-link @(IsActive("Reports") ? "active" : "")" asp-controller="Reports" asp-action="Index">
                            <span class="it-nav-ico">📊</span> Reports
                        </a>
                    }

                    <a class="it-nav-link @(IsActive("Categories") ? "active" : "")" asp-controller="Categories" asp-action="Index">
                        <span class="it-nav-ico">🗂️</span> Categories
                    </a>

                    <a class="it-nav-link @(IsActive("StorageLocations") ? "active" : "")" asp-controller="StorageLocations" asp-action="Index">
                        <span class="it-nav-ico">📍</span> Locations
                    </a>

                    @if (canSeeUserAdmin)
                    {
                        <div class="it-nav-divider"></div>
                        <a class="it-nav-link @(IsActive("AdminUsers") ? "active" : "")" asp-controller="AdminUsers" asp-action="Index">
                            <span class="it-nav-ico">🛡️</span> User Admin
                        </a>
                    }

                    <div class="it-nav-divider"></div>

                    <a class="it-nav-link" asp-controller="Home" asp-action="Privacy">
                        <span class="it-nav-ico">🔒</span> Privacy
                    </a>

                    <div class="it-nav-divider"></div>

                    <partial name="_LoginPartial" />
                </nav>
            </div>
        </div>

        <div class="position-fixed top-0 end-0 p-3" style="z-index: 1085;">
            <div id="appToastContainer" class="d-flex flex-column gap-2"></div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (signedIn)
    {
        <script>
            (function () {
                const orderBadgeIds = ['orderRequestsBadgeDesktop','orderRequestsBadgeMobile','orderRequestsBadgeTopDesktop','orderRequestsBadgeTopMobile'];

                const transferBadgeIds = [
                    'transferRequestsBadgeDesktop',
                    'transferRequestsBadgeMobile',
                    'transferRequestsBadgeTopDesktop',
                    'transferRequestsBadgeTopMobile'
                ];

                const chatBadgeIds = [
                    'chatBadgeDesktop',
                    'chatBadgeMobile',
                    'chatBadgeTopDesktop',
                    'chatBadgeTopMobile'
                ];

                function escapeHtml(text) {
                    return (text || '')
                        .replaceAll('&', '&amp;')
                        .replaceAll('<', '&lt;')
                        .replaceAll('>', '&gt;')
                        .replaceAll('"', '&quot;')
                        .replaceAll("'", '&#039;');
                }

                function setBadgeCount(ids, count) {
                    ids.forEach(id => {
                        const el = document.getElementById(id);
                        if (!el) return;

                        if (count > 0) {
                            el.textContent = count > 99 ? '99+' : count;
                            el.classList.remove('d-none');
                        } else {
                            el.textContent = '0';
                            el.classList.add('d-none');
                        }
                    });
                }

                function showToast(title, message) {
                    const container = document.getElementById('appToastContainer');
                    if (!container || !message) return;

                    const wrapper = document.createElement('div');
                    wrapper.className = 'toast';
                    wrapper.setAttribute('role', 'alert');
                    wrapper.setAttribute('aria-live', 'assertive');
                    wrapper.setAttribute('aria-atomic', 'true');

                    wrapper.innerHTML = `
                        <div class="toast-header">
                            <strong class="me-auto">${escapeHtml(title)}</strong>
                            <small>just now</small>
                            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                        <div class="toast-body">${escapeHtml(message)}</div>`;

                    container.appendChild(wrapper);

                    const toast = new bootstrap.Toast(wrapper, { delay: 5000 });
                    toast.show();
                    wrapper.addEventListener('hidden.bs.toast', function () { wrapper.remove(); });
                }

                function playNotificationBeep() {
                    try {
                        const AudioCtx = window.AudioContext || window.webkitAudioContext;
                        if (!AudioCtx) return;
                        const ctx = new AudioCtx();
                        const oscillator = ctx.createOscillator();
                        const gain = ctx.createGain();
                        oscillator.connect(gain);
                        gain.connect(ctx.destination);
                        oscillator.type = 'sine';
                        oscillator.frequency.setValueAtTime(880, ctx.currentTime);
                        gain.gain.setValueAtTime(0.0001, ctx.currentTime);
                        gain.gain.exponentialRampToValueAtTime(0.08, ctx.currentTime + 0.01);
                        gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.30);
                        oscillator.start(ctx.currentTime);
                        oscillator.stop(ctx.currentTime + 0.30);
                    } catch {
                    }
                }

                function showBrowserNotification(title, body, url) {
                    try {
                        if (!('Notification' in window)) return;
                        if (Notification.permission === 'default') {
                            Notification.requestPermission();
                            return;
                        }
                        if (Notification.permission !== 'granted') return;

                        const notification = new Notification(title, { body });
                        if (url) {
                            notification.onclick = function () {
                                window.location.href = url;
                                window.focus();
                            };
                        }
                    } catch {
                    }
                }

                async function refreshTransferBadge() {
                    if (!@canUseTransferRequests.ToString().ToLowerInvariant()) return;
                    try {
                        const response = await fetch('/StockTransferRequests/BadgeCount', {
                            method: 'GET',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });

                        if (!response.ok) return;

                        const data = await response.json();
                        setBadgeCount(transferBadgeIds, data.count || 0);
                    } catch {
                    }
                }

                async function refreshOrderBadge() {
                    if (!@canUseOrders.ToString().ToLowerInvariant()) return;
                    try {
                        const response = await fetch('/OrderRequests/BadgeCount', { method: 'GET', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                        if (!response.ok) return;
                        const data = await response.json();
                        setBadgeCount(orderBadgeIds, data.count || 0);
                    } catch { }
                }

                async function refreshChatBadge() {
                    if (!@canUseChat.ToString().ToLowerInvariant()) return;
                    try {
                        const response = await fetch('/Chats/NotificationSummary', {
                            method: 'GET',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                        if (!response.ok) return;
                        const data = await response.json();
                        setBadgeCount(chatBadgeIds, data.unreadMessageCount || 0);
                    } catch {
                    }
                }

                async function markActiveConversationRead() {
                    const activeConversationId = window.invenTrackChat?.activeConversationId;
                    if (!activeConversationId) return;

                    try {
                        await fetch(`/Chats/MarkRead?conversationId=${activeConversationId}`, {
                            method: 'POST',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });
                    } catch {
                    }
                }

                window.invenTrackChat = window.invenTrackChat || {
                    activeConversationId: null,
                    connection: null,
                    registerActiveConversation: async function (conversationId) {
                        this.activeConversationId = conversationId;
                        await markActiveConversationRead();
                        await refreshChatBadge();
                        if (this.connection && this.connection.state === 'Connected') {
                            try {
                                await this.connection.invoke('JoinConversationGroup', String(conversationId));
                            } catch {
                            }
                        }
                    }
                };

                async function startNotifications() {
                    await refreshTransferBadge();
                    await refreshOrderBadge();
                    await refreshChatBadge();

                    if (typeof signalR === 'undefined') return;

                    const chatConnection = new signalR.HubConnectionBuilder()
                        .withUrl('/hubs/chat')
                        .withAutomaticReconnect()
                        .build();

                    window.invenTrackChat.connection = chatConnection;

                    chatConnection.on('ReceiveMessage', async function (payload) {
                        document.dispatchEvent(new CustomEvent('inventrack:chat-message', { detail: payload }));

                        const activeConversationId = window.invenTrackChat?.activeConversationId;
                        const isOpenConversation = activeConversationId && Number(activeConversationId) === Number(payload?.conversationId);

                        if (isOpenConversation) {
                            await markActiveConversationRead();
                        } else if (payload && !payload.isSystemMessage) {
                            showToast(payload.senderDisplayName || 'Chat', payload.body || 'New message received.');
                            playNotificationBeep();
                            showBrowserNotification(
                                payload.senderDisplayName || 'New message',
                                payload.body || 'Open chat to read the message.',
                                `/Chats?id=${payload.conversationId}`
                            );
                        }

                        await refreshChatBadge();
                    });

                    chatConnection.on('ChatNotification', async function (payload) {
                        const activeConversationId = window.invenTrackChat?.activeConversationId;
                        const isOpenConversation = activeConversationId && Number(activeConversationId) === Number(payload?.conversationId);
                        if (!isOpenConversation) {
                            showToast(payload.conversationName || 'Chat', payload.preview || 'Chat updated.');
                            playNotificationBeep();
                            showBrowserNotification(
                                payload.conversationName || 'Chat notification',
                                payload.preview || 'Open chat for details.',
                                `/Chats?id=${payload.conversationId}`
                            );
                        }
                        await refreshChatBadge();
                    });

                    chatConnection.on('ConversationMembersChanged', async function (payload) {
                        document.dispatchEvent(new CustomEvent('inventrack:chat-members-changed', { detail: payload }));
                        await refreshChatBadge();
                    });

                    chatConnection.onreconnected(async function () {
                        await refreshTransferBadge();
                        await refreshOrderBadge();
                        await refreshChatBadge();
                        if (window.invenTrackChat?.activeConversationId) {
                            try {
                                await chatConnection.invoke('JoinConversationGroup', String(window.invenTrackChat.activeConversationId));
                            } catch {
                            }
                        }
                    });

                    try {
                        await chatConnection.start();
                        if (window.invenTrackChat?.activeConversationId) {
                            await chatConnection.invoke('JoinConversationGroup', String(window.invenTrackChat.activeConversationId));
                        }
                    } catch {
                    }

                    if (@canUseOrders.ToString().ToLowerInvariant()) {
                        const orderConnection = new signalR.HubConnectionBuilder().withUrl('/hubs/order-requests').withAutomaticReconnect().build();
                        orderConnection.on('OrderRequestsChanged', function (payload) { refreshOrderBadge(); if (payload && payload.message) { showToast('Restock Orders', payload.message); } });
                        orderConnection.onreconnected(function () { refreshOrderBadge(); });
                        try { await orderConnection.start(); } catch { }
                    }

                    if (@canUseTransferRequests.ToString().ToLowerInvariant()) {
                        const transferConnection = new signalR.HubConnectionBuilder()
                            .withUrl('/hubs/transfer-requests')
                            .withAutomaticReconnect()
                            .build();

                        transferConnection.on('TransferRequestsChanged', function (payload) {
                            refreshTransferBadge();
                            if (payload && payload.message) {
                                showToast('Transfer Requests', payload.message);
                            }
                        });

                        transferConnection.onreconnected(function () {
                            refreshTransferBadge();
                        });

                        try {
                            await transferConnection.start();
                        } catch {
                        }
                    }
                }

                startNotifications();
            })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


