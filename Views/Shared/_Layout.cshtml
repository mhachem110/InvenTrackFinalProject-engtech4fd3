@using Microsoft.AspNetCore.Identity
@using InvenTrack.Models
@inject SignInManager<ApplicationUser> SignInManager

@{
    var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
    bool IsActive(string c) => controller == (c ?? "").ToLowerInvariant();

    bool signedIn = SignInManager.IsSignedIn(User);

    bool isAdmin = User.IsInRole(AppRoles.Admin);
    bool isRegionalManager = User.IsInRole(AppRoles.RegionalManager);
    bool isManager = User.IsInRole(AppRoles.Manager);
    bool isSupervisor = User.IsInRole(AppRoles.Supervisor);
    bool isEmployee = User.IsInRole(AppRoles.Employee);

    bool canCreateEditInventory = isAdmin || isRegionalManager || isManager || isSupervisor;
    bool canUseTransferRequests = isAdmin || isRegionalManager || isManager || isSupervisor || isEmployee;
    bool canSeeUserAdmin = isAdmin;
    bool canSeeReports = signedIn;

    string roleLabel =
        isAdmin ? "Admin" :
        isRegionalManager ? "Regional Manager" :
        isManager ? "Manager" :
        isSupervisor ? "Supervisor" :
        isEmployee ? "Employee" : "User";

    var assignedLocationName = User.FindFirst("AssignedLocationName")?.Value ?? "";
    var isScopedUser = isManager || isSupervisor || isEmployee;
    var scopeLabel = isScopedUser
        ? (string.IsNullOrWhiteSpace(assignedLocationName) ? "Assigned location" : assignedLocationName)
        : "All locations";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InvenTrack</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InvenTrack.styles.css" asp-append-version="true" />
</head>

<body class="it-body">
    @if (!signedIn)
    {
        <div class="it-public-shell">
            <header class="it-topbar">
                <div class="container-fluid px-3 px-lg-4 d-flex align-items-center justify-content-between gap-3">
                    <a class="d-flex align-items-center gap-2 text-decoration-none" asp-controller="Home" asp-action="Index">
                        <span class="it-logo">IT</span>
                        <span class="fw-semibold text-dark">InvenTrack</span>
                    </a>

                    <div class="d-flex flex-wrap gap-2 justify-content-end">
                        <a class="btn btn-sm btn-outline-primary" asp-area="Identity" asp-page="/Account/Login">Login</a>
                    </div>
                </div>
            </header>

            <main role="main" class="it-content">
                <div class="container-fluid px-3 px-lg-4 py-4">
                    @RenderBody()
                </div>
            </main>

            <footer class="it-footer mt-auto">
                <div class="container-fluid px-3 px-lg-4 py-3 d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                    <div class="text-muted small text-center text-md-start">
                        &copy; 2026 <span class="fw-semibold">InvenTrack</span> - Inventory Management Platform
                    </div>
                    <div class="small">
                        <a class="text-decoration-none" asp-controller="Home" asp-action="Privacy">Privacy</a>
                    </div>
                </div>
            </footer>
        </div>
    }
    else
    {
        <div class="it-auth-shell">
            <header class="it-topbar d-lg-none">
                <div class="container-fluid px-3 d-flex align-items-center justify-content-between gap-2">
                    <button class="btn btn-outline-secondary it-icon-btn" type="button"
                            data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas" aria-controls="sidebarOffcanvas">
                        ☰
                    </button>

                    <a class="d-flex align-items-center gap-2 text-decoration-none flex-grow-1 justify-content-center justify-content-sm-start"
                       asp-controller="Home" asp-action="Index">
                        <span class="it-logo">IT</span>
                        <span class="fw-semibold text-dark">InvenTrack</span>
                    </a>

                    @if (canUseTransferRequests)
                    {
                        <a id="topTransferButtonMobile"
                           class="btn btn-outline-secondary it-icon-btn position-relative"
                           asp-controller="StockTransferRequests"
                           asp-action="Index"
                           title="Transfer request notifications">
                            🔔
                            <span id="transferRequestsBadgeTopMobile"
                                  class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">
                                0
                            </span>
                        </a>
                    }
                    else
                    {
                        <div style="width:40px;"></div>
                    }
                </div>
            </header>

            <div class="it-shell">
                <aside class="it-sidebar d-none d-lg-flex">
                    <div class="it-sidebar-inner">
                        <a class="d-flex align-items-center gap-2 text-decoration-none mb-4" asp-controller="Home" asp-action="Index">
                            <span class="it-logo">IT</span>
                            <div>
                                <div class="fw-bold text-dark">InvenTrack</div>
                                <div class="text-muted small">Inventory dashboard</div>
                                <div class="text-muted small mt-1">
                                    <span class="badge bg-light text-dark border it-badge">@roleLabel</span>
                                    <span class="badge bg-primary-subtle text-primary border it-badge ms-1">@scopeLabel</span>
                                </div>
                            </div>
                        </a>

                        <nav class="it-nav">
                            <a class="it-nav-link @(IsActive("Home") ? "active" : "")" asp-controller="Home" asp-action="Index">
                                <span class="it-nav-ico">🏠</span> Home
                            </a>

                            <a class="it-nav-link @(IsActive("InventoryItems") ? "active" : "")" asp-controller="InventoryItems" asp-action="Index">
                                <span class="it-nav-ico">📦</span> Inventory
                            </a>

                            <a class="it-nav-link @(IsActive("StockTransactions") ? "active" : "")" asp-controller="StockTransactions" asp-action="Index">
                                <span class="it-nav-ico">🧾</span> Transactions
                            </a>

                            @if (canUseTransferRequests)
                            {
                                <a class="it-nav-link @(IsActive("StockTransferRequests") ? "active" : "") d-flex justify-content-between align-items-center"
                                   asp-controller="StockTransferRequests"
                                   asp-action="Index">
                                    <span class="d-inline-flex align-items-center gap-2">
                                        <span class="it-nav-ico">🔁</span> Transfer Requests
                                    </span>
                                    <span id="transferRequestsBadgeDesktop"
                                          class="badge bg-danger-subtle text-danger border it-badge d-none">
                                        0
                                    </span>
                                </a>
                            }

                            @if (canSeeReports)
                            {
                                <a class="it-nav-link @(IsActive("Reports") ? "active" : "")" asp-controller="Reports" asp-action="Index">
                                    <span class="it-nav-ico">📊</span> Reports
                                </a>
                            }

                            <a class="it-nav-link @(IsActive("Categories") ? "active" : "")" asp-controller="Categories" asp-action="Index">
                                <span class="it-nav-ico">🗂️</span> Categories
                            </a>

                            <a class="it-nav-link @(IsActive("StorageLocations") ? "active" : "")" asp-controller="StorageLocations" asp-action="Index">
                                <span class="it-nav-ico">📍</span> Locations
                            </a>

                            @if (canSeeUserAdmin)
                            {
                                <div class="it-nav-divider"></div>
                                <a class="it-nav-link @(IsActive("AdminUsers") ? "active" : "")" asp-controller="AdminUsers" asp-action="Index">
                                    <span class="it-nav-ico">🛡️</span> User Admin
                                </a>
                            }

                            <div class="it-nav-divider"></div>

                            <a class="it-nav-link" asp-controller="Home" asp-action="Privacy">
                                <span class="it-nav-ico">🔒</span> Privacy
                            </a>

                            <div class="it-nav-divider"></div>

                            <partial name="_LoginPartial" />
                        </nav>

                        <div class="it-sidebar-footer mt-auto">
                            <div class="small text-muted">
                                Tip: scoped users only see data for their assigned location.
                            </div>
                        </div>
                    </div>
                </aside>

                <div class="it-main">
                    <header class="it-topbar d-none d-lg-flex">
                        <div class="container-fluid px-4 d-flex align-items-center justify-content-between gap-3">
                            <div class="d-flex align-items-center gap-2 min-w-0">
                                <div class="it-page-dot"></div>
                                <div class="fw-semibold text-truncate">@ViewData["Title"]</div>
                            </div>

                            <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                                <span class="badge bg-light text-dark border it-badge">
                                    @roleLabel • @scopeLabel
                                </span>

                                @if (canUseTransferRequests)
                                {
                                    <a id="topTransferButtonDesktop"
                                       class="btn btn-sm btn-outline-secondary position-relative"
                                       asp-controller="StockTransferRequests"
                                       asp-action="Index"
                                       title="Transfer request notifications">
                                        <span class="me-1">🔔</span>
                                        <span class="d-none d-md-inline">Notifications</span>
                                        <span id="transferRequestsBadgeTopDesktop"
                                              class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">
                                            0
                                        </span>
                                    </a>
                                }

                                @if (canCreateEditInventory)
                                {
                                    <a class="btn btn-sm btn-primary" asp-controller="InventoryItems" asp-action="Create">+ Add Item</a>
                                }
                            </div>
                        </div>
                    </header>

                    <main role="main" class="it-content">
                        <div class="container-fluid px-3 px-lg-4 py-4">
                            @RenderBody()
                        </div>
                    </main>

                    <footer class="it-footer mt-auto">
                        <div class="container-fluid px-3 px-lg-4 py-3 d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
                            <div class="text-muted small text-center text-md-start">
                                &copy; 2026 <span class="fw-semibold">InvenTrack</span> - Inventory Management Platform
                            </div>
                            <div class="small">
                                <a class="text-decoration-none" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            </div>
                        </div>
                    </footer>
                </div>
            </div>
        </div>

        <div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarOffcanvas" aria-labelledby="sidebarOffcanvasLabel">
            <div class="offcanvas-header">
                <div class="d-flex align-items-center gap-2">
                    <span class="it-logo">IT</span>
                    <div>
                        <div class="fw-bold" id="sidebarOffcanvasLabel">InvenTrack</div>
                        <div class="text-muted small">Inventory dashboard</div>
                        <div class="text-muted small mt-1">
                            <span class="badge bg-light text-dark border it-badge">@roleLabel</span>
                            <span class="badge bg-primary-subtle text-primary border it-badge ms-1">@scopeLabel</span>
                        </div>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>

            <div class="offcanvas-body d-flex flex-column">
                <nav class="it-nav">
                    <a class="it-nav-link @(IsActive("Home") ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <span class="it-nav-ico">🏠</span> Home
                    </a>

                    <a class="it-nav-link @(IsActive("InventoryItems") ? "active" : "")" asp-controller="InventoryItems" asp-action="Index">
                        <span class="it-nav-ico">📦</span> Inventory
                    </a>

                    <a class="it-nav-link @(IsActive("StockTransactions") ? "active" : "")" asp-controller="StockTransactions" asp-action="Index">
                        <span class="it-nav-ico">🧾</span> Transactions
                    </a>

                    @if (canUseTransferRequests)
                    {
                        <a class="it-nav-link @(IsActive("StockTransferRequests") ? "active" : "") d-flex justify-content-between align-items-center"
                           asp-controller="StockTransferRequests"
                           asp-action="Index">
                            <span class="d-inline-flex align-items-center gap-2">
                                <span class="it-nav-ico">🔁</span> Transfer Requests
                            </span>
                            <span id="transferRequestsBadgeMobile"
                                  class="badge bg-danger-subtle text-danger border it-badge d-none">
                                0
                            </span>
                        </a>
                    }

                    @if (canSeeReports)
                    {
                        <a class="it-nav-link @(IsActive("Reports") ? "active" : "")" asp-controller="Reports" asp-action="Index">
                            <span class="it-nav-ico">📊</span> Reports
                        </a>
                    }

                    <a class="it-nav-link @(IsActive("Categories") ? "active" : "")" asp-controller="Categories" asp-action="Index">
                        <span class="it-nav-ico">🗂️</span> Categories
                    </a>

                    <a class="it-nav-link @(IsActive("StorageLocations") ? "active" : "")" asp-controller="StorageLocations" asp-action="Index">
                        <span class="it-nav-ico">📍</span> Locations
                    </a>

                    @if (canSeeUserAdmin)
                    {
                        <div class="it-nav-divider"></div>
                        <a class="it-nav-link @(IsActive("AdminUsers") ? "active" : "")" asp-controller="AdminUsers" asp-action="Index">
                            <span class="it-nav-ico">🛡️</span> User Admin
                        </a>
                    }

                    <div class="it-nav-divider"></div>

                    <a class="it-nav-link" asp-controller="Home" asp-action="Privacy">
                        <span class="it-nav-ico">🔒</span> Privacy
                    </a>

                    <div class="it-nav-divider"></div>

                    <partial name="_LoginPartial" />
                </nav>
            </div>
        </div>

        <div class="position-fixed top-0 end-0 p-3" style="z-index: 1085;">
            <div id="transferToastContainer" class="d-flex flex-column gap-2"></div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (signedIn && canUseTransferRequests)
    {
        <script>
            (function () {
                const badgeIds = [
                    'transferRequestsBadgeDesktop',
                    'transferRequestsBadgeMobile',
                    'transferRequestsBadgeTopDesktop',
                    'transferRequestsBadgeTopMobile'
                ];

                function escapeHtml(text) {
                    return (text || '')
                        .replaceAll('&', '&amp;')
                        .replaceAll('<', '&lt;')
                        .replaceAll('>', '&gt;')
                        .replaceAll('"', '&quot;')
                        .replaceAll("'", '&#039;');
                }

                function setBadgeCount(count) {
                    badgeIds.forEach(id => {
                        const el = document.getElementById(id);
                        if (!el) return;

                        if (count > 0) {
                            el.textContent = count;
                            el.classList.remove('d-none');
                        } else {
                            el.textContent = '0';
                            el.classList.add('d-none');
                        }
                    });
                }

                async function refreshTransferBadge() {
                    try {
                        const response = await fetch('/StockTransferRequests/BadgeCount', {
                            method: 'GET',
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        });

                        if (!response.ok) return;

                        const data = await response.json();
                        setBadgeCount(data.count || 0);
                    } catch {
                    }
                }

                function showTransferToast(message) {
                    const container = document.getElementById('transferToastContainer');
                    if (!container || !message) return;

                    const wrapper = document.createElement('div');
                    wrapper.className = 'toast';
                    wrapper.setAttribute('role', 'alert');
                    wrapper.setAttribute('aria-live', 'assertive');
                    wrapper.setAttribute('aria-atomic', 'true');

                    wrapper.innerHTML = `
                        <div class="toast-header">
                            <strong class="me-auto">Transfer Requests</strong>
                            <small>just now</small>
                            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                        <div class="toast-body">
                            ${escapeHtml(message)}
                        </div>
                    `;

                    container.appendChild(wrapper);

                    const toast = new bootstrap.Toast(wrapper, { delay: 5000 });
                    toast.show();

                    wrapper.addEventListener('hidden.bs.toast', function () {
                        wrapper.remove();
                    });
                }

                async function startTransferNotifications() {
                    await refreshTransferBadge();

                    if (typeof signalR === 'undefined') return;

                    const connection = new signalR.HubConnectionBuilder()
                        .withUrl('/hubs/transfer-requests')
                        .withAutomaticReconnect()
                        .build();

                    connection.on('TransferRequestsChanged', function (payload) {
                        refreshTransferBadge();

                        if (payload && payload.message) {
                            showTransferToast(payload.message);
                        }
                    });

                    connection.onreconnected(function () {
                        refreshTransferBadge();
                    });

                    try {
                        await connection.start();
                    } catch {
                    }
                }

                startTransferNotifications();
            })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


