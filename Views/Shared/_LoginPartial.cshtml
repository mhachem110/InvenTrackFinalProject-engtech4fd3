@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using InvenTrack.Data
@using InvenTrack.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject InvenTrackContext Db

@{
    bool signedIn = SignInManager.IsSignedIn(User);
    string roleLabel =
        User.IsInRole(AppRoles.Admin) ? "Admin" :
        User.IsInRole(AppRoles.RegionalManager) ? "Regional Manager" :
        User.IsInRole(AppRoles.Manager) ? "Manager" :
        User.IsInRole(AppRoles.Supervisor) ? "Supervisor" :
        User.IsInRole(AppRoles.Employee) ? "Employee" : "";

    string assignedLocation = "-";
    string fullName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "User";
    string title = User.FindFirst("JobTitle")?.Value ?? "";
    string department = User.FindFirst("Department")?.Value ?? "";

    if (signedIn)
    {
        var userId = UserManager.GetUserId(User);
        if (!string.IsNullOrWhiteSpace(userId))
        {
            var assignedLocationId = await UserManager.Users
                .AsNoTracking()
                .Where(u => u.Id == userId)
                .Select(u => u.AssignedStorageLocationId)
                .FirstOrDefaultAsync();

            if (User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.RegionalManager))
            {
                assignedLocation = "All Locations";
            }
            else if (assignedLocationId.HasValue)
            {
                assignedLocation = await Db.StorageLocations
                    .AsNoTracking()
                    .Where(l => l.ID == assignedLocationId.Value)
                    .Select(l => l.Name)
                    .FirstOrDefaultAsync() ?? "-";
            }
        }
    }
}

@if (signedIn)
{
    <div class="rounded-4 border bg-body-tertiary p-3 mb-3">
        <div class="fw-semibold text-break">@fullName</div>
        @if (!string.IsNullOrWhiteSpace(title) || !string.IsNullOrWhiteSpace(department))
        {
            <div class="text-muted small mt-1">@title@(string.IsNullOrWhiteSpace(title) || string.IsNullOrWhiteSpace(department) ? "" : " • ")@department</div>
        }
        @if (!string.IsNullOrWhiteSpace(roleLabel))
        {
            <span class="badge bg-primary-subtle text-primary border it-badge mt-2">@roleLabel</span>
        }
        <div class="text-muted small mt-2">Location: @assignedLocation</div>
    </div>

    <a class="it-nav-link" asp-area="Identity" asp-page="/Account/Manage/Index">
        <span class="it-nav-ico">⚙️</span> Account
    </a>

    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="mt-1">
        <button type="submit" class="it-nav-link w-100 text-start" style="border:0;background:transparent;">
            <span class="it-nav-ico">🚪</span> Logout
        </button>
    </form>
}
else
{
    <a class="it-nav-link" asp-area="Identity" asp-page="/Account/Login">
        <span class="it-nav-ico">🔑</span> Login
    </a>
}
