@model InvenTrack.Models.Category

@{
    ViewData["Title"] = "Category Details";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Category Details</h1>
        </div>
        <div class="text-muted small">View category information.</div>
    </div>

    <div class="d-flex gap-2">
        @if (User.CanManage())
        {
            <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-outline-primary">Edit</a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="it-panel">
    <div class="it-panel-body">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="it-field">
                    <div class="label">Name</div>
                    <div class="value">@Model.Name</div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="it-field">
                    <div class="label">Description</div>
                    <div class="value">@(!string.IsNullOrWhiteSpace(Model.Description) ? Model.Description : "—")</div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            @if (User.CanManage())
            {
                <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-primary">Edit Category</a>
                <a asp-action="Delete" asp-route-id="@Model.ID" class="btn btn-outline-danger">Delete</a>
            }
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
        </div>
    </div>
</div>