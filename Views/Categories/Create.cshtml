@model InvenTrack.Models.Category

@{
    ViewData["Title"] = "Add Category";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Add Category</h1>
        </div>
        <div class="text-muted small">Create a new category for inventory classification.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<form asp-action="Create" method="post">
    <div class="row g-3 g-lg-4">
        <div class="col-lg-8">
            <div class="it-panel">
                <div class="it-panel-header">
                    <div class="fw-bold">Category details</div>
                    <div class="text-muted small">Name and description.</div>
                </div>

                <div class="it-panel-body">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g., IT Equipment" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description" class="form-control" placeholder="e.g., Computers, monitors, peripherals" />
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Create Category</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="it-panel">
                <div class="it-panel-header">
                    <div class="fw-bold">Tip</div>
                    <div class="text-muted small">Make categories consistent.</div>
                </div>
                <div class="it-panel-body">
                    <div class="it-hint">
                        Use simple names that everyone on the team understands (e.g., “Office Supplies”, “IT Equipment”).
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}