@model InvenTrack.Models.Category

@{
    ViewData["Title"] = "Edit Category";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Edit Category</h1>
        </div>
        <div class="text-muted small">Update category name and description.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ID" />

    <div class="row g-3 g-lg-4">
        <div class="col-lg-8">
            <div class="it-panel">
                <div class="it-panel-header">
                    <div class="fw-bold">Category details</div>
                    <div class="text-muted small">Edit the fields below.</div>
                </div>

                <div class="it-panel-body">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description" class="form-control" />
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="it-panel">
                <div class="it-panel-header">
                    <div class="fw-bold">Reminder</div>
                    <div class="text-muted small">Keep data clean.</div>
                </div>
                <div class="it-panel-body">
                    <div class="it-hint">
                        Avoid duplicate category names. Short descriptions are best.
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}