@model IEnumerable<InvenTrack.Models.StorageLocation>

@{
    ViewData["Title"] = "Locations";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Locations</h1>
        </div>
        <div class="text-muted small">Manage where inventory is stored (building/room).</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">+ New Location</a>
    </div>
</div>

<div class="it-panel mb-3">
    <div class="it-panel-body">
        <div class="row g-2 align-items-center">
            <div class="col-lg-8">
                <div class="it-input">
                    <span class="it-input-ico">🔎</span>
                    <input id="locSearch" type="search" class="form-control it-input-field"
                           placeholder="Search by location name, building, or room..." />
                </div>
            </div>

            <div class="col-lg-4 text-lg-end">
                <span class="text-muted small" id="locCount"></span>
            </div>
        </div>
    </div>
</div>

<div class="it-panel">
    <div class="it-panel-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 it-table" id="locTable">
                <thead>
                    <tr>
                        <th style="width: 34%;">Name</th>
                        <th style="width: 33%;">Building</th>
                        <th style="width: 13%;">Room</th>
                        <th class="text-end" style="width: 220px;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">
                                <div class="fw-semibold mb-1">No locations yet</div>
                                <div class="small mb-3">Create locations to keep inventory organized by area.</div>
                                <a asp-action="Create" class="btn btn-primary btn-sm">+ New Location</a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr class="loc-row">
                                <td class="fw-semibold">@item.Name</td>
                                <td class="text-muted">@(!string.IsNullOrWhiteSpace(item.Building) ? item.Building : "—")</td>
                                <td class="text-muted">@(!string.IsNullOrWhiteSpace(item.Room) ? item.Room : "—")</td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-secondary">Details</a>
                                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>

            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const search = document.getElementById('locSearch');
            const rows = Array.from(document.querySelectorAll('.loc-row'));
            const count = document.getElementById('locCount');

            function apply() {
                const q = (search.value || '').toLowerCase().trim();
                let visible = 0;

                rows.forEach(r => {
                    const text = r.innerText.toLowerCase();
                    const show = !q || text.includes(q);
                    r.style.display = show ? '' : 'none';
                    if (show) visible++;
                });

                count.textContent = rows.length ? `${visible} of ${rows.length} locations` : '';
            }

            if (search) search.addEventListener('input', apply);
            apply();
        })();
    </script>
}