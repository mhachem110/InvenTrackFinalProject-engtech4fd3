@model IEnumerable<InvenTrack.Models.StorageLocation>

@{
    ViewData["Title"] = "Storage Locations";
}

<div class="text-center">
    <h1 class="display-5 fw-semibold">Storage Locations</h1>
    <p class="text-muted">Manage where inventory is stored (building/room).</p>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div></div>
    <a asp-action="Create" class="btn btn-primary">
        + Create New Location
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 30%;">@Html.DisplayNameFor(model => model.First().Name)</th>
                        <th style="width: 35%;">@Html.DisplayNameFor(model => model.First().Building)</th>
                        <th style="width: 15%;">@Html.DisplayNameFor(model => model.First().Room)</th>
                        <th class="text-end" style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                No storage locations found. Click <strong>Create New Location</strong> to add one.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@Html.DisplayFor(modelItem => item.Name)</td>
                                <td class="text-muted">@Html.DisplayFor(modelItem => item.Building)</td>
                                <td class="text-muted">@Html.DisplayFor(modelItem => item.Room)</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-outline-secondary me-1">Details</a>
                                    <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>