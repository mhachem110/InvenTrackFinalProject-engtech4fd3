@if (TempData["RegMsg"] != null)
{
    <div class="alert alert-info">@TempData["RegMsg"]</div>
}

@if (TempData["DevConfirmLink"] != null)
{
    <div class="alert alert-warning">
        <div class="fw-semibold mb-1">DEV MODE: Confirmation link</div>
        <a href="@TempData["DevConfirmLink"]">@TempData["DevConfirmLink"]</a>
    </div>
}