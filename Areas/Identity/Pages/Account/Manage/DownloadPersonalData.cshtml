@page
@model DownloadPersonalDataModel
@{
    ViewData["Title"] = "Download Your Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Download Your Data</h1>
        </div>
        <div class="text-muted small">Export the personal data associated with your account.</div>
    </div>
</div>

<div class="row g-3 g-lg-4">
    <div class="col-12 col-lg-4">
        <div class="it-panel">
            <div class="it-panel-header">
                <div>
                    <div class="fw-bold">Account</div>
                    <div class="text-muted small">Manage your account settings.</div>
                </div>
            </div>
            <div class="it-panel-body p-0">
                <partial name="_ManageNav" />
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-8">
        <div class="it-panel">
            <div class="it-panel-header">
                <div>
                    <div class="fw-bold">Export</div>
                    <div class="text-muted small">You’ll receive a JSON file download in your browser.</div>
                </div>
            </div>

            <div class="it-panel-body">
                <div class="alert alert-info mb-3">
                    <div class="fw-semibold">What’s included?</div>
                    <div class="small">
                        This export contains the personal data stored in your Identity account (e.g., email, phone, claims, logins).
                    </div>
                </div>

                <div class="it-panel p-3">
                    <div class="fw-semibold mb-1">Download your data</div>
                    <div class="text-muted small mb-3">
                        Click the button below to download your personal data file.
                    </div>

                    <form method="post" class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            Download JSON
                        </button>
                        <a asp-page="./PersonalData" class="btn btn-outline-secondary">
                            Back
                        </a>
                    </form>
                </div>

                <div class="it-hint mt-3">
                    Tip: If you plan to delete your account, download your data first.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}