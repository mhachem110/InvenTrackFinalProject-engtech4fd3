@page
@model DownloadPersonalDataModel
@{
    ViewData["Title"] = "Download Your Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="it-account-shell">
    <section class="it-subhero">
        <div class="it-subhero__content">
            <div class="it-subhero__kicker">Account Center</div>
            <h1 class="it-subhero__title">Download Your Data</h1>
            <p class="it-subhero__text">
                Export the personal data associated with your Identity account as a file for backup or review.
            </p>
        </div>

        <div class="it-subhero__stats">
            <div class="it-subhero__stat">
                <div class="it-subhero__stat-label">Export format</div>
                <div class="it-subhero__stat-value">JSON</div>
                <div class="it-subhero__stat-text">A downloadable file will open in your browser.</div>
            </div>
            <div class="it-subhero__stat">
                <div class="it-subhero__stat-label">Best practice</div>
                <div class="it-subhero__stat-value">Backup</div>
                <div class="it-subhero__stat-text">Download your data before deleting or replacing the account.</div>
            </div>
        </div>
    </section>

    <div class="it-account-grid">
        <aside class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">Account settings</div>
                <div class="text-muted small">Profile, email, security, and personal data actions.</div>
            </div>
            <div class="it-panel-body p-0">
                <partial name="_ManageNav" />
            </div>
        </aside>

        <div class="it-account-main">
            <section class="it-panel">
                <div class="it-panel-header">
                    <div class="fw-bold">Export</div>
                    <div class="text-muted small">The download includes the personal data stored in your Identity account.</div>
                </div>

                <div class="it-panel-body">
                    <div class="it-account-callout it-account-callout--info">
                        <div class="it-account-callout__title">What's included?</div>
                        <div class="it-account-callout__text">
                            This export contains personal data associated with your Identity account, such as email, phone, claims, and login-related records.
                        </div>
                    </div>

                    <div class="it-account-mini-card mt-3">
                        <div class="it-account-mini-card__title">Download your data</div>
                        <div class="it-account-mini-card__text mb-3">Click below to generate and download your personal data file.</div>

                        <form method="post" class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Download JSON</button>
                            <a asp-page="./PersonalData" class="btn btn-outline-secondary">Back</a>
                        </form>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
