@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="it-account-shell">
    <section class="it-subhero">
        <div class="it-subhero__content">
            <div class="it-subhero__kicker">Account Center</div>
            <h1 class="it-subhero__title">Change Password</h1>
            <p class="it-subhero__text">
                Refresh your password to keep your account secure and reduce risk across the inventory workspace.
            </p>
        </div>

        <div class="it-subhero__stats">
            <div class="it-subhero__stat">
                <div class="it-subhero__stat-label">Password policy</div>
                <div class="it-subhero__stat-value">Strong</div>
                <div class="it-subhero__stat-text">Use 8+ characters with upper/lower case and numbers.</div>
            </div>
            <div class="it-subhero__stat">
                <div class="it-subhero__stat-label">Security tip</div>
                <div class="it-subhero__stat-value">Unique</div>
                <div class="it-subhero__stat-text">Avoid reusing passwords from other accounts or services.</div>
            </div>
        </div>
    </section>

    <partial name="_StatusMessage" for="StatusMessage" />

    <div class="it-account-grid">
        <aside class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">Account settings</div>
                <div class="text-muted small">Identity, security, and personal data tools.</div>
            </div>
            <div class="it-panel-body p-0">
                <partial name="_ManageNav" />
            </div>
        </aside>

        <div class="it-account-main">
            <section class="it-panel">
                <div class="it-panel-header">
                    <div class="fw-bold">Password update</div>
                    <div class="text-muted small">Change your current password without affecting the rest of your profile.</div>
                </div>

                <div class="it-panel-body">
                    <form id="change-password-form" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="Input.OldPassword" class="form-label"></label>
                                <input asp-for="Input.OldPassword"
                                       class="form-control"
                                       autocomplete="current-password"
                                       aria-required="true"
                                       placeholder="Current password" />
                                <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Input.NewPassword" class="form-label"></label>
                                <input asp-for="Input.NewPassword"
                                       class="form-control"
                                       autocomplete="new-password"
                                       aria-required="true"
                                       placeholder="New password" />
                                <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                                <input asp-for="Input.ConfirmPassword"
                                       class="form-control"
                                       autocomplete="new-password"
                                       aria-required="true"
                                       placeholder="Confirm new password" />
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <button type="submit" class="btn btn-primary w-100">Update password</button>
                            </div>
                        </div>
                    </form>
                </div>
            </section>

            <section class="it-account-card-grid">
                <div class="it-account-mini-card">
                    <div class="it-account-mini-card__title">Best practice</div>
                    <div class="it-account-mini-card__text">Use a password that is unique to InvenTrack and not shared with email or social accounts.</div>
                </div>

                <div class="it-account-mini-card">
                    <div class="it-account-mini-card__title">Extra protection</div>
                    <div class="it-account-mini-card__text">For stronger security, pair a fresh password with two-factor authentication from the next tab.</div>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
