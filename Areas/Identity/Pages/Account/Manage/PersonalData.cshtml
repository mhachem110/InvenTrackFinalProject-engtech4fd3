@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="it-account-shell">
    <section class="it-subhero">
        <div class="it-subhero__content">
            <div class="it-subhero__kicker">Account Center</div>
            <h1 class="it-subhero__title">Personal Data</h1>
            <p class="it-subhero__text">
                Review the data actions available for your account, including export for backup and permanent deletion.
            </p>
        </div>

        <div class="it-subhero__stats">
            <div class="it-subhero__stat">
                <div class="it-subhero__stat-label">Export</div>
                <div class="it-subhero__stat-value">Available</div>
                <div class="it-subhero__stat-text">Download the personal data stored in your Identity account.</div>
            </div>
            <div class="it-subhero__stat">
                <div class="it-subhero__stat-label">Delete</div>
                <div class="it-subhero__stat-value">Permanent</div>
                <div class="it-subhero__stat-text">Account deletion cannot be undone after confirmation.</div>
            </div>
        </div>
    </section>

    <div class="it-account-grid">
        <aside class="it-panel">
            <div class="it-panel-header">
                <div class="fw-bold">Account settings</div>
                <div class="text-muted small">Switch between account profile, security, and data pages.</div>
            </div>
            <div class="it-panel-body p-0">
                <partial name="_ManageNav" />
            </div>
        </aside>

        <div class="it-account-main">
            <section class="it-panel">
                <div class="it-panel-header">
                    <div class="fw-bold">Your data</div>
                    <div class="text-muted small">Export or permanently remove the personal data connected to this account.</div>
                </div>

                <div class="it-panel-body">
                    <div class="it-account-callout it-account-callout--warn">
                        <div class="it-account-callout__title">Deleting your data is permanent</div>
                        <div class="it-account-callout__text">Your account will be removed and cannot be recovered after deletion.</div>
                    </div>

                    <div class="it-account-card-grid mt-3">
                        <div class="it-account-mini-card">
                            <div class="it-account-mini-card__title">Download personal data</div>
                            <div class="it-account-mini-card__text mb-3">Export the personal data associated with your account before making irreversible changes.</div>

                            <form id="download-data" asp-page="DownloadPersonalData" method="post">
                                <button class="btn btn-outline-primary w-100" type="submit">Download</button>
                            </form>
                        </div>

                        <div class="it-account-mini-card">
                            <div class="it-account-mini-card__title text-danger">Delete account</div>
                            <div class="it-account-mini-card__text mb-3">Permanently delete your account and associated personal data.</div>

                            <a id="delete" asp-page="DeletePersonalData" class="btn btn-outline-danger w-100">Delete</a>
                        </div>
                    </div>

                    <div class="it-account-note mt-3">
                        If you only need access removed, ask an admin to disable or lock the account instead of deleting it.
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
