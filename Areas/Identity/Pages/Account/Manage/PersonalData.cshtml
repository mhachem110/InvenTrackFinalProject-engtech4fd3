@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Personal Data</h1>
        </div>
        <div class="text-muted small">Download or permanently delete your account data.</div>
    </div>
</div>

<div class="row g-3 g-lg-4">
    <div class="col-12 col-lg-4">
        <div class="it-panel">
            <div class="it-panel-header">
                <div>
                    <div class="fw-bold">Account</div>
                    <div class="text-muted small">Manage your account settings.</div>
                </div>
            </div>
            <div class="it-panel-body p-0">
                <partial name="_ManageNav" />
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-8">
        <div class="it-panel">
            <div class="it-panel-header">
                <div>
                    <div class="fw-bold">Your data</div>
                    <div class="text-muted small">Export or remove your Identity data.</div>
                </div>
            </div>

            <div class="it-panel-body">
                <div class="alert alert-warning mb-3">
                    <div class="fw-semibold">Deleting your data is permanent.</div>
                    <div class="small">Your account will be removed and cannot be recovered.</div>
                </div>

                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <div class="it-panel p-3">
                            <div class="fw-semibold mb-1">Download personal data</div>
                            <div class="text-muted small mb-3">Export the personal data associated with your account.</div>

                            <form id="download-data" asp-page="DownloadPersonalData" method="post">
                                <button class="btn btn-outline-primary w-100" type="submit">Download</button>
                            </form>
                        </div>
                    </div>

                    <div class="col-12 col-md-6">
                        <div class="it-panel p-3">
                            <div class="fw-semibold mb-1 text-danger">Delete account</div>
                            <div class="text-muted small mb-3">Permanently delete your account and associated data.</div>

                            <a id="delete" asp-page="DeletePersonalData" class="btn btn-outline-danger w-100">Delete</a>
                        </div>
                    </div>
                </div>

                <div class="it-hint mt-3">
                    Tip: If you just need access removed, ask an Admin to disable or lock the account instead.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}