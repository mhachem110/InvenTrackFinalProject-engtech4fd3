@page
@model RegisterModel

@{
    ViewData["Title"] = "Register";
}

<div class="it-pagehead mb-3">
    <div>
        <div class="d-flex align-items-center gap-2">
            <div class="it-page-dot"></div>
            <h1 class="h3 mb-0 fw-bold">Registration Disabled</h1>
        </div>
        <div class="text-muted small">Accounts for InvenTrack are created by an administrator.</div>
    </div>

    <div class="d-flex gap-2">
        <a asp-page="./Login" class="btn btn-outline-secondary">Back to Login</a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8 col-xl-6">
        <div class="it-panel">
            <div class="it-panel-header">
                <div>
                    <div class="fw-bold">Internal access only</div>
                    <div class="text-muted small">Self-registration is not available for this system.</div>
                </div>
            </div>

            <div class="it-panel-body">
                <div class="it-hint mb-3">
                    InvenTrack is an internal tool. New accounts must be created and assigned by an administrator.
                </div>

                <div class="text-muted small mb-3">
                    If you need access, contact your administrator or project owner and ask them to create your account and assign your role.
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-page="./Login" class="btn btn-primary">Go to Login</a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Home</a>
                </div>
            </div>
        </div>
    </div>
</div>